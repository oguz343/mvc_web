@{
    Layout = null;
    ViewData["Title"] = "Sistem Sıfırlama";

    var report = TempData["Report"]?.ToString() ?? "";
    var success = TempData["Success"]?.ToString() ?? "";
    var error = TempData["Error"]?.ToString() ?? "";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Sistem Sıfırlama</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(239, 68, 68, .14), transparent 32%),
                radial-gradient(circle at bottom right, rgba(79, 70, 229, .16), transparent 34%),
                #f8fafc;
            color: #0f172a;
        }

        .reset-shell {
            max-width: 1100px;
            margin: 0 auto;
            padding: 28px;
        }

        .hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            padding: 30px;
            border-radius: 34px;
            background: rgba(255, 255, 255, .95);
            border: 1px solid #e2e8f0;
            box-shadow: 0 24px 60px rgba(15, 23, 42, .10);
            margin-bottom: 18px;
        }

        .hero small {
            display: block;
            color: #ef4444;
            font-weight: 900;
            margin-bottom: 6px;
        }

        .hero h1 {
            margin: 0;
            font-size: 38px;
            font-weight: 950;
            letter-spacing: -1.4px;
        }

        .hero p {
            margin: 8px 0 0;
            color: #64748b;
            font-weight: 800;
            line-height: 1.45;
        }

        .hero-icon {
            width: 82px;
            height: 82px;
            border-radius: 30px;
            display: grid;
            place-items: center;
            background: #fee2e2;
            font-size: 42px;
            box-shadow: 0 18px 38px rgba(239, 68, 68, .18);
        }

        .top-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .top-actions a {
            text-decoration: none;
            padding: 13px 17px;
            border-radius: 18px;
            font-weight: 900;
            background: #eef2ff;
            color: #4f46e5;
            border: 1px solid #c7d2fe;
        }

        .alert {
            padding: 15px 17px;
            border-radius: 20px;
            font-weight: 900;
            margin-bottom: 14px;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fecaca;
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 18px;
            margin-bottom: 18px;
        }

        .card {
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 32px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .08);
            padding: 24px;
        }

        .card.danger {
            border-color: #fecaca;
        }

        .card.safe {
            border-color: #bbf7d0;
        }

        .card-icon {
            width: 62px;
            height: 62px;
            border-radius: 23px;
            display: grid;
            place-items: center;
            font-size: 31px;
            margin-bottom: 14px;
        }

        .danger .card-icon {
            background: #fee2e2;
        }

        .safe .card-icon {
            background: #dcfce7;
        }

        .card h2 {
            margin: 0 0 12px;
            font-size: 24px;
            font-weight: 950;
        }

        .delete-list {
            display: grid;
            gap: 10px;
        }

        .delete-list span {
            padding: 13px 14px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            font-weight: 850;
        }

        .keep-box {
            padding: 16px;
            border-radius: 22px;
            background: #ecfdf5;
            border: 1px solid #a7f3d0;
            display: grid;
            gap: 5px;
            margin-bottom: 12px;
        }

        .keep-box strong {
            color: #047857;
            font-weight: 950;
        }

        .keep-box span {
            color: #065f46;
            font-weight: 850;
        }

        .confirm-card {
            background: white;
            border: 1px solid #fecaca;
            border-radius: 32px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .08);
            padding: 24px;
        }

        .confirm-card h2 {
            margin: 0;
            font-size: 26px;
            font-weight: 950;
        }

        .confirm-card p {
            color: #64748b;
            font-weight: 800;
            line-height: 1.45;
        }

        .confirm-card form {
            display: grid;
            gap: 12px;
            margin-top: 16px;
        }

        .confirm-card input {
            width: 100%;
            border: 1px solid #fecaca;
            background: #fff7f7;
            color: #991b1b;
            outline: none;
            border-radius: 20px;
            padding: 15px 16px;
            font-weight: 950;
            font-size: 16px;
        }

        .confirm-card button {
            min-height: 58px;
            border: none;
            border-radius: 22px;
            cursor: pointer;
            color: white;
            background: linear-gradient(135deg, #ef4444, #b91c1c);
            font-weight: 950;
            font-size: 15px;
            box-shadow: 0 18px 36px rgba(239, 68, 68, .24);
        }

        .report-card {
            background: white;
            border: 1px solid #bae6fd;
            border-radius: 32px;
            box-shadow: 0 22px 50px rgba(15, 23, 42, .08);
            padding: 24px;
            margin-bottom: 18px;
        }

        .report-card pre {
            white-space: pre-wrap;
            padding: 16px;
            border-radius: 20px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #0f172a;
            font-weight: 800;
            line-height: 1.5;
        }

        @@media (max-width: 850px) {
            .reset-shell {
                padding: 16px;
            }

            .hero {
                flex-direction: column;
                align-items: flex-start;
            }

            .grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <main class="reset-shell">
        <section class="hero">
            <div>
                <small>Yönetim Paneli</small>
                <h1>Sistem Verilerini Sıfırla</h1>
                <p>
                    Kodlar, görünüş ve işlevler kalır. Sadece Firestore içindeki okul verileri temizlenir.
                </p>
            </div>

            <div class="hero-icon">⚠️</div>
        </section>

        <div class="top-actions">
            <a asp-controller="Dashboard" asp-action="Index">Admin Paneline Dön</a>
            <a href="/Lessons">Derslere Dön</a>
        </div>

        @if (!string.IsNullOrWhiteSpace(success))
        {
            <div class="alert alert-success">@success</div>
        }

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (!string.IsNullOrWhiteSpace(report))
        {
            <section class="report-card">
                <h2>Temizleme Raporu</h2>
                <pre>@report</pre>
            </section>
        }

        <section class="grid">
            <article class="card danger">
                <div class="card-icon">🧨</div>
                <h2>Silinecek Veriler</h2>

                <div class="delete-list">
                    <span>👨‍🎓 Öğrenciler</span>
                    <span>👨‍🏫 Öğretmenler</span>
                    <span>👨‍👩‍👧 Veliler</span>
                    <span>🏫 Sınıflar</span>
                    <span>📚 Dersler</span>
                    <span>📝 Ödevler</span>
                    <span>📥 Teslimler</span>
                    <span>📣 Duyurular</span>
                    <span>🔑 Şifre talepleri</span>
                </div>
            </article>

            <article class="card safe">
                <div class="card-icon">🛡️</div>
                <h2>Korunacak</h2>

                <div class="keep-box">
                    <strong>Admin hesabı korunacak</strong>
                    <span>No: 0000</span>
                    @if (ViewBag.IsDevelopment == true)
                    {
                        <span>Geliştirme şifresi: admin123</span>
                    }
                    else
                    {
                        <span>Şifre: Mevcut güvenli admin şifresi korunur</span>
                    }
                </div>

                <p>
                    Sıfırlamadan sonra sisteme yine admin hesabıyla giriş yapabileceksiniz.
                </p>
            </article>
        </section>

        <section class="confirm-card">
            <h2>Son Onay</h2>
            <p>
                Bu işlem geri alınamaz. Eminseniz aşağıdaki kutuya büyük harflerle
                <strong>SIFIRLA</strong> yazıp butona basın.
            </p>

            <form asp-controller="SystemReset" asp-action="Reset" method="post" onsubmit="return confirm('Tüm okul verileri sıfırlansın mı? Bu işlem geri alınamaz.');">
                @Html.AntiForgeryToken()

                <input name="confirmText"
                       autocomplete="off"
                       placeholder="SIFIRLA yazın"
                       required />

                <button type="submit">
                    🧨 Verileri Sıfırla
                </button>
            </form>
        </section>
    </main>
</body>
</html>
