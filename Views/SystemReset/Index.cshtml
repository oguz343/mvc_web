@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sistem Sıfırlama";
    ViewData["PageTitle"] = "Sistem Sıfırlama";
    ViewData["PageSubtitle"] = "Sistemdeki kritik verileri sıfırlamadan önce dikkatlice kontrol edin.";
}

<style>
    .reset-v2 {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .reset-v2-hero,
    .reset-v2-card,
    .reset-v2-side {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(239, 68, 68, .12), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .reset-v2-hero {
        padding: 24px;
        border-radius: 32px;
    }

    .reset-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #fecaca;
        background: rgba(239, 68, 68, .12);
        border: 1px solid rgba(248, 113, 113, .22);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .reset-v2-hero h1 {
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .reset-v2-hero p {
        max-width: 820px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .reset-v2-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        align-items: start;
    }

    .reset-v2-card,
    .reset-v2-side {
        padding: 22px;
        border-radius: 30px;
    }

    .reset-v2-warning {
        padding: 16px;
        border-radius: 18px;
        color: #fecaca;
        background: rgba(239, 68, 68, .12);
        border: 1px solid rgba(248, 113, 113, .22);
        font-size: 14px;
        font-weight: 850;
        line-height: 1.55;
    }

    .reset-v2-form {
        display: grid;
        gap: 14px;
        margin-top: 16px;
    }

    .reset-v2-field {
        display: grid;
        gap: 8px;
    }

    .reset-v2-field label {
        color: #dbeafe;
        font-size: 13px;
        font-weight: 950;
    }

    .reset-v2-field input {
        width: 100%;
        min-height: 48px;
        padding: 0 13px;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .18);
        outline: none;
        color: #ffffff;
        background: rgba(7, 17, 31, .58);
        font-size: 14px;
        font-weight: 750;
    }

    .reset-v2-field input:focus {
        border-color: rgba(248, 113, 113, .45);
        box-shadow: 0 0 0 4px rgba(239, 68, 68, .10);
    }

    .reset-v2-check {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 14px;
        border-radius: 18px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
    }

    .reset-v2-check input {
        width: 18px;
        height: 18px;
        margin-top: 1px;
        accent-color: #ef4444;
    }

    .reset-v2-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .reset-v2-danger,
    .reset-v2-back {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 950;
    }

    .reset-v2-danger {
        color: #ffffff;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        border-color: rgba(248, 113, 113, .28);
        box-shadow: 0 14px 30px rgba(239, 68, 68, .22);
    }

    .reset-v2-back {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border-color: rgba(148, 163, 184, .18);
    }

    .reset-v2-side h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .reset-v2-side p {
        margin: 8px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.55;
    }

    .reset-v2-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .reset-v2-note {
        padding: 12px;
        border-radius: 16px;
        color: #fecaca;
        background: rgba(239, 68, 68, .10);
        border: 1px solid rgba(248, 113, 113, .18);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
    }

    .reset-v2-report {
        padding: 22px;
        border-radius: 30px;
        border: 1px solid rgba(125, 211, 252, .22);
        color: #dbeafe;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
    }

    .reset-v2-report h3 {
        margin: 0 0 12px;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .reset-v2-report pre {
        margin: 0;
        white-space: pre-wrap;
        color: #dbeafe;
        font: inherit;
        line-height: 1.55;
    }

    @@media (max-width: 1100px) {
        .reset-v2-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .reset-v2-hero,
        .reset-v2-card,
        .reset-v2-side {
            border-radius: 22px;
            padding: 16px;
        }

        .reset-v2-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .reset-v2-danger,
        .reset-v2-back {
            width: 100%;
        }
    }
</style>

<div class="reset-v2">
    <section class="reset-v2-hero">
        <div class="reset-v2-kicker">Tehlikeli İşlem</div>

        <h1>Sistem sıfırlama merkezi.</h1>

        <p>
            Bu sayfadaki işlemler geri alınamayabilir. Devam etmeden önce neyin silineceğini ve hangi verilerin korunacağını dikkatlice kontrol edin.
        </p>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Report"] != null)
    {
        <section class="reset-v2-report">
            <h3>Temizleme Raporu</h3>
            <pre>@TempData["Report"]</pre>
        </section>
    }

    <section class="reset-v2-layout">
        <div class="reset-v2-card">
            <div class="reset-v2-warning">
                ⚠️ Bu işlem kritik sistem verilerini silebilir. Emin değilseniz bu sayfada işlem yapmayın.
            </div>

            <form asp-controller="SystemReset"
                  asp-action="Reset"
                  method="post"
                  onsubmit="return confirm('Tum okul verileri sifirlansin mi? Bu islem geri alinamaz.');"
                  class="reset-v2-form">

                @Html.AntiForgeryToken()

                <div class="reset-v2-field">
                    <label>Onay Metni</label>
                    <input type="text"
                           name="confirmText"
                           placeholder="SIFIRLA yazın"
                           autocomplete="off"
                           required />
                </div>
                <div class="reset-v2-check">
                    <span>Admin hesabi otomatik korunur. Diger okul verileri temizlenir.</span>
                </div>

                <div class="reset-v2-actions">
                    <a asp-controller="Dashboard"
                       asp-action="Index"
                       class="reset-v2-back">
                        Vazgeç
                    </a>

                    <button type="submit" class="reset-v2-danger">
                        🧨 Sıfırlama İşlemini Başlat
                    </button>
                </div>
            </form>
        </div>

        <aside class="reset-v2-side">
            <h3>Kontrol Listesi</h3>

            <p>
                Bu ekranı sadece test verilerini temizlemek veya sistemi yeniden kurmak için kullanın.
            </p>

            <div class="reset-v2-list">
                <div class="reset-v2-note">🚨 İşlem geri alınamayabilir.</div>
                <div class="reset-v2-note">🛡️ Adminleri koru seçeneği açık kalmalı.</div>
                <div class="reset-v2-note">📦 Gerçek veride işlem yapmadan önce yedek alın.</div>
            </div>
        </aside>
    </section>
</div>
