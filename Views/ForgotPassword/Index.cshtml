@model mvc_web.Models.ForgotPasswordViewModel

@{
    Layout = null;
    ViewData["Title"] = "Şifremi Unuttum";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Şifremi Unuttum</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(79,70,229,.22), transparent 35%),
                radial-gradient(circle at bottom right, rgba(6,182,212,.18), transparent 35%),
                linear-gradient(135deg, #0f172a, #111827);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 22px;
            color: #0f172a;
        }

        .forgot-card {
            width: 100%;
            max-width: 540px;
            background: rgba(255,255,255,.96);
            border-radius: 32px;
            padding: 32px;
            box-shadow: 0 30px 90px rgba(0,0,0,.35);
        }

        .logo {
            width: 68px;
            height: 68px;
            border-radius: 24px;
            background: linear-gradient(135deg, #4f46e5, #06b6d4);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 32px;
            margin-bottom: 18px;
        }

        h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 950;
            letter-spacing: -.7px;
        }

        p {
            margin: 8px 0 22px;
            color: #64748b;
            font-weight: 800;
            line-height: 1.5;
        }

        .alert {
            border-radius: 18px;
            padding: 14px 16px;
            font-weight: 900;
            margin-bottom: 16px;
        }

        .alert-success {
            background: #dcfce7;
            color: #166534;
        }

        .alert-danger {
            background: #fee2e2;
            color: #991b1b;
        }

        .form-grid {
            display: grid;
            gap: 15px;
        }

        label {
            display: block;
            font-weight: 950;
            margin-bottom: 7px;
            color: #1e293b;
        }

        .optional {
            color: #64748b;
            font-size: 12px;
            font-weight: 850;
        }

        input,
        select,
        textarea {
            width: 100%;
            border: 1px solid #e5e7eb;
            background: #f8fafc;
            border-radius: 18px;
            min-height: 54px;
            padding: 0 15px;
            outline: none;
            color: #0f172a;
            font-weight: 850;
            font-size: 15px;
        }

        textarea {
            min-height: 110px;
            resize: vertical;
            padding: 14px 15px;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: #4f46e5;
            background: #fff;
            box-shadow: 0 0 0 5px rgba(79,70,229,.11);
        }

        .submit-btn {
            width: 100%;
            min-height: 56px;
            border: 0;
            border-radius: 18px;
            background: linear-gradient(135deg, #4f46e5, #06b6d4);
            color: #fff;
            font-weight: 950;
            font-size: 16px;
            cursor: pointer;
            margin-top: 6px;
        }

        .back-link {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 52px;
            border-radius: 18px;
            background: #eef2ff;
            color: #4338ca;
            text-decoration: none;
            font-weight: 950;
            margin-top: 12px;
        }
    </style>
</head>

<body>
    <main class="forgot-card">
        <div class="logo">🔐</div>

        <h1>Şifremi Unuttum</h1>
        <p>Rol, ad soyad ve numara zorunludur. Not alanı isteğe bağlıdır.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(x => x.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="ForgotPassword"
              asp-action="Index"
              method="post"
              class="form-grid"
              novalidate>

            @Html.AntiForgeryToken()

            <div>
                <label>Rol</label>
                <select asp-for="Role">
                    <option value="">Rol seç</option>
                    <option value="Öğrenci">Öğrenci</option>
                    <option value="Öğretmen">Öğretmen</option>
                    <option value="Veli">Veli</option>
                </select>
            </div>

            <div>
                <label>Ad Soyad</label>
                <input asp-for="Name"
                       type="text"
                       placeholder="Örn: Ali Yılmaz" />
            </div>

            <div>
                <label>Numara</label>
                <input asp-for="Number"
                       type="text"
                       placeholder="Okul numarası" />
            </div>

            <div>
                <label>
                    Not
                    <span class="optional">(isteğe bağlı)</span>
                </label>

                <textarea asp-for="Note"
                          placeholder="İsterseniz kısa açıklama yazabilirsiniz. Boş bırakabilirsiniz."></textarea>
            </div>

            <button type="submit" class="submit-btn">
                Talep Gönder
            </button>
        </form>

        <a asp-controller="Auth" asp-action="Login" class="back-link">
            ← Giriş ekranına dön
        </a>
    </main>
</body>
</html>