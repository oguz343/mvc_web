@model mvc_web.Models.ForgotPasswordViewModel

@{
    Layout = null;
    ViewData["Title"] = "Şifremi Unuttum";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Şifremi Unuttum - Ödev Sistemi</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --bg: #07111f;
            --card: rgba(15, 23, 42, .82);
            --stroke: rgba(148, 163, 184, .18);
            --text: #f8fafc;
            --muted: #94a3b8;
            --primary: #38bdf8;
            --purple: #7c3aed;
            --danger: #ef4444;
            --success: #22c55e;
        }

        * {
            box-sizing: border-box;
        }

        body {
            min-height: 100vh;
            margin: 0;
            color: var(--text);
            font-family: "Inter", "Segoe UI", Arial, sans-serif;
            background:
                radial-gradient(circle at 0% 0%, rgba(37, 99, 235, .34), transparent 32%),
                radial-gradient(circle at 100% 0%, rgba(124, 58, 237, .30), transparent 34%),
                radial-gradient(circle at 60% 100%, rgba(6, 182, 212, .18), transparent 34%),
                linear-gradient(135deg, #06101e 0%, #0b1630 45%, #160f2f 100%);
            overflow-x: hidden;
        }

        .forgot-bg-grid {
            position: fixed;
            inset: 0;
            pointer-events: none;
            background-image:
                linear-gradient(rgba(148, 163, 184, .055) 1px, transparent 1px),
                linear-gradient(90deg, rgba(148, 163, 184, .055) 1px, transparent 1px);
            background-size: 44px 44px;
            mask-image: linear-gradient(to bottom, rgba(0, 0, 0, .70), transparent 86%);
        }

        .forgot-shell {
            width: min(1180px, calc(100% - 36px));
            min-height: 100vh;
            display: grid;
            grid-template-columns: minmax(0, 1fr) 430px;
            gap: 24px;
            align-items: center;
            margin: 0 auto;
            padding: 36px 0;
            position: relative;
            z-index: 1;
        }

        .forgot-hero {
            padding: 28px;
            border-radius: 34px;
            background:
                radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .13), transparent 34%),
                radial-gradient(circle at 100% 0%, rgba(139, 92, 246, .15), transparent 34%),
                linear-gradient(135deg, rgba(15, 23, 42, .70), rgba(17, 24, 39, .58));
            border: 1px solid rgba(148, 163, 184, .18);
            box-shadow: 0 24px 70px rgba(0, 0, 0, .30);
            backdrop-filter: blur(18px);
        }

        .forgot-kicker {
            width: fit-content;
            min-height: 31px;
            display: inline-flex;
            align-items: center;
            padding: 0 12px;
            border-radius: 999px;
            color: #67e8f9;
            background: rgba(56, 189, 248, .10);
            border: 1px solid rgba(103, 232, 249, .20);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: .16em;
            text-transform: uppercase;
        }

        .forgot-hero h1 {
            max-width: 760px;
            margin: 18px 0 0;
            color: #ffffff;
            font-size: clamp(42px, 5vw, 76px);
            font-weight: 950;
            line-height: .95;
            letter-spacing: -.075em;
        }

        .forgot-hero p {
            max-width: 680px;
            margin: 18px 0 0;
            color: #aab8cf;
            font-size: 16px;
            font-weight: 700;
            line-height: 1.7;
        }

        .forgot-steps {
            display: grid;
            gap: 12px;
            margin-top: 24px;
        }

        .forgot-step {
            display: grid;
            grid-template-columns: 48px minmax(0, 1fr);
            gap: 13px;
            align-items: center;
            padding: 13px;
            border-radius: 20px;
            background: rgba(255, 255, 255, .050);
            border: 1px solid rgba(148, 163, 184, .13);
        }

        .forgot-step-icon {
            width: 48px;
            height: 48px;
            display: grid;
            place-items: center;
            border-radius: 17px;
            color: #ffffff;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            font-size: 22px;
        }

        .forgot-step strong {
            display: block;
            color: #ffffff;
            font-size: 14px;
            font-weight: 950;
        }

        .forgot-step span {
            display: block;
            margin-top: 4px;
            color: #94a3b8;
            font-size: 13px;
            font-weight: 750;
            line-height: 1.45;
        }

        .forgot-card {
            padding: 24px;
            border-radius: 34px;
            background:
                radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
                linear-gradient(135deg, rgba(15, 23, 42, .92), rgba(17, 24, 39, .84));
            border: 1px solid rgba(148, 163, 184, .20);
            box-shadow: 0 24px 70px rgba(0, 0, 0, .34);
            backdrop-filter: blur(18px);
        }

        .forgot-brand {
            display: flex;
            align-items: center;
            gap: 13px;
            margin-bottom: 22px;
        }

        .forgot-brand-icon {
            width: 56px;
            height: 56px;
            display: grid;
            place-items: center;
            border-radius: 19px;
            color: #ffffff;
            background:
                radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .28), transparent 28%),
                linear-gradient(135deg, #2563eb, #7c3aed 58%, #06b6d4);
            box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
            font-size: 26px;
        }

        .forgot-brand strong {
            display: block;
            color: #ffffff;
            font-size: 18px;
            font-weight: 950;
            line-height: 1.1;
        }

        .forgot-brand span {
            display: block;
            margin-top: 4px;
            color: #94a3b8;
            font-size: 12px;
            font-weight: 800;
        }

        .forgot-form {
            display: grid;
            gap: 14px;
        }

        .forgot-field {
            display: grid;
            gap: 8px;
        }

        .forgot-field label {
            color: #dbeafe;
            font-size: 13px;
            font-weight: 950;
        }

        .forgot-field input,
        .forgot-field select,
        .forgot-field textarea {
            width: 100%;
            min-height: 50px;
            padding: 0 14px;
            border-radius: 16px;
            border: 1px solid rgba(148, 163, 184, .18);
            outline: none;
            color: #ffffff;
            background: rgba(7, 17, 31, .62);
            font-size: 14px;
            font-weight: 750;
            color-scheme: dark;
        }

        .forgot-field input:-webkit-autofill,
        .forgot-field input:-webkit-autofill:hover,
        .forgot-field input:-webkit-autofill:focus,
        .forgot-field textarea:-webkit-autofill,
        .forgot-field textarea:-webkit-autofill:hover,
        .forgot-field textarea:-webkit-autofill:focus {
            -webkit-text-fill-color: #ffffff;
            box-shadow: 0 0 0 1000px #081421 inset;
            caret-color: #ffffff;
            border-color: rgba(103, 232, 249, .35);
        }

        .forgot-field textarea {
            min-height: 120px;
            padding-top: 13px;
            resize: vertical;
            line-height: 1.55;
        }

        .forgot-field input::placeholder,
        .forgot-field textarea::placeholder {
            color: #64748b;
        }

        .forgot-field input:focus,
        .forgot-field select:focus,
        .forgot-field textarea:focus {
            color: #ffffff;
            background: rgba(7, 17, 31, .78);
            border-color: rgba(103, 232, 249, .45);
            box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
        }

        .forgot-field option {
            color: #0f172a;
            background: #ffffff;
        }

        .forgot-submit {
            min-height: 50px;
            border: 0;
            border-radius: 16px;
            color: #ffffff;
            cursor: pointer;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
            font-size: 14px;
            font-weight: 950;
            transition: .16s ease;
        }

        .forgot-submit:hover {
            transform: translateY(-1px);
        }

        .forgot-submit:disabled {
            opacity: .78;
            cursor: wait;
            transform: none;
        }

        .forgot-back {
            min-height: 46px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-top: 10px;
            border-radius: 16px;
            color: #dbeafe;
            background: rgba(255, 255, 255, .060);
            border: 1px solid rgba(148, 163, 184, .18);
            text-decoration: none;
            font-size: 13px;
            font-weight: 950;
        }

        .forgot-alert {
            padding: 14px 16px;
            margin-bottom: 14px;
            border-radius: 17px;
            font-size: 13px;
            font-weight: 850;
            line-height: 1.5;
        }

        .forgot-alert.success {
            color: #bbf7d0;
            background: rgba(34, 197, 94, .12);
            border: 1px solid rgba(74, 222, 128, .20);
        }

        .forgot-alert.error {
            color: #fecaca;
            background: rgba(239, 68, 68, .12);
            border: 1px solid rgba(248, 113, 113, .20);
        }

        @@media (max-width: 980px) {
            .forgot-shell {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 620px) {
            .forgot-shell {
                width: min(100% - 24px, 100%);
                padding: 20px 0;
            }

            .forgot-hero,
            .forgot-card {
                border-radius: 24px;
                padding: 18px;
            }

            .forgot-hero h1 {
                font-size: 40px;
            }
        }
    </style>
</head>

<body>
    <div class="forgot-bg-grid"></div>

    <main class="forgot-shell">
        <section class="forgot-hero">
            <div class="forgot-kicker">Şifre Kurtarma</div>

            <h1>Hesabına tekrar erişim iste.</h1>

            <p>
                Okul numaranı ve rolünü seçerek şifre sıfırlama talebi oluştur. Admin talebi onayladığında yeni aktivasyon kodun sistemde görünür.
            </p>

            <div class="forgot-steps">
                <div class="forgot-step">
                    <div class="forgot-step-icon">1</div>
                    <div>
                        <strong>Rolünü seç</strong>
                        <span>Öğrenci, öğretmen veya veli hesabını seç.</span>
                    </div>
                </div>

                <div class="forgot-step">
                    <div class="forgot-step-icon">2</div>
                    <div>
                        <strong>Numaranı yaz</strong>
                        <span>Okul numarası / kullanıcı numarası ile talep oluştur.</span>
                    </div>
                </div>

                <div class="forgot-step">
                    <div class="forgot-step-icon">3</div>
                    <div>
                        <strong>Admin onayı bekle</strong>
                        <span>Onay sonrası yeni aktivasyon kodu talep kartında görünür.</span>
                    </div>
                </div>
            </div>
        </section>

        <section class="forgot-card">
            <div class="forgot-brand">
                <div class="forgot-brand-icon">🔐</div>

                <div>
                    <strong>Şifremi Unuttum</strong>
                    <span>Ödev Sistemi güvenli talep ekranı</span>
                </div>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="forgot-alert success">
                    @TempData["Success"]
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="forgot-alert error">
                    @TempData["Error"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="forgot-alert error">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="ForgotPassword"
                  asp-action="Index"
                  method="post"
                  class="forgot-form">

                @Html.AntiForgeryToken()

                <div class="forgot-field">
                    <label>Rol</label>
                    <select asp-for="Role" required>
                        <option value="">Rol seçin</option>
                        <option value="Öğrenci">Öğrenci</option>
                        <option value="Öğretmen">Öğretmen</option>
                        <option value="Veli">Veli</option>
                    </select>
                </div>

                <div class="forgot-field">
                    <label>Ad Soyad</label>
                    <input asp-for="Name"
                           type="text"
                           maxlength="80"
                           placeholder="Adinizi ve soyadinizi yazin"
                           autocomplete="name"
                           required />
                </div>

                <div class="forgot-field">
                    <label>Okul / Kullanıcı No</label>
                    <input asp-for="Number"
                           type="text"
                           maxlength="20"
                           placeholder="Örn: 1001"
                           autocomplete="off"
                           required />
                </div>

                <div class="forgot-field">
                    <label>Açıklama</label>
                    <textarea asp-for="Note"
                              maxlength="300"
                              placeholder="İsterseniz kısa açıklama yazabilirsiniz."></textarea>
                </div>

                <button type="submit" class="forgot-submit" data-loading-text="Talep gönderiliyor...">
                    🔑 Şifre Talebi Oluştur
                </button>

                <a asp-controller="Auth"
                   asp-action="Login"
                   class="forgot-back">
                    Giriş ekranına dön
                </a>
            </form>
        </section>
    </main>

    <script>
        document.querySelector(".forgot-form")?.addEventListener("submit", function () {
            const button = this.querySelector(".forgot-submit");

            if (!button) {
                return;
            }

            button.disabled = true;
            button.textContent = button.dataset.loadingText || "Gönderiliyor...";
        });
    </script>
</body>
</html>
