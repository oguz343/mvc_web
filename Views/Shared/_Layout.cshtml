@using Microsoft.AspNetCore.Http

@{
    var title = ViewData["Title"]?.ToString() ?? "Ödev Sistemi";

    var name =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Kullanıcı";

    var number =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "-";

    var role =
        Context.Session.GetString("UserRole") ??
        Context.Session.GetString("Role") ??
        "";

    string RoleLabel(string value)
    {
        value = (value ?? "").Trim().ToLowerInvariant();

        return value switch
        {
            "student" or "öğrenci" or "ogrenci" => "Öğrenci",
            "parent" or "veli" => "Veli",
            "teacher" or "öğretmen" or "ogretmen" => "Öğretmen",
            "admin" or "yönetici" or "yonetici" => "Yönetici",
            _ => "Portal"
        };
    }

    string Initials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "K";
        }

        var parts = value
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return parts[0][0].ToString().ToUpperInvariant();
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@title - Ödev Sistemi</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body class="midnight-body public-midnight-body">
    <div class="midnight-background">
        <div class="midnight-orb orb-a"></div>
        <div class="midnight-orb orb-b"></div>
        <div class="midnight-orb orb-c"></div>
    </div>

    <main class="public-main midnight-public-main">
        <header class="portal-shell-header">
            <div class="portal-brand">
                <div class="brand-icon">
                    🎓
                </div>

                <div>
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        @RoleLabel(role) Paneli
                    </div>
                </div>
            </div>

            <div class="portal-header-actions">
                <div class="system-pill">
                    <span></span>
                    Sistem Aktif
                </div>

                <div class="user-chip">
                    <div class="user-avatar">
                        @Initials(name)
                    </div>

                    <div>
                        <div class="user-name">
                            @name
                        </div>

                        <div class="user-role">
                            @RoleLabel(role) · No: @number
                        </div>
                    </div>
                </div>

                <a class="logout-link public-logout"
                   asp-controller="Auth"
                   asp-action="Logout">
                    <span>🚪</span>
                    <strong>Çıkış</strong>
                </a>
            </div>
        </header>

        <section class="public-content-area">
            @RenderBody()
        </section>
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>