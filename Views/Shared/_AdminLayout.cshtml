@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";

    var adminName =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Admin";

    var adminNumber =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "0000";

    var pageTitle = ViewData["PageTitle"]?.ToString();
    var pageSubtitle = ViewData["PageSubtitle"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = ViewData["Title"]?.ToString() ?? "Admin Paneli";
    }

    if (string.IsNullOrWhiteSpace(pageSubtitle))
    {
        pageSubtitle = "Kullanıcıları, sınıfları, ödevleri ve güvenlik taleplerini yönetin.";
    }

    string Active(string controller)
    {
        return currentController == controller ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Admin Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body class="admin-dark">
    <div class="app-shell admin-shell">
        <aside class="sidebar admin-sidebar">
            <div class="brand">
                <div class="brand-icon admin" aria-hidden="true"></div>

                <div>
                    <div class="brand-title">Ödev Sistemi</div>
                    <div class="brand-subtitle">Admin Paneli</div>
                </div>
            </div>

            <nav class="nav-menu" aria-label="Admin menüsü">
                <a class="nav-link @Active("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Kontrol Paneli</strong>
                </a>

                <a class="nav-link @Active("Users")" asp-controller="Users" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Kullanıcılar</strong>
                </a>

                <a class="nav-link @Active("Classes")" asp-controller="Classes" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Sınıflar</strong>
                </a>

                <a class="nav-link @Active("Lessons")" asp-controller="Lessons" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Ders Atamaları</strong>
                </a>

                <a class="nav-link @Active("Submissions")" asp-controller="Submissions" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @Active("Announcements")" asp-controller="Announcements" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Duyurular</strong>
                </a>

                <a class="nav-link @Active("PasswordRequests")" asp-controller="PasswordRequests" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Şifre Talepleri</strong>
                </a>

                <a class="nav-link @Active("Reports")" asp-controller="Reports" asp-action="Index">
                    <span aria-hidden="true"></span>
                    <strong>Raporlar</strong>
                </a>

                <a class="nav-link @Active("AdminAccount")" asp-controller="AdminAccount" asp-action="ChangePassword">
                    <span aria-hidden="true"></span>
                    <strong>Ayarlar</strong>
                </a>
            </nav>

            <a class="logout-link" asp-controller="Auth" asp-action="Logout">
                <span aria-hidden="true"></span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content">
            <header class="topbar admin-topbar">
                <div class="topbar-copy">
                    <div class="topbar-subtitle">Hoş geldin, @adminName</div>
                    <div class="topbar-title">@pageTitle</div>
                    @if (!string.IsNullOrWhiteSpace(pageSubtitle))
                    {
                        <div class="topbar-description">@pageSubtitle</div>
                    }
                </div>

                <form class="admin-search" role="search" data-admin-search>
                    <span aria-hidden="true"></span>
                    <input type="search" name="q" placeholder="Aramak için yazın..." autocomplete="off" />
                    <kbd>↵</kbd>
                </form>

                <div class="topbar-actions">
                    <a class="notification-button" asp-controller="PasswordRequests" asp-action="Index" title="Şifre talepleri">
                        <span aria-hidden="true"></span>
                    </a>

                    <details class="user-menu">
                        <summary class="user-chip">
                            <div class="user-avatar admin">@adminName.Substring(0, 1).ToUpperInvariant()</div>
                            <div>
                                <div class="user-name">@adminName</div>
                                <div class="user-role">Yönetici</div>
                            </div>
                        </summary>

                        <div class="user-menu-panel">
                            <a asp-controller="AdminAccount" asp-action="ChangePassword">Admin şifresi</a>
                            <a asp-controller="Dashboard" asp-action="Index">Kontrol paneli</a>
                            <a asp-controller="Auth" asp-action="Logout">Çıkış yap</a>
                        </div>
                    </details>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (() => {
            const form = document.querySelector("[data-admin-search]");
            if (!form) return;

            const routes = [
                { keys: ["kontrol", "panel", "dashboard"], url: "@Url.Action("Index", "Dashboard")" },
                { keys: ["kullanici", "kullanıcı", "ogrenci", "öğrenci", "ogretmen", "öğretmen", "veli", "admin"], url: "@Url.Action("Index", "Users")" },
                { keys: ["sinif", "sınıf", "class"], url: "@Url.Action("Index", "Classes")" },
                { keys: ["ders", "atama", "ödev", "odev"], url: "@Url.Action("Index", "Lessons")" },
                { keys: ["teslim", "submission"], url: "@Url.Action("Index", "Submissions")" },
                { keys: ["duyuru", "announcement"], url: "@Url.Action("Index", "Announcements")" },
                { keys: ["sifre", "şifre", "talep", "password"], url: "@Url.Action("Index", "PasswordRequests")" },
                { keys: ["rapor", "report"], url: "@Url.Action("Index", "Reports")" },
                { keys: ["ayar", "şifrem", "sifrem"], url: "@Url.Action("ChangePassword", "AdminAccount")" }
            ];

            const normalize = value => value
                .toLocaleLowerCase("tr-TR")
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "");

            form.addEventListener("submit", event => {
                event.preventDefault();
                const query = normalize(new FormData(form).get("q")?.toString() || "");
                if (!query.trim()) return;

                const match = routes.find(route => route.keys.some(key => query.includes(normalize(key))));
                window.location.href = match ? match.url : "@Url.Action("Index", "Users")";
            });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>
