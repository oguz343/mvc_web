@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var adminName =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Admin";

    var adminNumber =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "0000";

    var pageTitle = ViewData["PageTitle"]?.ToString();
    var pageSubtitle = ViewData["PageSubtitle"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = ViewData["Title"]?.ToString() ?? "Admin Paneli";
    }

    if (string.IsNullOrWhiteSpace(pageSubtitle))
    {
        pageSubtitle = "Yönetim işlemlerinizi buradan kontrol edin.";
    }

    string Active(string controller)
    {
        return currentController == controller ? "active" : "";
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Admin Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body>
    <div class="app-shell">
        <aside class="sidebar admin-sidebar">
            <div class="brand">
                <div class="brand-icon admin">
                    🎓
                </div>

                <div>
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        Admin Paneli
                    </div>
                </div>
            </div>

            <nav class="nav-menu">
                <a class="nav-link @Active("Dashboard")"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <span>📊</span>
                    <strong>Kontrol Paneli</strong>
                </a>

                <a class="nav-link @Active("Users")"
                   asp-controller="Users"
                   asp-action="Index">
                    <span>👥</span>
                    <strong>Kullanıcılar</strong>
                </a>

                <a class="nav-link @Active("Classes")"
                   asp-controller="Classes"
                   asp-action="Index">
                    <span>🏫</span>
                    <strong>Sınıflar</strong>
                </a>

                <a class="nav-link @Active("Lessons")"
                   asp-controller="Lessons"
                   asp-action="Index">
                    <span>📚</span>
                    <strong>Ders Atamaları</strong>
                </a>

                <a class="nav-link @Active("Submissions")"
                   asp-controller="Submissions"
                   asp-action="Index">
                    <span>📥</span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @Active("Reports")"
                   asp-controller="Reports"
                   asp-action="Index">
                    <span>R</span>
                    <strong>Raporlama</strong>
                </a>

                <a class="nav-link @Active("Announcements")"
                   asp-controller="Announcements"
                   asp-action="Index">
                    <span>📣</span>
                    <strong>Duyurular</strong>
                </a>

                <a class="nav-link @Active("PasswordRequests")"
                   asp-controller="PasswordRequests"
                   asp-action="Index">
                    <span>🔑</span>
                    <strong>Şifre Talepleri</strong>
                </a>

                <a class="nav-link @Active("AdminAccount")"
                   asp-controller="AdminAccount"
                   asp-action="ChangePassword">
                    <span>🛡️</span>
                    <strong>Admin Şifresi</strong>
                </a>
            </nav>

            <a class="logout-link"
               asp-controller="Auth"
               asp-action="Logout">
                <span>🚪</span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div>
                    <div class="topbar-subtitle">
                        Yönetim Paneli
                    </div>

                    <div class="topbar-title">
                        @pageTitle
                    </div>

                    @if (!string.IsNullOrWhiteSpace(pageSubtitle))
                    {
                        <div class="topbar-description">
                            @pageSubtitle
                        </div>
                    }
                </div>

                <div class="topbar-tools" aria-label="Hızlı panel bağlantıları">
                    <a class="topbar-tool" asp-controller="Users" asp-action="Index" title="Kullanıcılar">
                        <span class="tool-mark users">KU</span>
                        <strong>Kullanıcılar</strong>
                    </a>

                    <a class="topbar-tool" asp-controller="Announcements" asp-action="Index" title="Duyurular">
                        <span class="tool-mark announcements">DY</span>
                        <strong>Duyurular</strong>
                    </a>

                    <a class="topbar-tool" asp-controller="PasswordRequests" asp-action="Index" title="Şifre talepleri">
                        <span class="tool-mark security">SF</span>
                        <strong>Şifre</strong>
                    </a>
                </div>

                <div class="user-chip">
                    <div class="user-avatar admin">
                        A
                    </div>

                    <div>
                        <div class="user-name">
                            @adminName
                        </div>

                        <div class="user-role">
                            No: @adminNumber
                        </div>
                    </div>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <style>
        :where(.page-header-card, .form-card, .table-card, .entity-card, .stat-card, .portal-card, .create-card, .side-card, .dash-panel, .dash-stat-card, .lesson-info-card, .empty-state) {
            background:
                radial-gradient(circle at 10% 0%, rgba(79, 70, 229, .13), transparent 34%),
                radial-gradient(circle at 96% 10%, rgba(6, 182, 212, .11), transparent 30%),
                linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.92)) !important;
            border-color: rgba(148, 163, 184, .44) !important;
            box-shadow:
                0 22px 58px rgba(15, 23, 42, .12),
                inset 0 1px 0 rgba(255,255,255,.88) !important;
        }

        :where(.topbar) {
            background:
                radial-gradient(circle at 12% 0%, rgba(79, 70, 229, .12), transparent 34%),
                linear-gradient(135deg, rgba(255,255,255,.98), rgba(241,245,249,.94)) !important;
            border-color: rgba(148, 163, 184, .46) !important;
            box-shadow: 0 24px 64px rgba(15, 23, 42, .13) !important;
        }

        :where(.entity-card, .dash-stat-card, .stat-card, .table-card, .form-card) {
            transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        }

        :where(.entity-card, .dash-stat-card, .stat-card):hover {
            border-color: rgba(99, 102, 241, .42) !important;
            box-shadow:
                0 28px 70px rgba(15, 23, 42, .15),
                0 0 0 1px rgba(99, 102, 241, .08) !important;
        }

        :where(.premium-table th, .dash-table th) {
            background: #eef2f7 !important;
            border-bottom-color: rgba(148, 163, 184, .38) !important;
        }

        :where(.premium-table td, .dash-table td) {
            border-bottom-color: rgba(203, 213, 225, .7) !important;
        }
    </style>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>
