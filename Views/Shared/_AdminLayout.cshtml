@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var adminName =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Admin";

    var adminNumber =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "0000";

    var pageTitle = ViewData["PageTitle"]?.ToString();
    var pageSubtitle = ViewData["PageSubtitle"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = ViewData["Title"]?.ToString() ?? "Admin Paneli";
    }

    if (string.IsNullOrWhiteSpace(pageSubtitle))
    {
        pageSubtitle = currentController switch
        {
            "Dashboard" => "Okul yönetimini tek ekrandan takip edin.",
            "Users" => "Öğrenci, öğretmen, veli ve yönetici hesaplarını düzenleyin.",
            "Classes" => "Sınıfları, kontenjanları ve sınıf öğretmenlerini yönetin.",
            "Lessons" => "Dersleri öğretmenler ve sınıflarla eşleştirin.",
            "Submissions" => "Ödev teslimlerini ve değerlendirme durumlarını inceleyin.",
            "Reports" => "Teslim, sınıf ve ödev raporlarını kontrol edin.",
            "Announcements" => "Duyuruları oluşturun, düzenleyin ve yayınlayın.",
            "PasswordRequests" => "Şifre taleplerini onaylayın veya reddedin.",
            "AdminAccount" => "Admin hesabınızın güvenlik ayarlarını yönetin.",
            _ => "Yönetim işlemlerinizi buradan kontrol edin."
        };
    }

    string Active(string controller)
    {
        return string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    }

    string Initials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "A";
        }

        var parts = value
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return parts[0][0].ToString().ToUpperInvariant();
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Admin Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body class="midnight-body">
    <div class="midnight-background">
        <div class="midnight-orb orb-a"></div>
        <div class="midnight-orb orb-b"></div>
        <div class="midnight-orb orb-c"></div>
    </div>

    <div class="app-shell midnight-shell">
        <aside class="sidebar midnight-sidebar">
            <div class="brand">
                <div class="brand-icon admin">
                    🎓
                </div>

                <div class="brand-text">
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        Admin Paneli
                    </div>
                </div>
            </div>

            <div class="sidebar-label">
                Yönetim
            </div>

            <nav class="nav-menu">
                <a class="nav-link @Active("Dashboard")"
                   asp-controller="Dashboard"
                   asp-action="Index">
                    <span>📊</span>
                    <strong>Kontrol Paneli</strong>
                </a>

                <a class="nav-link @Active("Users")"
                   asp-controller="Users"
                   asp-action="Index">
                    <span>👥</span>
                    <strong>Kullanıcılar</strong>
                </a>

                <a class="nav-link @Active("Classes")"
                   asp-controller="Classes"
                   asp-action="Index">
                    <span>🏫</span>
                    <strong>Sınıflar</strong>
                </a>

                <a class="nav-link @Active("Lessons")"
                   asp-controller="Lessons"
                   asp-action="Index">
                    <span>📚</span>
                    <strong>Ders Atamaları</strong>
                </a>

                <a class="nav-link @Active("Submissions")"
                   asp-controller="Submissions"
                   asp-action="Index">
                    <span>📥</span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @Active("Reports")"
                   asp-controller="Reports"
                   asp-action="Index">
                    <span>📈</span>
                    <strong>Raporlama</strong>
                </a>

                <a class="nav-link @Active("Announcements")"
                   asp-controller="Announcements"
                   asp-action="Index">
                    <span>📣</span>
                    <strong>Duyurular</strong>
                </a>

                <a class="nav-link @Active("PasswordRequests")"
                   asp-controller="PasswordRequests"
                   asp-action="Index">
                    <span>🔑</span>
                    <strong>Şifre Talepleri</strong>
                </a>

                <a class="nav-link @Active("AdminAccount")"
                   asp-controller="AdminAccount"
                   asp-action="ChangePassword">
                    <span>🛡️</span>
                    <strong>Admin Şifresi</strong>
                </a>
            </nav>

            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    @Initials(adminName)
                </div>

                <div class="sidebar-user-info">
                    <strong>@adminName</strong>
                    <span>No: @adminNumber</span>
                </div>
            </div>

            <a class="logout-link"
               asp-controller="Auth"
               asp-action="Logout">
                <span>🚪</span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content midnight-main">
            <header class="topbar midnight-topbar">
                <div class="topbar-left">
                    <div class="topbar-subtitle">
                        Yönetim Paneli
                    </div>

                    <div class="topbar-title">
                        @pageTitle
                    </div>

                    @if (!string.IsNullOrWhiteSpace(pageSubtitle))
                    {
                        <div class="topbar-description">
                            @pageSubtitle
                        </div>
                    }
                </div>

                <div class="topbar-right">
                    <div class="system-pill">
                        <span></span>
                        Sistem Aktif
                    </div>

                    <div class="user-chip">
                        <div class="user-avatar admin">
                            @Initials(adminName)
                        </div>

                        <div>
                            <div class="user-name">
                                @adminName
                            </div>

                            <div class="user-role">
                                Admin · No: @adminNumber
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>