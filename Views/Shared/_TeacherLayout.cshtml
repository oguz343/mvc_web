@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var name =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Öğretmen";

    var number =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "-";

    string ActiveTeacher(string action)
    {
        return currentController == "Teacher" && currentAction == action ? "active teacher-active" : "";
    }

    string ActiveController(string controller)
    {
        return currentController == controller ? "active teacher-active" : "";
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Öğretmen Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body>
    <div class="app-shell">
        <aside class="sidebar teacher-sidebar">
            <div class="brand">
                <div class="brand-icon teacher">
                    👨‍🏫
                </div>

                <div>
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        Öğretmen Paneli
                    </div>
                </div>
            </div>

            <nav class="nav-menu">
                <a class="nav-link @ActiveTeacher("Index")"
                   asp-controller="Teacher"
                   asp-action="Index">
                    <span>📊</span>
                    <strong>Kontrol Paneli</strong>
                </a>

                <a class="nav-link @(currentController == "Teacher" && (currentAction == "Assignments" || currentAction == "CreateAssignment" || currentAction == "EditAssignment") ? "active teacher-active" : "")"
                   asp-controller="Teacher"
                   asp-action="Assignments">
                    <span>📝</span>
                    <strong>Verdiğim Ödevler</strong>
                </a>

                <a class="nav-link @ActiveTeacher("Submissions")"
                   asp-controller="Teacher"
                   asp-action="Submissions">
                    <span>📥</span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @ActiveController("TeacherAnnouncements")"
                   asp-controller="TeacherAnnouncements"
                   asp-action="Index">
                    <span>📣</span>
                    <strong>Duyurular</strong>
                </a>
            </nav>

            <a class="logout-link teacher-logout"
               asp-controller="Auth"
               asp-action="Logout">
                <span>🚪</span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div>
                    <div class="topbar-title">
                        @ViewData["PageTitle"]
                    </div>

                    <div class="topbar-subtitle">
                        @ViewData["PageSubtitle"]
                    </div>
                </div>

                <div class="topbar-tools" aria-label="Hızlı panel bağlantıları">
                    <a class="topbar-tool" asp-controller="Teacher" asp-action="Assignments" title="Ödevler">
                        <span class="tool-mark assignments">OD</span>
                        <strong>Ödevler</strong>
                    </a>

                    <a class="topbar-tool" asp-controller="Teacher" asp-action="Submissions" title="Teslimler">
                        <span class="tool-mark submissions">TS</span>
                        <strong>Teslimler</strong>
                    </a>

                    <a class="topbar-tool" asp-controller="TeacherAnnouncements" asp-action="Index" title="Duyurular">
                        <span class="tool-mark announcements">DY</span>
                        <strong>Duyurular</strong>
                    </a>
                </div>

                <div class="user-chip">
                    <div class="user-avatar teacher">
                        Ö
                    </div>

                    <div>
                        <div class="user-name">
                            @name
                        </div>

                        <div class="user-role">
                            No: @number
                        </div>
                    </div>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <style>
        :where(.page-header-card, .form-card, .table-card, .entity-card, .stat-card, .teacher-panel, .teacher-stat-card, .lesson-row, .submission-row, .announcement-card-premium, .portal-card, .empty-state-mini) {
            background:
                radial-gradient(circle at 10% 0%, rgba(6, 182, 212, .14), transparent 34%),
                radial-gradient(circle at 96% 10%, rgba(79, 70, 229, .11), transparent 30%),
                linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.92)) !important;
            border-color: rgba(148, 163, 184, .44) !important;
            box-shadow:
                0 22px 58px rgba(15, 23, 42, .12),
                inset 0 1px 0 rgba(255,255,255,.88) !important;
        }

        :where(.topbar) {
            background:
                radial-gradient(circle at 12% 0%, rgba(6, 182, 212, .13), transparent 34%),
                linear-gradient(135deg, rgba(255,255,255,.98), rgba(241,245,249,.94)) !important;
            border-color: rgba(148, 163, 184, .46) !important;
            box-shadow: 0 24px 64px rgba(15, 23, 42, .13) !important;
        }

        :where(.teacher-hero, .teacher-panel, .teacher-stat-card, .lesson-row, .submission-row, .table-card, .form-card) {
            transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
        }

        :where(.teacher-stat-card, .lesson-row, .submission-row):hover {
            border-color: rgba(6, 182, 212, .45) !important;
            box-shadow:
                0 28px 70px rgba(15, 23, 42, .15),
                0 0 0 1px rgba(6, 182, 212, .08) !important;
        }

        :where(.premium-table th) {
            background: #eef2f7 !important;
            border-bottom-color: rgba(148, 163, 184, .38) !important;
        }

        :where(.premium-table td) {
            border-bottom-color: rgba(203, 213, 225, .7) !important;
        }
    </style>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>
