@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var name =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Öğretmen";

    var number =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "-";

    var pageTitle = ViewData["PageTitle"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageTitle))
    {
        pageTitle = ViewData["Title"]?.ToString() ?? "Öğretmen Paneli";
    }

    var pageSubtitle = ViewData["PageSubtitle"]?.ToString();

    if (string.IsNullOrWhiteSpace(pageSubtitle))
    {
        pageSubtitle = "Derslerinizi, ödevlerinizi ve öğrenci teslimlerini buradan takip edin.";
    }

    string ActiveTeacher(string action)
    {
        return currentController == "Teacher" && currentAction == action ? "active teacher-active" : "";
    }

    string ActiveController(string controller)
    {
        return currentController == controller ? "active teacher-active" : "";
    }

    string ActiveTeacherSubmissions()
    {
        var isLegacyTeacherAction = currentController == "Teacher" && currentAction == "Submissions";
        var isDedicatedController = currentController == "TeacherSubmissions";

        return isLegacyTeacherAction || isDedicatedController ? "active teacher-active" : "";
    }

    string Initials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Ö";
        }

        var parts = value
            .Trim()
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length >= 2)
        {
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();
        }

        return parts[0][0].ToString().ToUpperInvariant();
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Öğretmen Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body class="midnight-body">
    <div class="midnight-background">
        <div class="midnight-orb orb-a"></div>
        <div class="midnight-orb orb-b"></div>
        <div class="midnight-orb orb-c"></div>
    </div>

    <div class="app-shell midnight-shell">
        <aside class="sidebar midnight-sidebar teacher-sidebar">
            <div class="brand">
                <div class="brand-icon teacher">
                    👨‍🏫
                </div>

                <div class="brand-text">
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        Öğretmen Paneli
                    </div>
                </div>
            </div>

            <div class="sidebar-label">
                Öğretmen
            </div>

            <nav class="nav-menu">
                <a class="nav-link @ActiveTeacher("Index")"
                   asp-controller="Teacher"
                   asp-action="Index">
                    <span>📊</span>
                    <strong>Kontrol Paneli</strong>
                </a>

                <a class="nav-link @(currentController == "Teacher" && (currentAction == "Assignments" || currentAction == "CreateAssignment" || currentAction == "EditAssignment") ? "active teacher-active" : "")"
                   asp-controller="Teacher"
                   asp-action="Assignments">
                    <span>📝</span>
                    <strong>Verdiğim Ödevler</strong>
                </a>

                <a class="nav-link @ActiveTeacherSubmissions()"
                   asp-controller="TeacherSubmissions"
                   asp-action="Index">
                    <span>📥</span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @ActiveController("TeacherAnnouncements")"
                   asp-controller="TeacherAnnouncements"
                   asp-action="Index">
                    <span>📣</span>
                    <strong>Duyurular</strong>
                </a>
            </nav>

            <div class="sidebar-user">
                <div class="sidebar-user-avatar">
                    @Initials(name)
                </div>

                <div class="sidebar-user-info">
                    <strong>@name</strong>
                    <span>No: @number</span>
                </div>
            </div>

            <a class="logout-link teacher-logout"
               asp-controller="Auth"
               asp-action="Logout">
                <span>🚪</span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content midnight-main">
            <header class="topbar midnight-topbar">
                <div class="topbar-left">
                    <div class="topbar-subtitle">
                        Öğretmen Paneli
                    </div>

                    <div class="topbar-title">
                        @pageTitle
                    </div>

                    @if (!string.IsNullOrWhiteSpace(pageSubtitle))
                    {
                        <div class="topbar-description">
                            @pageSubtitle
                        </div>
                    }
                </div>

                <div class="topbar-right">
                    <div class="system-pill">
                        <span></span>
                        Çevrimiçi
                    </div>

                    <div class="user-chip">
                        <div class="user-avatar teacher">
                            @Initials(name)
                        </div>

                        <div>
                            <div class="user-name">
                                @name
                            </div>

                            <div class="user-role">
                                Öğretmen · No: @number
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>
