@using Microsoft.AspNetCore.Http

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";

    var name =
        Context.Session.GetString("UserName") ??
        Context.Session.GetString("Name") ??
        "Öğretmen";

    var number =
        Context.Session.GetString("UserNumber") ??
        Context.Session.GetString("Number") ??
        "-";

    string ActiveTeacher(string action)
    {
        return currentController == "Teacher" && currentAction == action ? "active teacher-active" : "";
    }

    string ActiveController(string controller)
    {
        return currentController == controller ? "active teacher-active" : "";
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Öğretmen Paneli</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>

<body>
    <div class="app-shell">
        <aside class="sidebar teacher-sidebar">
            <div class="brand">
                <div class="brand-icon teacher">
                    👨‍🏫
                </div>

                <div>
                    <div class="brand-title">
                        Ödev Sistemi
                    </div>

                    <div class="brand-subtitle">
                        Öğretmen Panel
                    </div>
                </div>
            </div>

            <nav class="nav-menu">
                <a class="nav-link @ActiveTeacher("Index")"
                   asp-controller="Teacher"
                   asp-action="Index">
                    <span>📊</span>
                    <strong>Dashboard</strong>
                </a>

                <a class="nav-link @(currentController == "Teacher" && (currentAction == "Assignments" || currentAction == "CreateAssignment" || currentAction == "EditAssignment") ? "active teacher-active" : "")"
                   asp-controller="Teacher"
                   asp-action="Assignments">
                    <span>📝</span>
                    <strong>Ödevlerim</strong>
                </a>

                <a class="nav-link @ActiveTeacher("Submissions")"
                   asp-controller="Teacher"
                   asp-action="Submissions">
                    <span>📥</span>
                    <strong>Teslimler</strong>
                </a>

                <a class="nav-link @ActiveController("TeacherAnnouncements")"
                   asp-controller="TeacherAnnouncements"
                   asp-action="Index">
                    <span>📣</span>
                    <strong>Duyurular</strong>
                </a>
            </nav>

            <a class="logout-link teacher-logout"
               asp-controller="Auth"
               asp-action="Logout">
                <span>🚪</span>
                <strong>Çıkış Yap</strong>
            </a>
        </aside>

        <main class="main-content">
            <header class="topbar">
                <div>
                    <div class="topbar-title">
                        @ViewData["PageTitle"]
                    </div>

                    <div class="topbar-subtitle">
                        @ViewData["PageSubtitle"]
                    </div>
                </div>

                <div class="user-chip">
                    <div class="user-avatar teacher">
                        Ö
                    </div>

                    <div>
                        <div class="user-name">
                            @name
                        </div>

                        <div class="user-role">
                            No: @number
                        </div>
                    </div>
                </div>
            </header>

            <section class="content-area">
                @RenderBody()
            </section>
        </main>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_DeleteConfirmModal")
</body>
</html>