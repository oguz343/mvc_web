@model List<UserViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanıcılar";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="page-actions">
    <a class="btn btn-primary" asp-controller="Users" asp-action="Create">
        👤 Yeni Kullanıcı
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">👥</div>
        <div class="empty-title">Henüz kullanıcı yok</div>
        <div class="empty-text">Yeni kullanıcı ekleyerek başlayabilirsiniz.</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var user in Model)
        {
            var roleBadge = user.Role == "Öğretmen"
                ? "badge-cyan"
                : user.Role == "Veli"
                    ? "badge-orange"
                    : "badge-purple";

            <div class="data-card">
                <div class="data-card-header">
                    <div class="data-card-icon">
                        @(user.Role == "Öğretmen" ? "👨‍🏫" : user.Role == "Veli" ? "👪" : "🎒")
                    </div>
                    <div>
                        <div class="data-card-title">@user.Name</div>
                        <div class="data-card-subtitle">@user.SchoolNo</div>
                    </div>
                </div>

                <div class="badge-row">
                    <span class="badge @roleBadge">@user.Role</span>

                    @if (user.MustChangePassword)
                    {
                        <span class="badge badge-orange">Aktivasyon Bekliyor</span>
                    }
                    else
                    {
                        <span class="badge badge-green">Aktif</span>
                    }
                </div>

                <div class="info-line">
                    <span>ℹ️</span>
                    <span>@user.Detail</span>
                </div>

                <div class="info-line">
                    <span>📞</span>
                    <span>@(string.IsNullOrWhiteSpace(user.Phone) ? "-" : user.Phone)</span>
                </div>

                <div class="info-line">
                    <span>🔑</span>
                    <span>
                        Aktivasyon:
                        <strong>@(string.IsNullOrWhiteSpace(user.ActivationCode) ? "Yok" : user.ActivationCode)</strong>
                    </span>
                </div>

                <div class="card-actions">
                    <a class="btn btn-light" asp-controller="Users" asp-action="Edit" asp-route-id="@user.Id">
                        ✏️ Düzenle
                    </a>

                    <form asp-controller="Users" asp-action="RenewCode" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@user.Id" />
                        <button class="btn btn-success" type="submit">
                            🔁 Kod Yenile
                        </button>
                    </form>

                    <form asp-controller="Users" asp-action="Delete" method="post" onsubmit="return confirmDelete('Kullanıcı silinsin mi?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@user.Id" />
                        <button class="btn btn-danger" type="submit">
                            🗑️ Sil
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}