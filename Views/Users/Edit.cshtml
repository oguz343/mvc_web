@model mvc_web.Models.UserViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanıcı Düzenle";
    ViewData["PageTitle"] = "Kullanıcı Düzenle";
    ViewData["PageSubtitle"] = "Kullanıcı bilgilerini, rolünü, sınıf/branş/veli bağlantısını ve iletişim bilgisini güncelleyin.";

    var classes = ViewBag.Classes as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var students = ViewBag.Students as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    var userId = Model?.Id ?? "";
    var userName = Model?.Name ?? "";
    var selectedClassName = Model?.ClassName ?? "";
    var userRole = Model?.Role ?? "";
    var userSchoolNo = Model?.SchoolNo ?? "";
    var linkedStudentNo = Model?.LinkedStudentNo ?? "";
    var userActivationCode = Model?.ActivationCode ?? "";
    var userMustChangePassword = Model?.MustChangePassword ?? true;
}

<style>
    .user-edit-v2 {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .user-edit-hero,
    .user-edit-card,
    .user-edit-side {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .user-edit-hero {
        padding: 24px;
        border-radius: 32px;
    }

    .user-edit-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .user-edit-hero h1 {
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .user-edit-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .user-edit-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        align-items: start;
    }

    .user-edit-card,
    .user-edit-side {
        padding: 22px;
        border-radius: 30px;
    }

    .user-edit-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .user-edit-field {
        display: grid;
        gap: 8px;
    }

    .user-edit-field.full {
        grid-column: 1 / -1;
    }

    .user-edit-field label {
        color: #dbeafe;
        font-size: 13px;
        font-weight: 950;
    }

    .user-edit-field input,
    .user-edit-field select {
        width: 100%;
        min-height: 48px;
        padding: 0 13px;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .18);
        outline: none;
        color: #ffffff;
        background: rgba(7, 17, 31, .58);
        font-size: 14px;
        font-weight: 750;
    }

    .user-edit-field input:focus,
    .user-edit-field select:focus {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .user-edit-field option {
        color: #0f172a;
        background: #ffffff;
    }

    .role-fields {
        display: none;
        grid-column: 1 / -1;
        gap: 14px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .role-fields.show {
        display: grid;
    }

    .user-edit-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    .user-edit-save,
    .user-edit-back {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 950;
    }

    .user-edit-save {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-color: rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .user-edit-back {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border-color: rgba(148, 163, 184, .18);
    }

    .user-edit-side h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .user-edit-side p {
        margin: 8px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.55;
    }

    .user-edit-info-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .user-edit-info {
        padding: 12px;
        border-radius: 16px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
        overflow-wrap: anywhere;
    }

    @@media (max-width: 1100px) {
        .user-edit-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .user-edit-hero,
        .user-edit-card,
        .user-edit-side {
            border-radius: 22px;
            padding: 16px;
        }

        .user-edit-grid,
        .role-fields {
            grid-template-columns: 1fr;
        }

        .user-edit-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .user-edit-save,
        .user-edit-back {
            width: 100%;
        }
    }
</style>

<div class="user-edit-v2">
    <section class="user-edit-hero">
        <div class="user-edit-kicker">Kullanıcı Düzenle</div>

        <h1>@(string.IsNullOrWhiteSpace(userName) ? "Kullanıcı Düzenle" : userName)</h1>

        <p>
            Hesap bilgilerini güncelleyin. Rol değişirse ilgili öğrenci, öğretmen veya veli alanları otomatik gösterilir.
        </p>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <section class="user-edit-layout">
        <form asp-controller="Users"
              asp-action="Edit"
              asp-route-id="@userId"
              method="post"
              class="user-edit-card">

            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" name="Id" />

            <div class="user-edit-grid">
                <div class="user-edit-field">
                    <label>Ad Soyad</label>
                    <input asp-for="Name"
                           name="Name"
                           maxlength="80"
                           required />
                </div>

                <div class="user-edit-field">
                    <label>Rol</label>
                    <select asp-for="Role" name="Role" id="roleSelect" required>
                        <option value="Öğrenci">Öğrenci</option>
                        <option value="Öğretmen">Öğretmen</option>
                        <option value="Veli">Veli</option>
                    </select>
                </div>

                <div class="user-edit-field">
                    <label>Okul / Kullanıcı No</label>
                    <input asp-for="SchoolNo"
                           name="SchoolNo"
                           inputmode="numeric"
                           maxlength="20"
                           required />
                </div>

                <div class="user-edit-field">
                    <label>Telefon</label>
                    <input asp-for="Phone"
                           name="Phone"
                           class="phone-mask"
                           inputmode="numeric"
                           maxlength="15"
                           placeholder="Örn: (555) 123 45 67" />
                </div>

                <div id="studentFields" class="role-fields">
                    <div class="user-edit-field">
                        <label>Sınıf</label>
                        <select asp-for="ClassName" name="ClassName">
                            <option value="">Sınıf seçin</option>

                            @foreach (var item in classes)
                            {
                                <option value="@item.Name" selected="@(selectedClassName == item.Name ? "selected" : null)">
                                    @item.Name
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div id="teacherFields" class="role-fields">
                    <div class="user-edit-field">
                        <label>Branş</label>
                        <input asp-for="Branch"
                               name="Branch"
                               maxlength="60"
                               placeholder="Örn: Matematik" />
                    </div>
                </div>

                <div id="parentFields" class="role-fields">
                    <div class="user-edit-field">
                        <label>Bağlı Öğrenci No</label>
                        <select asp-for="LinkedStudentNo" name="LinkedStudentNo">
                            <option value="">Öğrenci seçin</option>

                            @foreach (var student in students)
                            {
                                <option value="@student.Number" selected="@(linkedStudentNo == student.Number ? "selected" : null)">
                                    @student.DisplayName
                                </option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <div class="user-edit-actions">
                <a asp-controller="Users"
                   asp-action="Index"
                   class="user-edit-back">
                    Vazgeç
                </a>

                <button type="submit" class="user-edit-save">
                    💾 Değişiklikleri Kaydet
                </button>
            </div>
        </form>

        <aside class="user-edit-side">
            <h3>Hesap Özeti</h3>

            <p>
                Bu alan kullanıcının mevcut kayıt durumunu hızlıca görmeniz için hazırlanmıştır.
            </p>

            <div class="user-edit-info-list">
                <div class="user-edit-info">👤 Rol: @(string.IsNullOrWhiteSpace(userRole) ? "-" : userRole)</div>
                <div class="user-edit-info">🔢 No: @(string.IsNullOrWhiteSpace(userSchoolNo) ? "-" : userSchoolNo)</div>
                @if (userMustChangePassword && !string.IsNullOrWhiteSpace(userActivationCode))
                {
                    <div class="user-edit-info">🔑 Aktivasyon: @userActivationCode</div>
                }
                <div class="user-edit-info">🛡️ Durum: @(userMustChangePassword ? "Aktivasyon Bekliyor" : "Aktif")</div>
            </div>
        </aside>
    </section>
</div>

@section Scripts {
    <script>
        const roleSelect = document.getElementById("roleSelect");
        const studentFields = document.getElementById("studentFields");
        const teacherFields = document.getElementById("teacherFields");
        const parentFields = document.getElementById("parentFields");
        const phoneInputs = Array.from(document.querySelectorAll(".phone-mask"));

        function syncRoleFields() {
            const role = roleSelect?.value || "";

            studentFields?.classList.toggle("show", role === "Öğrenci");
            teacherFields?.classList.toggle("show", role === "Öğretmen");
            parentFields?.classList.toggle("show", role === "Veli");
        }

        if (roleSelect) {
            roleSelect.addEventListener("change", syncRoleFields);
            syncRoleFields();
        }

        function clearHiddenRoleFields() {
            document.querySelectorAll(".role-fields:not(.show) input, .role-fields:not(.show) select, .role-fields:not(.show) textarea")
                .forEach(input => {
                    input.value = "";
                });
        }

        if (roleSelect) {
            roleSelect.addEventListener("change", clearHiddenRoleFields);
        }

        function formatPhone(value) {
            let digits = (value || "").replace(/\D/g, "");

            if (digits.startsWith("90")) {
                digits = digits.slice(2);
            }

            if (digits.startsWith("0")) {
                digits = digits.slice(1);
            }

            digits = digits.slice(0, 10);

            const p1 = digits.slice(0, 3);
            const p2 = digits.slice(3, 6);
            const p3 = digits.slice(6, 8);
            const p4 = digits.slice(8, 10);
            let text = "";

            if (p1) {
                text = "(" + p1 + (p1.length === 3 ? ")" : "");
            }

            if (p2) {
                text += " " + p2;
            }

            if (p3) {
                text += " " + p3;
            }

            if (p4) {
                text += " " + p4;
            }

            return text.trim();
        }

        phoneInputs.forEach(input => {
            input.value = formatPhone(input.value);
            input.addEventListener("input", () => {
                input.value = formatPhone(input.value);
            });
        });
    </script>
}
