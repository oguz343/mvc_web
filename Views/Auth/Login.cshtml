@{
    Layout = null;
    ViewData["Title"] = "Giriş Yap";

    var selectedRole = Context.Request.HasFormContentType
        ? Context.Request.Form["Role"].ToString()
        : "";

    if (string.IsNullOrWhiteSpace(selectedRole))
    {
        selectedRole = "Öğrenci";
    }

    var postedNumber = Context.Request.HasFormContentType
        ? Context.Request.Form["Number"].ToString()
        : "";

    var activeUsersText = ViewBag.ActiveUsersText != null
        ? ViewBag.ActiveUsersText.ToString()
        : (ViewBag.ActiveUserCount != null ? ViewBag.ActiveUserCount.ToString() : "0");

    var activeLessonsText = ViewBag.ActiveLessonsText != null
        ? ViewBag.ActiveLessonsText.ToString()
        : (ViewBag.ActiveLessonCount != null ? ViewBag.ActiveLessonCount.ToString() : "0");

    var completedHomeworksText = ViewBag.CompletedHomeworksText != null
        ? ViewBag.CompletedHomeworksText.ToString()
        : (ViewBag.CompletedHomeworkCount != null ? ViewBag.CompletedHomeworkCount.ToString() : "0");

    var systemSuccessRateText = ViewBag.SystemSuccessRateText != null
        ? ViewBag.SystemSuccessRateText.ToString()
        : "%0";

    var systemStatusTitle = ViewBag.SystemStatusTitle != null
        ? ViewBag.SystemStatusTitle.ToString()
        : "Sistem Aktif";

    var systemStatusSubTitle = ViewBag.SystemStatusSubTitle != null
        ? ViewBag.SystemStatusSubTitle.ToString()
        : "Tüm Sistemler Çevrimiçi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş Yap - Ödev Sistemi</title>

    <style>
        :root {
            --white: #ffffff;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-300: #cbd5e1;
            --slate-400: #94a3b8;
            --cyan: #22d3ee;
            --blue: #38bdf8;
            --blue-2: #2563eb;
            --purple: #8b5cf6;
            --violet: #a855f7;
            --pink: #d946ef;
            --green: #22c55e;
            --emerald: #34d399;
            --orange: #fb923c;
            --amber: #fbbf24;
            --ease: cubic-bezier(.2, .8, .2, 1);
            --shadow-deep: 0 42px 130px rgba(0, 0, 0, .66);
        }

        * {
            box-sizing: border-box;
        }

        *::before,
        *::after {
            box-sizing: border-box;
        }

        html {
            min-height: 100%;
            scroll-behavior: smooth;
        }

        body {
            margin: 0;
            min-height: 100vh;
            color: var(--white);
            font-family:
                Inter,
                ui-sans-serif,
                system-ui,
                -apple-system,
                BlinkMacSystemFont,
                "Segoe UI",
                Arial,
                sans-serif;
            background:
                radial-gradient(circle at 13% 18%, rgba(37, 99, 235, .34), transparent 30%),
                radial-gradient(circle at 80% 8%, rgba(147, 51, 234, .30), transparent 27%),
                radial-gradient(circle at 90% 90%, rgba(34, 211, 238, .20), transparent 31%),
                linear-gradient(135deg, #020617 0%, #07142b 48%, #020617 100%);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            text-rendering: geometricPrecision;
        }

        button,
        input {
            font: inherit;
        }

        button {
            -webkit-tap-highlight-color: transparent;
        }

        a {
            color: inherit;
        }

        .page {
            position: relative;
            min-height: 100vh;
            padding: 18px;
            display: grid;
            place-items: center;
            overflow: hidden;
            isolation: isolate;
        }

        .page::before {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background:
                linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
            background-size: 72px 72px;
            mask-image: radial-gradient(circle at 50% 50%, black 0%, transparent 76%);
            opacity: .75;
        }

        .page::after {
            content: "";
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            background-image: radial-gradient(rgba(255,255,255,.26) 1px, transparent 1px);
            background-size: 27px 27px;
            mask-image: radial-gradient(circle at 50% 46%, black 0%, transparent 66%);
            opacity: .075;
        }

        .aurora {
            position: fixed;
            inset: -180px;
            z-index: 0;
            pointer-events: none;
            filter: blur(8px);
            opacity: .95;
        }

        .aurora span {
            position: absolute;
            width: 640px;
            height: 640px;
            border-radius: 999px;
            mix-blend-mode: screen;
            animation: auroraFloat 17s var(--ease) infinite;
        }

        .aurora span:nth-child(1) {
            left: -100px;
            top: -40px;
            background: radial-gradient(circle, rgba(37,99,235,.44), transparent 70%);
        }

        .aurora span:nth-child(2) {
            right: -120px;
            top: -10px;
            background: radial-gradient(circle, rgba(139,92,246,.36), transparent 72%);
            animation-delay: -5s;
        }

        .aurora span:nth-child(3) {
            right: 14%;
            bottom: -170px;
            background: radial-gradient(circle, rgba(34,211,238,.30), transparent 72%);
            animation-delay: -9s;
        }

        .aurora span:nth-child(4) {
            left: 32%;
            bottom: -190px;
            background: radial-gradient(circle, rgba(16,185,129,.14), transparent 72%);
            animation-delay: -13s;
        }

        @@keyframes auroraFloat {
            0%, 100% {
                transform: translate3d(0, 0, 0) scale(1);
            }

            38% {
                transform: translate3d(48px, -34px, 0) scale(1.08);
            }

            72% {
                transform: translate3d(-34px, 26px, 0) scale(.98);
            }
        }

        .beam {
            position: fixed;
            z-index: 0;
            pointer-events: none;
            width: 560px;
            height: 2px;
            opacity: 0;
            background: linear-gradient(90deg, transparent, rgba(103,232,249,.82), rgba(167,139,250,.65), transparent);
            filter: blur(.35px);
            transform: rotate(-24deg);
            animation: beamMove 10s ease-in-out infinite;
        }

        .beam.one {
            left: 1%;
            top: 8%;
        }

        .beam.two {
            right: -3%;
            bottom: 11%;
            animation-delay: -3.4s;
        }

        .beam.three {
            left: 42%;
            top: 4%;
            animation-delay: -6.2s;
        }

        @@keyframes beamMove {
            0%, 70%, 100% {
                opacity: 0;
                transform: translate3d(-150px, 0, 0) rotate(-24deg);
            }

            78% {
                opacity: .85;
            }

            90% {
                opacity: 0;
                transform: translate3d(300px, 0, 0) rotate(-24deg);
            }
        }

        .shell {
            position: relative;
            z-index: 2;
            width: min(1640px, 100%);
            min-height: 900px;
            display: grid;
            grid-template-columns: minmax(0, 1.18fr) minmax(470px, .82fr);
            gap: 32px;
            padding: 30px;
            border-radius: 38px;
            background:
                radial-gradient(circle at 47% 14%, rgba(124, 58, 237, .12), transparent 33%),
                linear-gradient(135deg, rgba(255,255,255,.060), rgba(255,255,255,.025)),
                rgba(2, 6, 23, .42);
            border: 1px solid rgba(148, 163, 184, .20);
            box-shadow:
                var(--shadow-deep),
                inset 0 1px 0 rgba(255,255,255,.10);
            backdrop-filter: blur(22px);
            overflow: hidden;
            isolation: isolate;
        }

        .shell::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: -1;
            border-radius: inherit;
            background:
                radial-gradient(circle at 7% 8%, rgba(34,211,238,.12), transparent 26%),
                radial-gradient(circle at 92% 92%, rgba(124,58,237,.14), transparent 28%);
            pointer-events: none;
        }

        .left {
            min-width: 0;
            display: flex;
            flex-direction: column;
            padding: 14px 12px 10px;
        }

        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 15px;
            min-width: 0;
        }

        .brand-logo {
            position: relative;
            flex: 0 0 auto;
            width: 78px;
            height: 78px;
            border-radius: 26px;
            display: grid;
            place-items: center;
            background:
                radial-gradient(circle at 28% 16%, rgba(255,255,255,.46), transparent 24%),
                linear-gradient(135deg, #1d4ed8 0%, #4f46e5 45%, #06b6d4 100%);
            border: 1px solid rgba(255,255,255,.24);
            box-shadow:
                0 0 30px rgba(34,211,238,.26),
                0 24px 56px rgba(79,70,229,.32),
                inset 0 1px 0 rgba(255,255,255,.38);
            overflow: hidden;
        }

        .brand-logo::before {
            content: "";
            position: absolute;
            inset: -45%;
            background: conic-gradient(from 180deg, transparent, rgba(255,255,255,.44), transparent 34%);
            animation: logoSpin 5.6s linear infinite;
        }

        .brand-logo span {
            position: relative;
            z-index: 1;
            font-size: 38px;
            filter: drop-shadow(0 10px 16px rgba(2,6,23,.30));
        }

        @@keyframes logoSpin {
            to {
                transform: rotate(360deg);
            }
        }

        .brand-text strong {
            display: block;
            color: #fff;
            font-size: 27px;
            line-height: 1;
            font-weight: 1000;
            letter-spacing: -.7px;
        }

        .brand-text small {
            display: block;
            margin-top: 8px;
            color: rgba(226,232,240,.78);
            font-size: 13px;
            font-weight: 780;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            min-height: 60px;
            padding: 0 21px;
            border-radius: 22px;
            background: rgba(15, 23, 42, .58);
            border: 1px solid rgba(148,163,184,.20);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 18px 42px rgba(2,6,23,.24);
            backdrop-filter: blur(18px);
            white-space: nowrap;
        }

        .status-dot {
            width: 16px;
            height: 16px;
            border-radius: 999px;
            background: #22c55e;
            box-shadow: 0 0 0 0 rgba(34,197,94,.68), 0 0 24px rgba(34,197,94,.64);
            animation: statusPulse 1.8s ease-out infinite;
        }

        @@keyframes statusPulse {
            0% {
                box-shadow: 0 0 0 0 rgba(34,197,94,.62), 0 0 24px rgba(34,197,94,.62);
            }

            100% {
                box-shadow: 0 0 0 14px rgba(34,197,94,0), 0 0 24px rgba(34,197,94,.62);
            }
        }

        .status-text strong {
            display: block;
            color: #fff;
            font-size: 13px;
            font-weight: 1000;
        }

        .status-text span {
            display: block;
            margin-top: 2px;
            color: rgba(203,213,225,.72);
            font-size: 11px;
            font-weight: 760;
        }

        .hero {
            position: relative;
            flex: 1;
            display: grid;
            grid-template-columns: minmax(0, .98fr) minmax(330px, .86fr);
            gap: 20px;
            align-items: center;
            padding: 46px 0 32px;
        }

        .copy {
            min-width: 0;
        }

        .eyebrow {
            width: fit-content;
            display: inline-flex;
            align-items: center;
            min-height: 37px;
            padding: 0 17px;
            border-radius: 999px;
            color: #67e8f9;
            letter-spacing: 6px;
            text-transform: uppercase;
            background:
                linear-gradient(90deg, rgba(6,182,212,.16), rgba(124,58,237,.18));
            border: 1px solid rgba(103,232,249,.16);
            box-shadow:
                0 0 28px rgba(34,211,238,.08),
                inset 0 1px 0 rgba(255,255,255,.08);
            font-size: 12px;
            font-weight: 1000;
        }

        .hero-title {
            margin: 20px 0 0;
            max-width: 670px;
            color: #fff;
            font-size: clamp(62px, 5.5vw, 94px);
            line-height: .94;
            letter-spacing: -3.2px;
            font-weight: 1000;
            text-shadow: 0 8px 28px rgba(0,0,0,.34);
        }

        .hero-title .gradient {
            display: inline-block;
            color: transparent;
            background:
                linear-gradient(90deg, #22d3ee 0%, #60a5fa 34%, #8b5cf6 68%, #d946ef 100%);
            background-size: 200% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            animation: titleFlow 5.2s ease-in-out infinite;
        }

        @@keyframes titleFlow {
            0%, 100% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }
        }

        .hero-desc {
            max-width: 580px;
            margin: 22px 0 0;
            color: rgba(226,232,240,.84);
            font-size: 16px;
            line-height: 1.68;
            font-weight: 730;
        }

        .trust-row {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 26px;
        }

        .trust-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            min-height: 39px;
            padding: 0 15px;
            border-radius: 999px;
            color: rgba(241,245,249,.94);
            background: rgba(15, 23, 42, .56);
            border: 1px solid rgba(148,163,184,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 14px 28px rgba(2,6,23,.20);
            backdrop-filter: blur(16px);
            font-size: 12px;
            font-weight: 950;
            white-space: nowrap;
        }

        .visual {
            position: relative;
            min-height: 445px;
            display: grid;
            place-items: center;
            overflow: visible;
        }

        .orbit {
            position: absolute;
            width: 420px;
            height: 198px;
            border: 1px solid rgba(96,165,250,.34);
            border-radius: 50%;
            transform: rotate(-20deg);
            box-shadow: 0 0 28px rgba(59,130,246,.18);
            animation: orbitSpin 14s linear infinite;
        }

        .orbit.two {
            width: 470px;
            height: 220px;
            border-color: rgba(168,85,247,.34);
            transform: rotate(28deg);
            animation-duration: 18s;
            animation-direction: reverse;
        }

        .orbit.three {
            width: 380px;
            height: 176px;
            border-color: rgba(34,211,238,.30);
            transform: rotate(8deg);
            animation-duration: 12s;
        }

        .orbit::before {
            content: "";
            position: absolute;
            width: 10px;
            height: 10px;
            right: 44px;
            top: 16px;
            border-radius: 999px;
            background: #67e8f9;
            box-shadow: 0 0 22px #67e8f9;
        }

        .orbit.two::before {
            background: #a78bfa;
            box-shadow: 0 0 22px #a78bfa;
        }

        .orbit.three::before {
            background: #f472b6;
            box-shadow: 0 0 22px #f472b6;
        }

        @@keyframes orbitSpin {
            to {
                rotate: 360deg;
            }
        }

        .planet-icon {
            position: absolute;
            width: 64px;
            height: 64px;
            border-radius: 22px;
            display: grid;
            place-items: center;
            font-size: 30px;
            color: #fff;
            border: 1px solid rgba(255,255,255,.20);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.16),
                0 16px 34px rgba(2,6,23,.32);
            backdrop-filter: blur(16px);
            animation: planetFloat 4.8s var(--ease) infinite;
        }

        .planet-icon.one {
            left: 0;
            top: 112px;
            background: rgba(37,99,235,.64);
        }

        .planet-icon.two {
            right: 0;
            top: 80px;
            background: rgba(124,58,237,.64);
            animation-delay: -1s;
        }

        .planet-icon.three {
            right: 34px;
            bottom: 92px;
            background: rgba(16,185,129,.55);
            animation-delay: -2s;
        }

        .planet-icon.four {
            left: 42px;
            bottom: 78px;
            background: rgba(245,158,11,.55);
            animation-delay: -3s;
        }

        @@keyframes planetFloat {
            0%, 100% {
                transform: translate3d(0,0,0);
            }

            50% {
                transform: translate3d(0,-12px,0);
            }
        }

        .shield-stage {
            position: relative;
            width: 310px;
            height: 370px;
            display: grid;
            place-items: center;
            transform: translateY(20px) scale(1.04);
        }

        .stage-base {
            position: absolute;
            bottom: 12px;
            width: 296px;
            height: 90px;
            border-radius: 50%;
            background:
                radial-gradient(circle, rgba(34,211,238,.46), transparent 62%),
                linear-gradient(90deg, rgba(79,70,229,.40), rgba(6,182,212,.30));
            box-shadow:
                0 0 56px rgba(34,211,238,.38),
                0 0 90px rgba(79,70,229,.25);
        }

        .stage-base::before {
            content: "";
            position: absolute;
            inset: 16px 34px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,.25);
        }

        .cap-3d {
            position: absolute;
            top: -20px;
            left: 50%;
            z-index: 8;
            width: 230px;
            height: 118px;
            transform: translateX(-50%) rotate(-8deg);
            animation: capFloat 5.6s var(--ease) infinite;
            filter:
                drop-shadow(0 24px 38px rgba(37, 99, 235, .36))
                drop-shadow(0 0 30px rgba(168, 85, 247, .28));
        }

        @@keyframes capFloat {
            0%, 100% {
                transform: translateX(-50%) translateY(0) rotate(-8deg);
            }

            50% {
                transform: translateX(-50%) translateY(-12px) rotate(-8deg);
            }
        }

        .cap-board {
            position: absolute;
            left: 50%;
            top: 8px;
            width: 226px;
            height: 94px;
            transform: translateX(-50%) skewX(-16deg) rotate(-2deg);
            border-radius: 22px 26px 18px 22px;
            background:
                linear-gradient(135deg, rgba(255,255,255,.30), transparent 26%),
                linear-gradient(145deg, #1e3a8a 0%, #2563eb 42%, #7c3aed 100%);
            border: 1px solid rgba(255,255,255,.25);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.28),
                inset 0 -24px 40px rgba(2,6,23,.30),
                0 0 36px rgba(96,165,250,.28);
            clip-path: polygon(50% 0%, 100% 39%, 50% 80%, 0% 39%);
        }

        .cap-body {
            position: absolute;
            left: 50%;
            top: 67px;
            width: 102px;
            height: 52px;
            transform: translateX(-50%);
            border-radius: 0 0 28px 28px;
            background:
                linear-gradient(135deg, rgba(255,255,255,.18), transparent 30%),
                linear-gradient(145deg, #1d4ed8, #4f46e5 55%, #06b6d4);
            border: 1px solid rgba(255,255,255,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.22),
                0 14px 30px rgba(2,6,23,.28);
        }

        .cap-button {
            position: absolute;
            left: 50%;
            top: 39px;
            width: 18px;
            height: 18px;
            transform: translateX(-50%);
            border-radius: 999px;
            background: #93c5fd;
            border: 2px solid rgba(255,255,255,.55);
            box-shadow: 0 0 20px rgba(147,197,253,.70);
        }

        .cap-tassel {
            position: absolute;
            top: 48px;
            left: calc(50% + 82px);
            z-index: 9;
            width: 5px;
            height: 88px;
            border-radius: 999px;
            background: linear-gradient(180deg, #fbbf24, #fb923c);
            box-shadow: 0 0 18px rgba(251,191,36,.58);
            transform-origin: top center;
            animation: tasselSwing 3.7s ease-in-out infinite;
        }

        .cap-tassel::before {
            content: "";
            position: absolute;
            left: 50%;
            top: -9px;
            width: 15px;
            height: 15px;
            transform: translateX(-50%);
            border-radius: 999px;
            background: #fbbf24;
            box-shadow: 0 0 20px rgba(251,191,36,.72);
        }

        .cap-tassel::after {
            content: "";
            position: absolute;
            left: 50%;
            bottom: -16px;
            width: 28px;
            height: 32px;
            transform: translateX(-50%);
            border-radius: 0 0 15px 15px;
            background:
                linear-gradient(90deg, #f59e0b, #fbbf24, #fb923c);
            clip-path: polygon(12% 0%, 88% 0%, 100% 100%, 72% 78%, 50% 100%, 28% 78%, 0% 100%);
            box-shadow: 0 0 18px rgba(251,191,36,.50);
        }

        @@keyframes tasselSwing {
            0%, 100% {
                transform: rotate(7deg);
            }

            50% {
                transform: rotate(-10deg);
            }
        }

        .shield {
            position: relative;
            z-index: 4;
            width: 232px;
            height: 282px;
            filter: drop-shadow(0 30px 52px rgba(6,182,212,.28));
            animation: shieldFloat 5.6s var(--ease) infinite;
        }

        @@keyframes shieldFloat {
            0%, 100% {
                transform: translate3d(0, 0, 0);
            }

            50% {
                transform: translate3d(0, -15px, 0);
            }
        }

        .shield::before {
            content: "";
            position: absolute;
            inset: 0;
            clip-path: polygon(50% 0%, 91% 16%, 84% 71%, 50% 100%, 16% 71%, 9% 16%);
            background:
                linear-gradient(135deg, rgba(255,255,255,.36), rgba(255,255,255,.06) 28%, rgba(96,165,250,.38) 62%, rgba(34,211,238,.20)),
                linear-gradient(135deg, #312e81, #2563eb 55%, #06b6d4);
            border: 1px solid rgba(255,255,255,.42);
            box-shadow:
                inset 0 2px 0 rgba(255,255,255,.34),
                inset 0 -24px 46px rgba(2,6,23,.25),
                0 0 50px rgba(59,130,246,.40);
        }

        .shield::after {
            content: "";
            position: absolute;
            inset: 24px;
            clip-path: polygon(50% 0%, 88% 17%, 80% 68%, 50% 95%, 20% 68%, 12% 17%);
            background:
                linear-gradient(135deg, rgba(255,255,255,.20), rgba(99,102,241,.24), rgba(6,182,212,.14));
            border: 1px solid rgba(255,255,255,.30);
            box-shadow: inset 0 0 36px rgba(125,211,252,.20);
        }

        .lock {
            position: absolute;
            left: 50%;
            top: 50%;
            z-index: 6;
            width: 84px;
            height: 72px;
            transform: translate(-50%, -34%);
            border-radius: 19px;
            background:
                linear-gradient(135deg, #dbeafe, #7dd3fc 55%, #60a5fa);
            box-shadow:
                0 0 38px rgba(125,211,252,.72),
                inset 0 1px 0 rgba(255,255,255,.80);
        }

        .lock::before {
            content: "";
            position: absolute;
            left: 17px;
            top: -45px;
            width: 50px;
            height: 58px;
            border-radius: 26px 26px 10px 10px;
            border: 11px solid rgba(219,234,254,.96);
            border-bottom: 0;
            box-shadow: 0 0 20px rgba(125,211,252,.38);
        }

        .lock::after {
            content: "";
            position: absolute;
            left: 50%;
            top: 26px;
            width: 11px;
            height: 25px;
            transform: translateX(-50%);
            border-radius: 999px;
            background: #1e3a8a;
        }

        .role-info-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 15px;
            margin-top: 8px;
        }

        .role-info {
            position: relative;
            min-height: 176px;
            padding: 18px 70px 30px 18px;
            border-radius: 24px;
            border: 1px solid rgba(148,163,184,.18);
            background:
                linear-gradient(145deg, rgba(15,23,42,.66), rgba(15,23,42,.34));
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 18px 42px rgba(2,6,23,.20);
            backdrop-filter: blur(18px);
            overflow: hidden;
            cursor: pointer;
            transition:
                transform .2s var(--ease),
                border-color .2s var(--ease),
                box-shadow .2s var(--ease),
                background .2s var(--ease);
        }

        .role-info::before {
            content: "";
            position: absolute;
            width: 140px;
            height: 140px;
            right: -74px;
            bottom: -76px;
            border-radius: 999px;
            background: rgba(96,165,250,.08);
            pointer-events: none;
        }

        .role-info:hover {
            transform: translateY(-5px);
            border-color: rgba(96,165,250,.38);
            box-shadow:
                0 0 0 1px rgba(96,165,250,.08),
                0 22px 48px rgba(2,6,23,.28),
                0 0 28px rgba(59,130,246,.10);
        }

        .role-info:active {
            transform: translateY(-2px) scale(.995);
        }

        .role-info.student {
            border-color: rgba(59,130,246,.32);
        }

        .role-info.teacher {
            border-color: rgba(16,185,129,.28);
        }

        .role-info.parent {
            border-color: rgba(168,85,247,.30);
        }

        .role-info.admin {
            border-color: rgba(251,146,60,.30);
        }

        .role-info-icon {
            width: 52px;
            height: 52px;
            border-radius: 18px;
            display: grid;
            place-items: center;
            margin-bottom: 13px;
            font-size: 25px;
            color: #fff;
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.14),
                0 14px 26px rgba(2,6,23,.24);
        }

        .student .role-info-icon {
            background: rgba(37,99,235,.58);
        }

        .teacher .role-info-icon {
            background: rgba(16,185,129,.46);
        }

        .parent .role-info-icon {
            background: rgba(124,58,237,.54);
        }

        .admin .role-info-icon {
            background: rgba(245,158,11,.48);
        }

        .role-info strong {
            display: block;
            font-size: 18px;
            line-height: 1.1;
            font-weight: 1000;
        }

        .student strong {
            color: #38bdf8;
        }

        .teacher strong {
            color: #34d399;
        }

        .parent strong {
            color: #c084fc;
        }

        .admin strong {
            color: #fbbf24;
        }

        .role-info p {
            margin: 9px 0 0;
            color: rgba(226,232,240,.78);
            font-size: 12px;
            line-height: 1.52;
            font-weight: 740;
            max-width: 100%;
        }

        .role-arrow {
            position: absolute;
            right: 16px;
            bottom: 15px;
            width: 42px;
            height: 42px;
            border-radius: 16px;
            display: grid;
            place-items: center;
            background: rgba(255,255,255,.07);
            border: 1px solid rgba(255,255,255,.10);
            color: #93c5fd;
            font-size: 22px;
            pointer-events: none;
        }

        .metrics {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0;
            margin-top: 22px;
            border-radius: 25px;
            background:
                linear-gradient(145deg, rgba(15,23,42,.72), rgba(15,23,42,.42));
            border: 1px solid rgba(148,163,184,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 18px 42px rgba(2,6,23,.20);
            backdrop-filter: blur(18px);
            overflow: hidden;
        }

        .metric {
            min-height: 98px;
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 17px;
            border-right: 1px solid rgba(148,163,184,.14);
        }

        .metric:last-child {
            border-right: 0;
        }

        .metric-icon {
            width: 50px;
            height: 50px;
            flex: 0 0 auto;
            border-radius: 17px;
            display: grid;
            place-items: center;
            font-size: 25px;
            background: rgba(79,70,229,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.12),
                0 0 28px rgba(79,70,229,.16);
        }

        .metric-value {
            color: #fff;
            font-size: 27px;
            line-height: 1;
            font-weight: 1000;
            letter-spacing: -.6px;
            white-space: nowrap;
        }

        .metric-label {
            margin-top: 6px;
            color: rgba(203,213,225,.72);
            font-size: 11px;
            font-weight: 790;
        }

        .right {
            min-width: 0;
            display: flex;
        }

        .login-card {
            position: relative;
            width: 100%;
            min-height: 100%;
            padding: 36px;
            border-radius: 36px;
            background:
                radial-gradient(circle at 10% 8%, rgba(59,130,246,.18), transparent 28%),
                radial-gradient(circle at 90% 88%, rgba(124,58,237,.20), transparent 30%),
                linear-gradient(145deg, rgba(15,23,42,.80), rgba(2,6,23,.76));
            border: 1px solid rgba(148,163,184,.24);
            box-shadow:
                0 34px 90px rgba(2,6,23,.42),
                inset 0 1px 0 rgba(255,255,255,.10);
            backdrop-filter: blur(22px);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-card::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            pointer-events: none;
            background:
                linear-gradient(135deg, rgba(255,255,255,.10), transparent 36%),
                radial-gradient(circle at 85% 12%, rgba(167,139,250,.12), transparent 24%);
        }

        .login-card > * {
            position: relative;
            z-index: 1;
        }

        .login-tools {
            position: absolute;
            right: 24px;
            top: 22px;
            z-index: 2;
            display: flex;
            gap: 10px;
        }

        .tool-pill,
        .tool-circle {
            min-height: 43px;
            border-radius: 16px;
            color: rgba(241,245,249,.92);
            background: rgba(15,23,42,.56);
            border: 1px solid rgba(148,163,184,.20);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.08),
                0 12px 24px rgba(2,6,23,.18);
            backdrop-filter: blur(16px);
        }

        .tool-pill {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 0 13px;
            font-size: 12px;
            font-weight: 900;
        }

        .tool-circle {
            width: 43px;
            display: grid;
            place-items: center;
            font-size: 17px;
        }

        .login-head {
            max-width: 470px;
            margin: 0 auto 28px;
            text-align: center;
        }

        .login-symbol {
            width: 112px;
            height: 112px;
            margin: 0 auto 18px;
            border-radius: 34px;
            display: grid;
            place-items: center;
            font-size: 50px;
            background:
                radial-gradient(circle at 28% 18%, rgba(255,255,255,.46), transparent 25%),
                linear-gradient(135deg, #1d4ed8 0%, #7c3aed 58%, #06b6d4 100%);
            border: 1px solid rgba(255,255,255,.24);
            box-shadow:
                0 0 34px rgba(34,211,238,.18),
                0 24px 60px rgba(79,70,229,.32),
                inset 0 1px 0 rgba(255,255,255,.34);
            position: relative;
            overflow: hidden;
        }

        .login-symbol::before {
            content: "";
            position: absolute;
            inset: -50%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.34), transparent);
            transform: rotate(35deg) translateX(-100%);
            animation: symbolSweep 4.8s ease-in-out infinite;
        }

        @@keyframes symbolSweep {
            0%, 55%, 100% {
                transform: rotate(35deg) translateX(-100%);
            }

            72% {
                transform: rotate(35deg) translateX(100%);
            }
        }

        .login-symbol span {
            position: relative;
            z-index: 1;
            filter: drop-shadow(0 10px 16px rgba(2,6,23,.35));
        }

        .login-title {
            margin: 0;
            color: #fff;
            font-size: 42px;
            line-height: 1;
            font-weight: 1000;
            letter-spacing: -1.3px;
        }

        .login-subtitle {
            margin: 12px auto 0;
            max-width: 390px;
            color: rgba(203,213,225,.78);
            font-size: 14px;
            line-height: 1.55;
            font-weight: 760;
        }

        .alert {
            width: min(100%, 580px);
            margin: 0 auto 15px;
            border-radius: 18px;
            padding: 13px 15px;
            font-size: 13px;
            line-height: 1.5;
            font-weight: 900;
            border: 1px solid transparent;
        }

        .alert-success {
            color: #bbf7d0;
            background: rgba(22,101,52,.26);
            border-color: rgba(34,197,94,.22);
        }

        .alert-danger {
            color: #fecaca;
            background: rgba(127,29,29,.30);
            border-color: rgba(248,113,113,.20);
        }

        .form {
            width: min(100%, 580px);
            margin: 0 auto;
            display: grid;
            gap: 15px;
        }

        .role-switcher {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 8px;
            padding: 7px;
            border-radius: 23px;
            background: rgba(15,23,42,.54);
            border: 1px solid rgba(148,163,184,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.07),
                0 14px 30px rgba(2,6,23,.20);
        }

        .role-item {
            position: relative;
        }

        .role-item input {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        .role-item label {
            min-height: 72px;
            border-radius: 17px;
            display: grid;
            place-items: center;
            gap: 7px;
            color: rgba(203,213,225,.75);
            cursor: pointer;
            user-select: none;
            font-size: 12px;
            font-weight: 1000;
            transition:
                transform .18s var(--ease),
                color .18s var(--ease),
                background .18s var(--ease),
                box-shadow .18s var(--ease);
        }

        .role-item label:hover {
            transform: translateY(-2px);
            color: #fff;
            background: rgba(255,255,255,.06);
        }

        .role-item label span {
            display: block;
            font-size: 24px;
            line-height: 1;
        }

        .role-item input:checked + label {
            color: #fff;
            background:
                radial-gradient(circle at 28% 18%, rgba(255,255,255,.22), transparent 30%),
                linear-gradient(135deg, rgba(37,99,235,.92), rgba(124,58,237,.92));
            box-shadow:
                0 0 0 1px rgba(125,211,252,.24),
                0 16px 34px rgba(79,70,229,.32),
                inset 0 1px 0 rgba(255,255,255,.16);
            transform: translateY(-1px);
        }

        .field {
            display: grid;
            gap: 8px;
        }

        .field-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .field-head label {
            color: #fff;
            font-size: 14px;
            font-weight: 1000;
        }

        .field-hint {
            color: rgba(148,163,184,.78);
            font-size: 12px;
            font-weight: 850;
            white-space: nowrap;
        }

        .input-box {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            width: 40px;
            height: 40px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            color: rgba(203,213,225,.86);
            background: rgba(15,23,42,.62);
            border: 1px solid rgba(148,163,184,.14);
            font-size: 17px;
            pointer-events: none;
        }

        .input-control {
            width: 100%;
            min-height: 62px;
            border: 1px solid rgba(148,163,184,.22);
            outline: none;
            border-radius: 18px;
            color: #fff;
            background: rgba(15, 23, 42, .52);
            padding: 0 56px 0 64px;
            font-size: 14px;
            font-weight: 840;
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.06),
                0 12px 24px rgba(2,6,23,.18);
            transition:
                border-color .18s var(--ease),
                box-shadow .18s var(--ease),
                background .18s var(--ease);
        }

        .input-control::placeholder {
            color: rgba(148,163,184,.72);
        }

        .input-control:focus {
            background: rgba(15,23,42,.72);
            border-color: rgba(96,165,250,.72);
            box-shadow:
                0 0 0 4px rgba(59,130,246,.13),
                0 18px 36px rgba(2,6,23,.26);
        }

        .password-toggle {
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            width: 40px;
            height: 40px;
            border: 0;
            border-radius: 14px;
            display: grid;
            place-items: center;
            cursor: pointer;
            color: rgba(203,213,225,.84);
            background: rgba(15,23,42,.62);
            border: 1px solid rgba(148,163,184,.14);
            font-size: 15px;
            transition:
                background .18s var(--ease),
                color .18s var(--ease),
                transform .18s var(--ease);
        }

        .password-toggle:hover {
            color: #fff;
            background: rgba(79,70,229,.34);
            transform: translateY(-50%) scale(1.04);
        }

        .forgot-row {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin-top: -2px;
        }

        .forgot-link {
            color: #a78bfa;
            text-decoration: none;
            font-size: 12px;
            font-weight: 1000;
        }

        .forgot-link:hover {
            color: #c4b5fd;
            text-decoration: underline;
        }

        .submit-area {
            display: grid;
            gap: 12px;
            margin-top: 4px;
        }

        .login-button {
            position: relative;
            width: 100%;
            min-height: 66px;
            border: 0;
            border-radius: 19px;
            color: #fff;
            cursor: pointer;
            overflow: hidden;
            font-size: 15px;
            font-weight: 1000;
            background:
                linear-gradient(135deg, #22d3ee 0%, #2563eb 46%, #9333ea 100%);
            box-shadow:
                0 24px 56px rgba(37,99,235,.30),
                0 12px 28px rgba(147,51,234,.20);
            transition:
                transform .18s var(--ease),
                box-shadow .18s var(--ease),
                filter .18s var(--ease);
        }

        .login-button::before {
            content: "";
            position: absolute;
            top: 0;
            left: -120%;
            width: 70%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.34), transparent);
            transform: skewX(-20deg);
            transition: left .62s var(--ease);
        }

        .login-button span {
            position: relative;
            z-index: 1;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .login-button:hover {
            transform: translateY(-2px) scale(1.01);
            filter: brightness(1.04);
            box-shadow:
                0 30px 68px rgba(37,99,235,.38),
                0 16px 36px rgba(147,51,234,.24);
        }

        .login-button:hover::before {
            left: 132%;
        }

        .divider {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 32px;
            color: rgba(148,163,184,.75);
            font-size: 12px;
            font-weight: 800;
        }

        .divider::before,
        .divider::after {
            content: "";
            height: 1px;
            flex: 1;
            background: rgba(148,163,184,.18);
        }

        .divider span {
            padding: 0 16px;
        }

        .security-card {
            display: flex;
            align-items: center;
            gap: 14px;
            min-height: 75px;
            padding: 15px;
            border-radius: 21px;
            background:
                radial-gradient(circle at 92% 20%, rgba(79,70,229,.18), transparent 28%),
                rgba(15,23,42,.54);
            border: 1px solid rgba(148,163,184,.18);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,.07),
                0 14px 30px rgba(2,6,23,.20);
        }

        .security-icon {
            width: 52px;
            height: 52px;
            flex: 0 0 auto;
            border-radius: 17px;
            display: grid;
            place-items: center;
            font-size: 26px;
            background:
                linear-gradient(135deg, rgba(37,99,235,.75), rgba(124,58,237,.65));
            box-shadow:
                0 0 28px rgba(79,70,229,.18),
                inset 0 1px 0 rgba(255,255,255,.16);
        }

        .security-card strong {
            display: block;
            color: #fff;
            font-size: 13px;
            font-weight: 1000;
        }

        .security-card span {
            display: block;
            margin-top: 4px;
            color: rgba(203,213,225,.72);
            font-size: 11px;
            line-height: 1.45;
            font-weight: 740;
        }

        .micro-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
            margin-top: 14px;
        }

        .micro {
            min-height: 66px;
            padding: 12px;
            border-radius: 18px;
            background: rgba(15,23,42,.50);
            border: 1px solid rgba(148,163,184,.15);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .micro-icon {
            width: 33px;
            height: 33px;
            flex: 0 0 auto;
            border-radius: 12px;
            display: grid;
            place-items: center;
            font-size: 17px;
            background: rgba(255,255,255,.06);
        }

        .micro strong {
            display: block;
            color: rgba(241,245,249,.92);
            font-size: 11px;
            font-weight: 1000;
        }

        .micro span {
            display: block;
            margin-top: 2px;
            color: rgba(148,163,184,.76);
            font-size: 10px;
            line-height: 1.25;
            font-weight: 760;
        }

        @@media (max-width: 1360px) {
            .page {
                display: block;
                padding: 18px;
            }

            .shell {
                grid-template-columns: 1fr;
                min-height: auto;
                max-width: 1000px;
                margin: 0 auto;
            }

            .hero {
                grid-template-columns: 1fr;
                padding-top: 42px;
            }

            .visual {
                order: -1;
                min-height: 400px;
                margin-top: 10px;
            }

            .left {
                padding: 12px 0 0;
            }

            .right {
                min-height: auto;
            }

            .login-card {
                min-height: auto;
            }
        }

        @@media (max-width: 900px) {
            .shell {
                padding: 18px;
                border-radius: 34px;
            }

            .topbar {
                align-items: flex-start;
            }

            .status-pill {
                display: none;
            }

            .hero-title {
                font-size: clamp(46px, 11vw, 72px);
                letter-spacing: -2.4px;
            }

            .eyebrow {
                letter-spacing: 4px;
            }

            .role-info-grid {
                grid-template-columns: 1fr 1fr;
            }

            .role-info {
                min-height: 160px;
                padding-right: 74px;
                padding-bottom: 30px;
            }

            .metrics {
                grid-template-columns: 1fr 1fr;
            }

            .metric:nth-child(2) {
                border-right: 0;
            }

            .metric:nth-child(1),
            .metric:nth-child(2) {
                border-bottom: 1px solid rgba(148,163,184,.14);
            }

            .login-tools {
                position: static;
                margin-bottom: 18px;
                justify-content: flex-end;
            }

            .login-head {
                margin-top: 0;
            }
        }

        @@media (max-width: 640px) {
            .page {
                padding: 10px;
            }

            .shell {
                padding: 14px;
                border-radius: 28px;
            }

            .brand-logo {
                width: 60px;
                height: 60px;
                border-radius: 22px;
            }

            .brand-logo span {
                font-size: 30px;
            }

            .brand-text strong {
                font-size: 21px;
            }

            .brand-text small {
                font-size: 12px;
            }

            .hero {
                padding: 32px 0 24px;
            }

            .eyebrow {
                width: 100%;
                justify-content: center;
                letter-spacing: 2px;
                font-size: 11px;
            }

            .hero-title {
                font-size: 43px;
                letter-spacing: -1.8px;
            }

            .hero-desc {
                font-size: 14px;
            }

            .trust-pill {
                width: 100%;
                justify-content: center;
            }

            .visual {
                min-height: 320px;
                transform: scale(.76);
                margin: -28px 0 -56px;
            }

            .role-info-grid,
            .metrics,
            .micro-grid {
                grid-template-columns: 1fr;
            }

            .role-info {
                min-height: auto;
                padding: 18px 74px 32px 18px;
            }

            .metric {
                border-right: 0;
                border-bottom: 1px solid rgba(148,163,184,.14);
            }

            .metric:last-child {
                border-bottom: 0;
            }

            .login-card {
                padding: 20px;
                border-radius: 28px;
            }

            .login-tools {
                justify-content: space-between;
            }

            .login-symbol {
                width: 88px;
                height: 88px;
                border-radius: 28px;
                font-size: 40px;
            }

            .login-title {
                font-size: 34px;
            }

            .role-switcher {
                grid-template-columns: 1fr 1fr;
            }

            .role-item label {
                min-height: 66px;
            }

            .field-head {
                align-items: flex-start;
                flex-direction: column;
                gap: 4px;
            }

            .security-card {
                align-items: flex-start;
            }
        }

        @@media (max-width: 420px) {
            .hero-title {
                font-size: 38px;
            }

            .login-tools {
                display: none;
            }

            .role-switcher {
                grid-template-columns: 1fr;
            }

            .visual {
                display: none;
            }

            .input-control {
                padding-left: 62px;
                padding-right: 54px;
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: .01ms !important;
                animation-iteration-count: 1 !important;
                scroll-behavior: auto !important;
                transition-duration: .01ms !important;
            }
        }
    </style>
</head>

<body>
    <main class="page">
        <div class="aurora" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="beam one" aria-hidden="true"></div>
        <div class="beam two" aria-hidden="true"></div>
        <div class="beam three" aria-hidden="true"></div>

        <section class="shell">
            <aside class="left">
                <div class="topbar">
                    <div class="brand">
                        <div class="brand-logo">
                            <span>🎓</span>
                        </div>

                        <div class="brand-text">
                            <strong>Ödev Sistemi</strong>
                            <small>Akıllı Okul Yönetim Platformu</small>
                        </div>
                    </div>

                    <div class="status-pill">
                        <span class="status-dot"></span>

                        <div class="status-text">
                            <strong>@systemStatusTitle</strong>
                            <span>@systemStatusSubTitle</span>
                        </div>
                    </div>
                </div>

                <div class="hero">
                    <div class="copy">
                        <div class="eyebrow">
                            AKILLI OKUL, GÜÇLÜ GELECEK
                        </div>

                        <h1 class="hero-title">
                            Her Rol İçin<br />
                            Tek Noktadan<br />
                            <span class="gradient">Akıllı Giriş</span>
                        </h1>

                        <p class="hero-desc">
                            Öğrenci, öğretmen, veli ve yöneticiler için tasarlanmış modern, hızlı ve güvenli giriş deneyimi.
                        </p>

                        <div class="trust-row">
                            <div class="trust-pill">🛡️ Güvenli Erişim</div>
                            <div class="trust-pill">⚡ Hızlı & Kolay</div>
                            <div class="trust-pill">🎧 Destekli Sistem</div>
                            <div class="trust-pill">🔒 Verileriniz Güvende</div>
                        </div>
                    </div>

                    <div class="visual" aria-hidden="true">
                        <div class="orbit"></div>
                        <div class="orbit two"></div>
                        <div class="orbit three"></div>

                        <div class="planet-icon one">👥</div>
                        <div class="planet-icon two">📖</div>
                        <div class="planet-icon three">🎓</div>
                        <div class="planet-icon four">👪</div>

                        <div class="shield-stage">
                            <div class="cap-3d">
                                <div class="cap-board"></div>
                                <div class="cap-body"></div>
                                <div class="cap-button"></div>
                                <div class="cap-tassel"></div>
                            </div>

                            <div class="stage-base"></div>

                            <div class="shield">
                                <div class="lock"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="role-info-grid">
                    <div class="role-info student" data-role-card="Öğrenci" tabindex="0" role="button" aria-label="Öğrenci rolünü seç">
                        <div class="role-info-icon">🎓</div>
                        <strong>Öğrenci</strong>
                        <p>Ödevlerinizi görüntüleyin, teslim edin ve notlarınızı takip edin.</p>
                        <div class="role-arrow">→</div>
                    </div>

                    <div class="role-info teacher" data-role-card="Öğretmen" tabindex="0" role="button" aria-label="Öğretmen rolünü seç">
                        <div class="role-info-icon">🧑‍🏫</div>
                        <strong>Öğretmen</strong>
                        <p>Dersleri yönetin, ödevleri değerlendirin ve öğrencileri takip edin.</p>
                        <div class="role-arrow">→</div>
                    </div>

                    <div class="role-info parent" data-role-card="Veli" tabindex="0" role="button" aria-label="Veli rolünü seç">
                        <div class="role-info-icon">👥</div>
                        <strong>Veli</strong>
                        <p>Çocuğunuzun gelişimini izleyin ve duyuruları takip edin.</p>
                        <div class="role-arrow">→</div>
                    </div>

                    <div class="role-info admin" data-role-card="Admin" tabindex="0" role="button" aria-label="Admin rolünü seç">
                        <div class="role-info-icon">👑</div>
                        <strong>Yönetici</strong>
                        <p>Kullanıcıları ve sistemi yönetin, raporları inceleyin.</p>
                        <div class="role-arrow">→</div>
                    </div>
                </div>

                <div class="metrics" aria-label="Sistem bilgileri">
                    <div class="metric">
                        <div class="metric-icon">👥</div>
                        <div>
                            <div class="metric-value">@activeUsersText</div>
                            <div class="metric-label">Aktif Kullanıcı</div>
                        </div>
                    </div>

                    <div class="metric">
                        <div class="metric-icon">📚</div>
                        <div>
                            <div class="metric-value">@activeLessonsText</div>
                            <div class="metric-label">Aktif Ders</div>
                        </div>
                    </div>

                    <div class="metric">
                        <div class="metric-icon">📋</div>
                        <div>
                            <div class="metric-value">@completedHomeworksText</div>
                            <div class="metric-label">Tamamlanan Ödev</div>
                        </div>
                    </div>

                    <div class="metric">
                        <div class="metric-icon">📈</div>
                        <div>
                            <div class="metric-value">@systemSuccessRateText</div>
                            <div class="metric-label">Sistem Başarı Oranı</div>
                        </div>
                    </div>
                </div>
            </aside>

            <section class="right">
                <div class="login-card">
                    <div class="login-tools" aria-hidden="true">
                        <div class="tool-pill">🌐 TR</div>
                        <div class="tool-circle">☾</div>
                    </div>

                    <div class="login-head">
                        <div class="login-symbol">
                            <span>🔐</span>
                        </div>

                        <h2 class="login-title">
                            Giriş Yap
                        </h2>

                        <p class="login-subtitle">
                            Hesabınıza erişmek için bilgilerinizi girin.
                        </p>
                    </div>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">
                            @TempData["Success"]
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">
                            @TempData["Error"]
                        </div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(x => x.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-controller="Auth" asp-action="Login" method="post" class="form" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="role-switcher" aria-label="Rol seçimi">
                            <div class="role-item">
                                <input type="radio"
                                       id="role-student"
                                       name="Role"
                                       value="Öğrenci"
                                       @(selectedRole == "Öğrenci" ? "checked" : "") />
                                <label for="role-student">
                                    <span>🎓</span>
                                    Öğrenci
                                </label>
                            </div>

                            <div class="role-item">
                                <input type="radio"
                                       id="role-teacher"
                                       name="Role"
                                       value="Öğretmen"
                                       @(selectedRole == "Öğretmen" ? "checked" : "") />
                                <label for="role-teacher">
                                    <span>🧑‍🏫</span>
                                    Öğretmen
                                </label>
                            </div>

                            <div class="role-item">
                                <input type="radio"
                                       id="role-parent"
                                       name="Role"
                                       value="Veli"
                                       @(selectedRole == "Veli" ? "checked" : "") />
                                <label for="role-parent">
                                    <span>👥</span>
                                    Veli
                                </label>
                            </div>

                            <div class="role-item">
                                <input type="radio"
                                       id="role-admin"
                                       name="Role"
                                       value="Admin"
                                       @(selectedRole == "Admin" ? "checked" : "") />
                                <label for="role-admin">
                                    <span>👑</span>
                                    Yönetici
                                </label>
                            </div>
                        </div>

                        <div class="field">
                            <div class="field-head">
                                <label for="numberInput">Numara</label>
                                <span class="field-hint">Okul / Kullanıcı Numaranızı Girin</span>
                            </div>

                            <div class="input-box">
                                <div class="input-icon">#</div>

                                <input id="numberInput"
                                       class="input-control"
                                       type="text"
                                       name="Number"
                                       value="@postedNumber"
                                       inputmode="numeric"
                                       autocomplete="username"
                                       placeholder="Okul / Kullanıcı Numaranızı Girin" />
                            </div>
                        </div>

                        <div class="field">
                            <div class="field-head">
                                <label for="passwordInput">Şifre</label>
                            </div>

                            <div class="input-box">
                                <div class="input-icon">🔒</div>

                                <input id="passwordInput"
                                       class="input-control"
                                       type="password"
                                       name="Password"
                                       autocomplete="current-password"
                                       placeholder="Şifrenizi Girin" />

                                <button class="password-toggle"
                                        type="button"
                                        aria-label="Şifreyi göster"
                                        onclick="togglePassword()">
                                    👁️
                                </button>
                            </div>
                        </div>

                        <div class="forgot-row">
                            <a asp-controller="ForgotPassword"
                               asp-action="Index"
                               class="forgot-link">
                                Şifremi Unuttum?
                            </a>
                        </div>

                        <div class="submit-area">
                            <button type="submit" class="login-button">
                                <span>🔒 Giriş Yap →</span>
                            </button>
                        </div>

                        <div class="divider">
                            <span>veya</span>
                        </div>

                        <div class="security-card">
                            <div class="security-icon">🛡️</div>
                            <div>
                                <strong>Güvenliğiniz Bizim Önceliğimiz</strong>
                                <span>
                                    İlk girişte aktivasyon kodu istenirse size verilen kodla giriş yapıp yeni şifrenizi oluşturabilirsiniz.
                                </span>
                            </div>
                        </div>

                        <div class="micro-grid">
                            <div class="micro">
                                <div class="micro-icon">🔐</div>
                                <div>
                                    <strong>Güvenli Giriş</strong>
                                    <span>Rol bazlı erişim</span>
                                </div>
                            </div>

                            <div class="micro">
                                <div class="micro-icon">⚡</div>
                                <div>
                                    <strong>Hızlı Erişim</strong>
                                    <span>Anında giriş imkanı</span>
                                </div>
                            </div>

                            <div class="micro">
                                <div class="micro-icon">🎧</div>
                                <div>
                                    <strong>Destekli Sistem</strong>
                                    <span>Kesintisiz kullanım</span>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </section>
        </section>
    </main>

    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const button = document.querySelector(".password-toggle");

            if (!input) {
                return;
            }

            if (input.type === "password") {
                input.type = "text";

                if (button) {
                    button.textContent = "🙈";
                    button.setAttribute("aria-label", "Şifreyi gizle");
                }
            } else {
                input.type = "password";

                if (button) {
                    button.textContent = "👁️";
                    button.setAttribute("aria-label", "Şifreyi göster");
                }
            }
        }

        const numberInput = document.getElementById("numberInput");
        const passwordInput = document.getElementById("passwordInput");
        const roleCards = document.querySelectorAll("[data-role-card]");
        const roleInputs = document.querySelectorAll("input[name='Role']");

        let currentRole = "";

        roleInputs.forEach(function (input) {
            if (input.checked) {
                currentRole = input.value;
            }
        });

        function clearLoginFields() {
            if (numberInput) {
                numberInput.value = "";
            }

            if (passwordInput) {
                passwordInput.value = "";
                passwordInput.type = "password";
            }

            const button = document.querySelector(".password-toggle");

            if (button) {
                button.textContent = "👁️";
                button.setAttribute("aria-label", "Şifreyi göster");
            }
        }

        function changeRole(role) {
            if (!role) {
                return;
            }

            roleInputs.forEach(function (input) {
                if (input.value === role) {
                    if (currentRole !== role) {
                        input.checked = true;
                        currentRole = role;
                        clearLoginFields();
                    } else {
                        input.checked = true;
                    }
                }
            });
        }

        if (numberInput) {
            numberInput.addEventListener("input", function () {
                this.value = this.value.replace(/[^\d]/g, "");
            });
        }

        roleInputs.forEach(function (input) {
            input.addEventListener("change", function () {
                changeRole(input.value);
            });
        });

        roleCards.forEach(function (card) {
            card.addEventListener("click", function () {
                changeRole(card.getAttribute("data-role-card"));
            });

            card.addEventListener("keydown", function (event) {
                if (event.key === "Enter" || event.key === " ") {
                    event.preventDefault();
                    card.click();
                }
            });
        });
    </script>
</body>
</html>