@model CreatePasswordViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Şifre Oluştur";
}

<div class="auth-page">
    <div class="auth-shell">
        <section class="auth-hero">
            <div class="auth-brand">
                <div class="auth-brand-icon">🔐</div>
                <div class="auth-brand-title">Güvenli İlk Giriş</div>
            </div>

            <div class="auth-hero-title">
                Aktivasyon<br />
                tamamlandı.<br />
                Şimdi şifre oluştur.
            </div>

            <div class="auth-hero-text">
                Bu şifre sonraki girişlerinde kullanılacak.
                Aktivasyon kodun artık geçersiz hale getirilecek.
            </div>

            <div class="auth-pills">
                <div class="auth-pill">✅ Tek kullanımlık kod</div>
                <div class="auth-pill">🔒 Kalıcı şifre</div>
                <div class="auth-pill">⚡ Hızlı giriş</div>
            </div>
        </section>

        <section class="auth-card">
            <div class="auth-card-icon">🔑</div>

            <div class="auth-card-title">Yeni Şifre</div>
            <div class="auth-card-subtitle">
                @Model.Name hesabı için kalıcı şifre oluştur.
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="Auth" asp-action="CreatePassword" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Role" />
                <input type="hidden" asp-for="Name" />
                <input type="hidden" asp-for="Number" />

                <div class="form-group">
                    <label class="form-label" asp-for="NewPassword">Yeni Şifre</label>
                    <input class="form-control"
                           asp-for="NewPassword"
                           type="password"
                           placeholder="En az 4 karakter" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div style="height: 14px;"></div>

                <div class="form-group">
                    <label class="form-label" asp-for="RepeatPassword">Yeni Şifre Tekrar</label>
                    <input class="form-control"
                           asp-for="RepeatPassword"
                           type="password"
                           placeholder="Şifreyi tekrar gir" />
                    <span asp-validation-for="RepeatPassword" class="text-danger"></span>
                </div>

                <div style="height: 24px;"></div>

                <button type="submit" class="btn btn-primary" style="width:100%; height:58px;">
                    ✅ Şifreyi Oluştur
                </button>
            </form>
        </section>
    </div>
</div>