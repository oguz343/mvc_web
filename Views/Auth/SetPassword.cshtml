@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Şifre Oluştur";

    var name = ViewBag.Name as string ?? "Kullanıcı";
    var role = ViewBag.Role as string ?? "";
    var number = ViewBag.Number as string ?? "";
}

<div class="set-password-page">
    <div class="set-password-card">
        <div class="set-password-icon">🔐</div>

        <h1>Yeni Şifre Oluştur</h1>

        <p>
            @name hesabı için kalıcı şifrenizi oluşturun.
            Bundan sonra aktivasyon kodu yerine bu şifreyle giriş yapacaksınız.
        </p>

        <div class="user-mini-info">
            <strong>@role</strong>
            <span>No: @number</span>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Auth" asp-action="SetPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="field">
                <label>Yeni Şifre</label>
                <input type="password"
                       name="password"
                       placeholder="Yeni şifre"
                       autocomplete="new-password"
                       minlength="8"
                       required />
            </div>

            <div class="field">
                <label>Yeni Şifre Tekrar</label>
                <input type="password"
                       name="repeatPassword"
                       placeholder="Yeni şifre tekrar"
                       autocomplete="new-password"
                       minlength="8"
                       required />
            </div>

            <button type="submit" class="save-btn">
                Şifreyi Oluştur
            </button>
        </form>
    </div>
</div>

<style>
    .set-password-page {
        min-height: calc(100vh - 120px);
        display: grid;
        align-items: center;
        justify-content: center;
        padding: 34px 18px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .13), transparent 34%),
            radial-gradient(circle at 100% 20%, rgba(124, 58, 237, .14), transparent 34%),
            linear-gradient(135deg, rgba(7, 17, 31, .72), rgba(15, 23, 42, .42));
    }

    .set-password-card {
        width: 100%;
        max-width: 540px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .12), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .95), rgba(17, 24, 39, .88));
        border: 1px solid rgba(148, 163, 184, .20);
        border-radius: 30px;
        padding: 32px;
        box-shadow: 0 24px 70px rgba(0, 0, 0, .34);
        color: #f8fafc;
        backdrop-filter: blur(18px);
    }

    .set-password-icon {
        width: 64px;
        height: 64px;
        border-radius: 20px;
        background:
            radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .28), transparent 28%),
            linear-gradient(135deg, #2563eb, #7c3aed 58%, #06b6d4);
        color: #ffffff;
        display: grid;
        place-items: center;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        margin: 0 auto 18px;
        box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
    }

    .set-password-card h1 {
        text-align: center;
        margin: 0;
        color: #ffffff;
        font-size: clamp(30px, 4vw, 44px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.04em;
    }

    .set-password-card p {
        text-align: center;
        color: #aab8cf;
        font-weight: 700;
        line-height: 1.6;
        margin: 14px 0 0;
    }

    .user-mini-info {
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 16px;
        padding: 14px;
        margin: 18px 0;
        display: flex;
        gap: 10px;
        justify-content: space-between;
        font-weight: 900;
        color: #ffffff;
    }

    .user-mini-info span {
        color: #94a3b8;
    }

    .alert {
        padding: 14px 16px;
        border-radius: 16px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .alert-danger {
        background: rgba(239, 68, 68, .12);
        color: #fecaca;
        border: 1px solid rgba(248, 113, 113, .20);
    }

    .field {
        margin-bottom: 14px;
    }

    .field label {
        display: block;
        margin-bottom: 8px;
        color: #dbeafe;
        font-weight: 900;
    }

    .field input {
        width: 100%;
        border: 1px solid rgba(148, 163, 184, .18);
        background: rgba(7, 17, 31, .62);
        color: #ffffff;
        border-radius: 16px;
        padding: 16px;
        font-weight: 700;
        outline: none;
        color-scheme: dark;
    }

    .field input::placeholder {
        color: #64748b;
    }

    .field input:-webkit-autofill,
    .field input:-webkit-autofill:hover,
    .field input:-webkit-autofill:focus {
        -webkit-text-fill-color: #ffffff;
        box-shadow: 0 0 0 1000px #081421 inset;
        caret-color: #ffffff;
        border-color: rgba(103, 232, 249, .35);
    }

    .field input:focus {
        border-color: rgba(103, 232, 249, .45);
        background: rgba(7, 17, 31, .78);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .save-btn {
        width: 100%;
        height: 56px;
        border: 0;
        border-radius: 16px;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        font-weight: 950;
        cursor: pointer;
        margin-top: 10px;
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .save-btn:hover {
        transform: translateY(-1px);
        filter: brightness(1.04);
    }

    @@media (max-width: 620px) {
        .set-password-card {
            border-radius: 24px;
            padding: 22px;
        }

        .user-mini-info {
            display: grid;
        }
    }
</style>
