@{
    Layout = "_Layout";
    ViewData["Title"] = "Yeni Şifre Oluştur";

    var name = ViewBag.Name as string ?? "Kullanıcı";
    var role = ViewBag.Role as string ?? "";
    var number = ViewBag.Number as string ?? "";
}

<div class="set-password-page">
    <div class="set-password-card">
        <div class="set-password-icon">🔐</div>

        <h1>Yeni Şifre Oluştur</h1>

        <p>
            @name hesabı için kalıcı şifrenizi oluşturun.
            Bundan sonra aktivasyon kodu yerine bu şifreyle giriş yapacaksınız.
        </p>

        <div class="user-mini-info">
            <strong>@role</strong>
            <span>No: @number</span>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Auth" asp-action="SetPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="field">
                <label>Yeni Şifre</label>
                <input type="password" name="password" placeholder="Yeni şifre" />
            </div>

            <div class="field">
                <label>Yeni Şifre Tekrar</label>
                <input type="password" name="repeatPassword" placeholder="Yeni şifre tekrar" />
            </div>

            <button type="submit" class="save-btn">
                Şifreyi Oluştur
            </button>
        </form>
    </div>
</div>

<style>
    .set-password-page {
        min-height: calc(100vh - 60px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background:
            radial-gradient(circle at top left, rgba(99,102,241,.25), transparent 35%),
            linear-gradient(135deg, #f8fafc, #eef2ff);
    }

    .set-password-card {
        width: 100%;
        max-width: 500px;
        background: #fff;
        border-radius: 32px;
        padding: 32px;
        box-shadow: 0 28px 70px rgba(15,23,42,.16);
    }

    .set-password-icon {
        width: 76px;
        height: 76px;
        border-radius: 24px;
        background: #eef2ff;
        color: #4f46e5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        margin: 0 auto 18px;
    }

    h1 {
        text-align: center;
        margin: 0;
        color: #111827;
        font-size: 30px;
        font-weight: 900;
    }

    p {
        text-align: center;
        color: #64748b;
        font-weight: 700;
        line-height: 1.5;
    }

    .user-mini-info {
        background: #f8fafc;
        border-radius: 18px;
        padding: 14px;
        margin: 18px 0;
        display: flex;
        justify-content: space-between;
        font-weight: 900;
        color: #111827;
    }

    .user-mini-info span {
        color: #64748b;
    }

    .alert {
        padding: 14px 16px;
        border-radius: 16px;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .field {
        margin-bottom: 14px;
    }

    .field label {
        display: block;
        margin-bottom: 8px;
        color: #111827;
        font-weight: 900;
    }

    .field input {
        width: 100%;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        border-radius: 18px;
        padding: 16px;
        font-weight: 700;
        outline: none;
    }

    .field input:focus {
        border-color: #4f46e5;
        background: #fff;
        box-shadow: 0 0 0 4px rgba(79,70,229,.12);
    }

    .save-btn {
        width: 100%;
        height: 56px;
        border: 0;
        border-radius: 18px;
        background: #4f46e5;
        color: #fff;
        font-weight: 900;
        cursor: pointer;
        margin-top: 10px;
    }
</style>