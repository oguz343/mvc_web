</style>

<div class="announcements-v2">
    <section class="announcements-v2-hero">
        <div class="announcements-v2-hero-main">
            <div class="announcements-v2-kicker">
                Duyuru Merkezi
            </div>

            <h2>Okul duyuruları artık daha görünür.</h2>

            <p>
                Öğrenci, öğretmen, veli veya tüm okula yayınladığınız duyuruları koyu panel içinde
                daha okunabilir ve daha düzenli şekilde yönetin.
            </p>

            <div class="announcements-v2-actions">
                <a asp-controller="Announcements"
                   asp-action="Create"
                   class="announcements-v2-primary-action">
                    📣 Yeni Duyuru
                </a>

                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="announcements-v2-soft-action">
                    📊 Kontrol Paneli
                </a>
            </div>
        </div>

        <div class="announcements-v2-hero-side">
            <div class="announcements-v2-summary-card">
                <strong>@totalCount</strong>
                <span>Toplam Duyuru</span>
            </div>

            <div class="announcements-v2-summary-card">
                <strong>@allSchoolCount</strong>
                <span>Tüm Okul</span>
            </div>

            <div class="announcements-v2-summary-card">
                <strong>@studentCount</strong>
                <span>Öğrenci Hedefli</span>
            </div>

            <div class="announcements-v2-summary-card">
                <strong>@teacherCount</strong>
                <span>Öğretmen Hedefli</span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="announcements-v2-alert success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="announcements-v2-alert error">
            @TempData["Error"]
        </div>
    }

    <section class="announcements-v2-toolbar">
        <div class="announcements-v2-search">
            <span>🔍</span>

            <input id="announcementSearchInput"
                   type="search"
                   placeholder="Duyuru başlığı, içerik, hedef veya yayınlayan ara..."
                   autocomplete="off" />
        </div>

        <div class="announcements-v2-visible-box">
            <strong id="visibleAnnouncementCount">@announcements.Count</strong>
            <span>duyuru gösteriliyor</span>
        </div>
    </section>

    @if (!announcements.Any())
    {
        <div class="announcements-v2-empty">
            <div>
                <div class="announcements-v2-empty-icon">📣</div>
                Henüz duyuru eklenmedi.
            </div>
        </div>
    }
    else
    {
        <section id="announcementsGrid" class="announcements-v2-grid">
            @foreach (var item in announcements)
            {
                var id = GetText(item, "Id");
                var title = FirstNonEmpty(GetText(item, "Title"), "Duyuru");
                var content = FirstNonEmpty(GetText(item, "Content"), GetText(item, "Message"), "-");
                var target = FirstNonEmpty(
                    GetText(item, "Target"),
                    GetText(item, "TargetRole"),
                    GetText(item, "Audience"),
                    GetText(item, "Role"),
                    "Tüm Okul"
                );
                var author = FirstNonEmpty(GetText(item, "Author"), GetText(item, "CreatedBy"), "Admin");
                var createdText = GetDateText(item, "CreatedAt", "CreatedDate", "Date", "PublishedAt");
                var targetClass = TargetClass(target);
                var targetIcon = TargetIcon(target);

                <article class="announcements-v2-card"
                         data-title="@title"
                         data-content="@content"
                         data-target="@target"
                         data-author="@author">

                    <div class="announcements-v2-top">
                        <div class="announcements-v2-icon">
                            📢
                        </div>

                        <div class="announcements-v2-title">
                            <h3>@title</h3>
                            <p>@createdText tarihinde yayınlandı</p>
                        </div>
                    </div>

                    <div class="announcements-v2-tags">
                        <span class="announcements-v2-tag @targetClass">
                            @targetIcon @target
                        </span>

                        <span class="announcements-v2-tag author">
                            ✍️ @author
                        </span>
                    </div>

                    <div class="announcements-v2-content-box">
                        <strong>Duyuru İçeriği</strong>
                        <p>@content</p>
                    </div>

                    <div class="announcements-v2-actions-row">
                        <a asp-controller="Announcements"
                           asp-action="Edit"
                           asp-route-id="@id"
                           class="announcements-v2-edit">
                            ✏️ Düzenle
                        </a>

                        <form asp-controller="Announcements"
                              asp-action="Delete"
                              method="post"
                              data-delete="true"
                              data-delete-name="@title">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@id" />

                            <button type="submit" class="announcements-v2-delete">
                                🗑️ Sil
                            </button>
                        </form>
                    </div>
                </article>
            }
        </section>

        <div id="noAnnouncementResult" class="announcements-v2-empty" style="display:none;">
            <div>
                <div class="announcements-v2-empty-icon">🔍</div>
                Aradığınız kritere uygun duyuru bulunamadı.
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const announcementSearchInput = document.getElementById("announcementSearchInput");
        const announcementCards = Array.from(document.querySelectorAll(".announcements-v2-card"));
        const visibleAnnouncementCount = document.getElementById("visibleAnnouncementCount");
        const noAnnouncementResult = document.getElementById("noAnnouncementResult");

        function normalizeAnnouncementText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterAnnouncements() {
            const query = normalizeAnnouncementText(announcementSearchInput?.value || "");
            let count = 0;

            announcementCards.forEach(card => {
                const title = normalizeAnnouncementText(card.dataset.title || "");
                const content = normalizeAnnouncementText(card.dataset.content || "");
                const target = normalizeAnnouncementText(card.dataset.target || "");
                const author = normalizeAnnouncementText(card.dataset.author || "");

                const searchable = `${title} ${content} ${target} ${author}`;
                const show = query === "" || searchable.includes(query);

                card.style.display = show ? "" : "none";

                if (show) {
                    count++;
                }
            });

            if (visibleAnnouncementCount) {
                visibleAnnouncementCount.textContent = count;
            }

            if (noAnnouncementResult) {
                noAnnouncementResult.style.display = count === 0 ? "grid" : "none";
            }
        }

        if (announcementSearchInput) {
            announcementSearchInput.addEventListener("input", function (event) {
                event.preventDefault();
                filterAnnouncements();
            });

            announcementSearchInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        filterAnnouncements();
    </script>
}
