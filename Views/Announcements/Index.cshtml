@using System.Reflection
@model List<mvc_web.Models.AnnouncementViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Duyurular";
    ViewData["PageTitle"] = "Duyurular";
    ViewData["PageSubtitle"] = "Öğrenci, öğretmen ve velilere yayınlanan duyuruları koyu tema ile daha düzenli şekilde yönetin.";

    var announcements = Model ?? new List<mvc_web.Models.AnnouncementViewModel>();

    var totalCount = announcements.Count;
    var allSchoolCount = announcements.Count(x => (x.Target ?? "").Contains("Tüm", StringComparison.OrdinalIgnoreCase));
    var studentCount = announcements.Count(x => (x.Target ?? "").Contains("Öğrenci", StringComparison.OrdinalIgnoreCase) || (x.Target ?? "").Contains("Ogrenci", StringComparison.OrdinalIgnoreCase));
    var teacherCount = announcements.Count(x => (x.Target ?? "").Contains("Öğretmen", StringComparison.OrdinalIgnoreCase) || (x.Target ?? "").Contains("Ogretmen", StringComparison.OrdinalIgnoreCase));

    string TargetClass(string target)
    {
        target = (target ?? "").Trim().ToLowerInvariant();

        if (target.Contains("öğretmen") || target.Contains("ogretmen") || target.Contains("teacher"))
        {
            return "teacher";
        }

        if (target.Contains("öğrenci") || target.Contains("ogrenci") || target.Contains("student"))
        {
            return "student";
        }

        if (target.Contains("veli") || target.Contains("parent"))
        {
            return "parent";
        }

        return "all";
    }

    string TargetIcon(string target)
    {
        target = (target ?? "").Trim().ToLowerInvariant();

        if (target.Contains("öğretmen") || target.Contains("ogretmen") || target.Contains("teacher"))
        {
            return "👨‍🏫";
        }

        if (target.Contains("öğrenci") || target.Contains("ogrenci") || target.Contains("student"))
        {
            return "🎒";
        }

        if (target.Contains("veli") || target.Contains("parent"))
        {
            return "👪";
        }

        return "🌐";
    }
}

@functions {
    private string GetText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(
                key,
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase
            );

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string GetDateText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "-";
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(
                key,
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase
            );

            if (prop == null)
            {
                continue;
            }

            var value = prop.GetValue(item);

            if (value == null)
            {
                continue;
            }

            if (value is DateTime date)
            {
                return date.ToString("dd.MM.yyyy HH:mm");
            }

            if (DateTime.TryParse(value.ToString(), out var parsed))
            {
                return parsed.ToString("dd.MM.yyyy HH:mm");
            }
        }

        return "-";
    }

    private string FirstNonEmpty(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }
}

