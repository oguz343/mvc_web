@model AnnouncementViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Duyuru Ekle";
}

<div class="form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form asp-controller="Announcements" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-grid">
            <div class="form-group full">
                <label class="form-label" asp-for="Title">Başlık</label>
                <input class="form-control" asp-for="Title" placeholder="Duyuru başlığı" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Author">Yayınlayan</label>
                <input class="form-control" asp-for="Author" placeholder="Admin" />
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Target">Hedef Kitle</label>
                <select class="form-control" asp-for="Target">
                    <option value="Tüm Okul">Tüm Okul</option>
                    <option value="Öğrenciler">Öğrenciler</option>
                    <option value="Öğretmenler">Öğretmenler</option>
                    <option value="Veliler">Veliler</option>
                </select>
                <span asp-validation-for="Target" class="text-danger"></span>
            </div>

            <div class="form-group full">
                <label class="form-label" asp-for="Content">Duyuru İçeriği</label>
                <textarea class="form-control" asp-for="Content" placeholder="Duyuru metnini yaz"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
        </div>

        <div style="height: 22px;"></div>

        <div class="page-actions">
            <button class="btn btn-primary" type="submit">
                📢 Duyuruyu Yayınla
            </button>

            <a class="btn btn-light" asp-controller="Announcements" asp-action="Index">
                ← Geri Dön
            </a>
        </div>
    </form>
</div>