@model mvc_web.Models.AdminPasswordViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Şifresi";
    ViewData["PageTitle"] = "Admin Şifresi";
    ViewData["PageSubtitle"] = "Admin hesabınızın şifresini güvenli şekilde güncelleyin.";
}

<style>
    .security-v2 {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .security-v2-hero,
    .security-v2-card,
    .security-v2-side {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .security-v2-hero {
        padding: 24px;
        border-radius: 32px;
    }

    .security-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .security-v2-hero h1 {
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .security-v2-hero p {
        max-width: 820px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .security-v2-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        align-items: start;
    }

    .security-v2-card,
    .security-v2-side {
        padding: 22px;
        border-radius: 30px;
    }

    .security-v2-form {
        display: grid;
        gap: 14px;
    }

    .security-v2-field {
        display: grid;
        gap: 8px;
    }

    .security-v2-field label {
        color: #dbeafe;
        font-size: 13px;
        font-weight: 950;
    }

    .security-v2-field input {
        width: 100%;
        min-height: 48px;
        padding: 0 13px;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .18);
        outline: none;
        color: #ffffff;
        background: rgba(7, 17, 31, .58);
        font-size: 14px;
        font-weight: 750;
    }

    .security-v2-field input:focus {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .security-v2-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 4px;
    }

    .security-v2-save,
    .security-v2-back {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 950;
    }

    .security-v2-save {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-color: rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .security-v2-back {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border-color: rgba(148, 163, 184, .18);
    }

    .security-v2-side h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .security-v2-side p {
        margin: 8px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.55;
    }

    .security-v2-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .security-v2-note {
        padding: 12px;
        border-radius: 16px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
    }

    @@media (max-width: 1100px) {
        .security-v2-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .security-v2-hero,
        .security-v2-card,
        .security-v2-side {
            border-radius: 22px;
            padding: 16px;
        }

        .security-v2-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .security-v2-save,
        .security-v2-back {
            width: 100%;
        }
    }
</style>

<div class="security-v2">
    <section class="security-v2-hero">
        <div class="security-v2-kicker">Güvenlik</div>

        <h1>Admin şifresini güncelleyin.</h1>

        <p>
            Hesabınızı güvende tutmak için güçlü ve tahmin edilmesi zor bir şifre kullanın.
        </p>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <section class="security-v2-layout">
        <form asp-controller="AdminAccount"
              asp-action="ChangePassword"
              method="post"
              class="security-v2-card">

            @Html.AntiForgeryToken()

            <div class="security-v2-form">
                <div class="security-v2-field">
                    <label>Mevcut Şifre</label>
                    <input asp-for="CurrentPassword"
                           type="password"
                           autocomplete="current-password"
                           required />
                </div>

                <div class="security-v2-field">
                    <label>Yeni Şifre</label>
                    <input asp-for="NewPassword"
                           type="password"
                           autocomplete="new-password"
                           minlength="8"
                           required />
                </div>

                <div class="security-v2-field">
                    <label>Yeni Şifre Tekrar</label>
                    <input asp-for="RepeatPassword"
                           type="password"
                           autocomplete="new-password"
                           minlength="8"
                           required />
                </div>
            </div>

            <div class="security-v2-actions">
                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="security-v2-back">
                    Vazgeç
                </a>

                <button type="submit" class="security-v2-save">
                    🛡️ Şifreyi Güncelle
                </button>
            </div>
        </form>

        <aside class="security-v2-side">
            <h3>Güvenlik Önerileri</h3>

            <p>
                Admin hesabı tüm sisteme eriştiği için şifre güçlü olmalıdır.
            </p>

            <div class="security-v2-list">
                <div class="security-v2-note">🔐 En az 8 karakter kullanın.</div>
                <div class="security-v2-note">🔢 Harf ve rakam karışımı daha güvenlidir.</div>
                <div class="security-v2-note">🚫 Öğrenci numarası gibi kolay tahmin edilen şeyleri kullanmayın.</div>
            </div>
        </aside>
    </section>
</div>
