@model mvc_web.Models.AdminPasswordViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Şifresi";
}

<div class="admin-password-page">
    <div class="security-card">
        <div class="security-hero">
            <div class="security-icon">🔐</div>

            <div>
                <h1>Admin Şifresi</h1>
                <p>Panel güvenliği için admin şifrenizi düzenli olarak güncelleyin.</p>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="AdminAccount" asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="field">
                <label>Mevcut Şifre</label>
                <input asp-for="CurrentPassword" type="password" placeholder="Mevcut admin şifresi" />
            </div>

            <div class="field">
                <label>Yeni Şifre</label>
                <input asp-for="NewPassword" type="password" placeholder="Yeni şifre" />
            </div>

            <div class="field">
                <label>Yeni Şifre Tekrar</label>
                <input asp-for="RepeatPassword" type="password" placeholder="Yeni şifre tekrar" />
            </div>

            <button type="submit" class="save-password-btn">
                Şifreyi Güncelle
            </button>
        </form>

        <div class="info-box">
            <strong>Not:</strong>
            Admin şifresi değiştirildikten sonra eski şifreyle giriş yapılamaz.
        </div>
    </div>
</div>

<style>
    .admin-password-page {
        max-width: 760px;
    }

    .security-card {
        background: #fff;
        border-radius: 32px;
        padding: 30px;
        box-shadow: 0 20px 55px rgba(15, 23, 42, .08);
    }

    .security-hero {
        display: flex;
        align-items: center;
        gap: 18px;
        margin-bottom: 24px;
    }

    .security-icon {
        width: 74px;
        height: 74px;
        border-radius: 24px;
        background: linear-gradient(135deg, #4f46e5, #06b6d4);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
        box-shadow: 0 18px 36px rgba(79, 70, 229, .22);
    }

    .security-hero h1 {
        margin: 0;
        color: #0f172a;
        font-size: 32px;
        font-weight: 950;
    }

    .security-hero p {
        margin: 6px 0 0;
        color: #64748b;
        font-weight: 800;
    }

    .alert {
        border-radius: 18px;
        padding: 14px 16px;
        margin-bottom: 18px;
        font-weight: 850;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .field {
        margin-bottom: 16px;
    }

    .field label {
        display: block;
        color: #0f172a;
        font-weight: 950;
        margin-bottom: 8px;
    }

    .field input {
        width: 100%;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        border-radius: 20px;
        min-height: 58px;
        padding: 0 16px;
        outline: none;
        color: #111827;
        font-weight: 850;
    }

    .field input:focus {
        background: #fff;
        border-color: #4f46e5;
        box-shadow: 0 0 0 5px rgba(79, 70, 229, .11);
    }

    .save-password-btn {
        width: 100%;
        min-height: 58px;
        border: 0;
        border-radius: 20px;
        background: linear-gradient(135deg, #4f46e5, #06b6d4);
        color: #fff;
        font-weight: 950;
        cursor: pointer;
        box-shadow: 0 18px 36px rgba(79,70,229,.22);
    }

    .info-box {
        margin-top: 18px;
        background: #eef2ff;
        color: #3730a3;
        border-radius: 18px;
        padding: 14px 16px;
        font-weight: 800;
    }

    @@media (max-width: 640px) {
        .security-hero {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>