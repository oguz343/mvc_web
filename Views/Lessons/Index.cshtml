@model List<mvc_web.Models.LessonViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dersler";

    var lessons = Model ?? new List<mvc_web.Models.LessonViewModel>();
}

<div class="page-shell">
    <section class="page-header-card">
        <div>
            <div class="eyebrow">Yönetim Paneli</div>
            <h1>Dersler</h1>
            <p>Dersleri sınıf ve öğretmenlerle eşleştirerek düzenli bir yapı kurun.</p>
        </div>

        <div class="page-actions">
            <a asp-controller="Lessons" asp-action="Create" class="btn-primary">
                📚 Yeni Ders
            </a>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!lessons.Any())
    {
        <div class="empty-state">
            Henüz ders eklenmedi.
        </div>
    }
    else
    {
        <section class="entity-grid">
            @foreach (var item in lessons)
            {
                var lessonName = string.IsNullOrWhiteSpace(item.Name) ? "-" : item.Name;
                var className = string.IsNullOrWhiteSpace(item.ClassName) ? "-" : item.ClassName;
                var teacherName = string.IsNullOrWhiteSpace(item.TeacherName) ? "Atanmadı" : item.TeacherName;
                var teacherBranch = string.IsNullOrWhiteSpace(item.TeacherBranch) ? "-" : item.TeacherBranch;

                <article class="entity-card">
                    <div class="entity-head">
                        <div class="entity-icon info">📘</div>

                        <div class="entity-title">
                            <h3>@lessonName</h3>
                            <p>@className sınıfı için tanımlı ders</p>
                        </div>
                    </div>

                    <div class="badge-row">
                        <span class="badge-pill badge-info">@className</span>
                        <span class="badge-pill badge-primary">@lessonName</span>
                    </div>

                    <div class="meta-list">
                        <div class="meta-item">
                            <span>👨‍🏫</span>
                            <span>Öğretmen: @teacherName</span>
                        </div>

                        <div class="meta-item">
                            <span>🧠</span>
                            <span>Branş: @teacherBranch</span>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a asp-controller="Lessons" asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary">
                            ✏️ Düzenle
                        </a>

                        <form asp-controller="Lessons"
                              asp-action="Delete"
                              method="post"
                              class="inline-form js-delete-form"
                              data-delete-name="@lessonName">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-danger">🗑️ Sil</button>
                        </form>
                    </div>
                </article>
            }
        </section>
    }
</div>