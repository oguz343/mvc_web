@model List<LessonViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Dersler";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="page-actions">
    <a class="btn btn-primary" asp-controller="Lessons" asp-action="Create">
        📚 Yeni Ders
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📚</div>
        <div class="empty-title">Henüz ders yok</div>
        <div class="empty-text">Yeni ders oluşturarak başlayabilirsiniz.</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var item in Model)
        {
            <div class="data-card">
                <div class="data-card-header">
                    <div class="data-card-icon">📚</div>
                    <div>
                        <div class="data-card-title">@item.Name</div>
                        <div class="data-card-subtitle">@item.ClassName sınıfı</div>
                    </div>
                </div>

                <div class="badge-row">
                    <span class="badge badge-purple">@item.Name</span>
                    <span class="badge badge-green">@item.ClassName</span>
                </div>

                <div class="info-line">
                    <span>👨‍🏫</span>
                    <span>Öğretmen: <strong>@item.TeacherName</strong></span>
                </div>

                <div class="info-line">
                    <span>💼</span>
                    <span>Branş: @item.TeacherBranch</span>
                </div>

                <div class="card-actions">
                    <a class="btn btn-light" asp-controller="Lessons" asp-action="Edit" asp-route-id="@item.Id">
                        ✏️ Düzenle
                    </a>

                    <form asp-controller="Lessons" asp-action="Delete" method="post" onsubmit="return confirmDelete('Ders silinsin mi?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-danger" type="submit">
                            🗑️ Sil
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}