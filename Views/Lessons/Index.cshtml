@model List<mvc_web.Models.LessonViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ders Atamaları";
    ViewData["PageTitle"] = "Ders Atamaları";
    ViewData["PageSubtitle"] = "Dersleri aktif sınıflar ve aktif öğretmenlerle eşleştirerek okulun akademik yapısını düzenleyin.";

    var lessons = Model ?? new List<mvc_web.Models.LessonViewModel>();

    var teacherCount = lessons
        .Select(x => (x.TeacherName ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    var classCount = lessons
        .Select(x => (x.ClassName ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    var branchCount = lessons
        .Select(x => (x.TeacherBranch ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .Count();

    string SafeText(string value, string fallback = "-")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    string LessonIcon(string name)
    {
        var value = (name ?? "").Trim().ToLowerInvariant();

        if (value.Contains("mat"))
        {
            return "➗";
        }

        if (value.Contains("türk") || value.Contains("turk") || value.Contains("edeb"))
        {
            return "📖";
        }

        if (value.Contains("fen") || value.Contains("fiz") || value.Contains("kim") || value.Contains("biy"))
        {
            return "🧪";
        }

        if (value.Contains("tarih") || value.Contains("sos"))
        {
            return "🏛️";
        }

        if (value.Contains("ing") || value.Contains("dil"))
        {
            return "🌍";
        }

        if (value.Contains("din"))
        {
            return "🕌";
        }

        if (value.Contains("res") || value.Contains("görsel"))
        {
            return "🎨";
        }

        if (value.Contains("müz") || value.Contains("muz"))
        {
            return "🎵";
        }

        if (value.Contains("beden") || value.Contains("spor"))
        {
            return "⚽";
        }

        return "📘";
    }
}

<style>
    .lessons-v2 {
        width: 100%;
        max-width: none;
        display: grid;
        gap: 18px;
    }

    .lessons-v2-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .15), transparent 34%),
            radial-gradient(circle at 100% 0%, rgba(139, 92, 246, .18), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .94), rgba(17, 24, 39, .86));
        border: 1px solid rgba(148, 163, 184, .20);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .28);
        backdrop-filter: blur(18px);
    }

    .lessons-v2-hero::after {
        content: "";
        position: absolute;
        width: 390px;
        height: 390px;
        right: -180px;
        top: -190px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .22);
        pointer-events: none;
    }

    .lessons-v2-hero-main,
    .lessons-v2-hero-side {
        position: relative;
        z-index: 1;
    }

    .lessons-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .lessons-v2-hero h2 {
        max-width: 780px;
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .lessons-v2-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .lessons-v2-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .lessons-v2-primary-action,
    .lessons-v2-soft-action {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 15px;
        border-radius: 15px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        transition: .16s ease;
    }

    .lessons-v2-primary-action {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: 1px solid rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .lessons-v2-soft-action {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border: 1px solid rgba(148, 163, 184, .18);
    }

    .lessons-v2-primary-action:hover,
    .lessons-v2-soft-action:hover {
        transform: translateY(-1px);
    }

    .lessons-v2-hero-side {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .lessons-v2-summary-card {
        min-height: 106px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .lessons-v2-summary-card strong {
        display: block;
        color: #ffffff;
        font-size: 30px;
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.04em;
    }

    .lessons-v2-summary-card span {
        display: block;
        margin-top: 7px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .lessons-v2-alert {
        padding: 15px 17px;
        border-radius: 18px;
        font-weight: 850;
        line-height: 1.5;
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .lessons-v2-alert.success {
        color: #bbf7d0;
        background: rgba(34, 197, 94, .12);
        border-color: rgba(74, 222, 128, .20);
    }

    .lessons-v2-alert.error {
        color: #fecaca;
        background: rgba(239, 68, 68, .12);
        border-color: rgba(248, 113, 113, .20);
    }

    .lessons-v2-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px;
        padding: 16px;
        border-radius: 28px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .08), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .84));
        border: 1px solid rgba(148, 163, 184, .18);
        box-shadow: 0 16px 44px rgba(0, 0, 0, .20);
        backdrop-filter: blur(16px);
    }

    .lessons-v2-search {
        min-height: 54px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 15px;
        border-radius: 18px;
        background: rgba(7, 17, 31, .58);
        border: 1px solid rgba(148, 163, 184, .18);
        transition: .15s ease;
    }

    .lessons-v2-search:focus-within {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .lessons-v2-search span {
        font-size: 20px;
    }

    .lessons-v2-search input {
        width: 100%;
        border: 0;
        outline: 0;
        color: #ffffff;
        background: transparent;
        font-size: 14px;
        font-weight: 800;
    }

    .lessons-v2-search input::placeholder {
        color: #64748b;
    }

    .lessons-v2-visible-box {
        min-width: 170px;
        min-height: 54px;
        display: grid;
        align-content: center;
        padding: 0 15px;
        border-radius: 18px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .lessons-v2-visible-box strong {
        color: #ffffff;
        font-size: 24px;
        font-weight: 950;
        line-height: 1;
    }

    .lessons-v2-visible-box span {
        margin-top: 4px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .lessons-v2-empty {
        min-height: 320px;
        display: grid;
        place-items: center;
        padding: 42px 24px;
        border-radius: 30px;
        color: #94a3b8;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .08), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .84));
        border: 1px dashed rgba(148, 163, 184, .20);
        box-shadow: 0 18px 46px rgba(0, 0, 0, .22);
        text-align: center;
        font-size: 15px;
        font-weight: 850;
    }

    .lessons-v2-empty-icon {
        width: 76px;
        height: 76px;
        display: grid;
        place-items: center;
        margin: 0 auto 15px;
        border-radius: 26px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 34px;
    }

    .lessons-v2-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(370px, 1fr));
        gap: 16px;
    }

    .lessons-v2-card {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-height: 100%;
        padding: 20px;
        border-radius: 28px;
        background:
            radial-gradient(circle at 100% 0%, rgba(56, 189, 248, .075), transparent 36%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        border: 1px solid rgba(148, 163, 184, .18);
        box-shadow: 0 16px 44px rgba(0, 0, 0, .22);
        backdrop-filter: blur(16px);
        transition: .16s ease;
    }

    .lessons-v2-card:hover {
        transform: translateY(-2px);
        border-color: rgba(125, 211, 252, .28);
        box-shadow: 0 22px 54px rgba(0, 0, 0, .27);
    }

    .lessons-v2-card::after {
        content: "";
        position: absolute;
        width: 180px;
        height: 180px;
        right: -92px;
        top: -104px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .13);
        pointer-events: none;
    }

    .lessons-v2-top {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr);
        gap: 14px;
        align-items: center;
    }

    .lessons-v2-icon {
        width: 64px;
        height: 64px;
        display: grid;
        place-items: center;
        border-radius: 22px;
        color: #ffffff;
        background:
            radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .28), transparent 28%),
            linear-gradient(135deg, #2563eb, #7c3aed 58%, #06b6d4);
        box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
        font-size: 30px;
    }

    .lessons-v2-title {
        min-width: 0;
    }

    .lessons-v2-title h3 {
        margin: 0;
        color: #ffffff;
        font-size: 23px;
        font-weight: 950;
        line-height: 1.15;
        letter-spacing: -.035em;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .lessons-v2-title p {
        margin: 6px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .lessons-v2-tags {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .lessons-v2-tag {
        min-height: 31px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 950;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .lessons-v2-tag.lesson {
        color: #bfdbfe;
        background: rgba(37, 99, 235, .14);
        border-color: rgba(96, 165, 250, .20);
    }

    .lessons-v2-tag.class {
        color: #a5f3fc;
        background: rgba(6, 182, 212, .13);
        border-color: rgba(103, 232, 249, .18);
    }

    .lessons-v2-tag.teacher {
        color: #bbf7d0;
        background: rgba(34, 197, 94, .13);
        border-color: rgba(74, 222, 128, .20);
    }

    .lessons-v2-tag.branch {
        color: #fde68a;
        background: rgba(245, 158, 11, .13);
        border-color: rgba(251, 191, 36, .18);
    }

    .lessons-v2-details {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 9px;
    }

    .lessons-v2-detail-row {
        display: grid;
        grid-template-columns: 28px minmax(110px, .68fr) minmax(0, 1fr);
        gap: 9px;
        align-items: center;
        padding: 10px 11px;
        border-radius: 16px;
        color: #94a3b8;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 750;
    }

    .lessons-v2-detail-row strong {
        color: #dbeafe;
        font-weight: 950;
    }

    .lessons-v2-detail-row b {
        min-width: 0;
        color: #ffffff;
        font-weight: 900;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .lessons-v2-footer-note {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 7px;
        padding: 13px;
        border-radius: 18px;
        color: #dbeafe;
        background:
            radial-gradient(circle at 100% 0%, rgba(56, 189, 248, .11), transparent 34%),
            rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .13);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.5;
    }

    .lessons-v2-footer-note span {
        color: #94a3b8;
        font-size: 12px;
        font-weight: 750;
    }

    .lessons-v2-actions-row {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: auto;
    }

    .lessons-v2-edit,
    .lessons-v2-delete {
        min-height: 45px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 13px;
        font-weight: 950;
        transition: .15s ease;
    }

    .lessons-v2-edit {
        color: #ffffff;
        background: rgba(56, 189, 248, .11);
        border-color: rgba(125, 211, 252, .22);
    }

    .lessons-v2-delete {
        width: 100%;
        color: #ffffff;
        background: rgba(239, 68, 68, .82);
        border-color: rgba(248, 113, 113, .24);
    }

    .lessons-v2-edit:hover,
    .lessons-v2-delete:hover {
        transform: translateY(-1px);
    }

    @@media (max-width: 1200px) {
        .lessons-v2-hero,
        .lessons-v2-toolbar {
            grid-template-columns: 1fr;
        }

        .lessons-v2-visible-box {
            min-width: 0;
        }
    }

    @@media (max-width: 760px) {
        .lessons-v2-hero {
            border-radius: 22px;
            padding: 16px;
        }

        .lessons-v2-hero-side {
            grid-template-columns: 1fr;
        }

        .lessons-v2-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .lessons-v2-primary-action,
        .lessons-v2-soft-action {
            width: 100%;
        }

        .lessons-v2-grid {
            grid-template-columns: 1fr;
        }

        .lessons-v2-card {
            border-radius: 22px;
            padding: 16px;
        }

        .lessons-v2-top {
            grid-template-columns: 56px minmax(0, 1fr);
        }

        .lessons-v2-icon {
            width: 56px;
            height: 56px;
            font-size: 26px;
        }

        .lessons-v2-detail-row {
            grid-template-columns: 24px minmax(0, 1fr);
        }

        .lessons-v2-detail-row b {
            grid-column: 1 / -1;
            text-align: left;
        }

        .lessons-v2-actions-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="lessons-v2">
    <section class="lessons-v2-hero">
        <div class="lessons-v2-hero-main">
            <div class="lessons-v2-kicker">
                Ders Merkezi
            </div>

            <h2>Ders atamaları artık daha düzenli.</h2>

            <p>
                Hangi dersin hangi sınıfta, hangi öğretmen tarafından yürütüldüğünü tek ekranda
                koyu tema ile daha okunabilir ve daha profesyonel şekilde takip edin.
            </p>

            <div class="lessons-v2-actions">
                <a asp-controller="Lessons"
                   asp-action="Create"
                   class="lessons-v2-primary-action">
                    📚 Yeni Ders Ataması
                </a>

                <a asp-controller="Classes"
                   asp-action="Index"
                   class="lessons-v2-soft-action">
                    🏫 Sınıflar
                </a>

                <a asp-controller="Users"
                   asp-action="Index"
                   class="lessons-v2-soft-action">
                    👨‍🏫 Öğretmenler
                </a>
            </div>
        </div>

        <div class="lessons-v2-hero-side">
            <div class="lessons-v2-summary-card">
                <strong>@lessons.Count</strong>
                <span>Toplam Atama</span>
            </div>

            <div class="lessons-v2-summary-card">
                <strong>@teacherCount</strong>
                <span>Öğretmen</span>
            </div>

            <div class="lessons-v2-summary-card">
                <strong>@classCount</strong>
                <span>Sınıf</span>
            </div>

            <div class="lessons-v2-summary-card">
                <strong>@branchCount</strong>
                <span>Branş</span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="lessons-v2-alert success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="lessons-v2-alert error">
            @TempData["Error"]
        </div>
    }

    <section class="lessons-v2-toolbar">
        <div class="lessons-v2-search">
            <span>🔍</span>

            <input id="lessonSearchInput"
                   type="search"
                   placeholder="Ders, sınıf, öğretmen veya branş ara... Örn: Matematik, 9-A, Ahmet"
                   autocomplete="off" />
        </div>

        <div class="lessons-v2-visible-box">
            <strong id="visibleLessonCount">@lessons.Count</strong>
            <span>ders ataması gösteriliyor</span>
        </div>
    </section>

    @if (!lessons.Any())
    {
        <div class="lessons-v2-empty">
            <div>
                <div class="lessons-v2-empty-icon">📚</div>
                Aktif ders ataması bulunmuyor. Ders eklemek için önce aktif öğretmen ve aktif sınıf tanımlanmış olmalıdır.
            </div>
        </div>
    }
    else
    {
        <section id="lessonsGrid" class="lessons-v2-grid">
            @foreach (var item in lessons)
            {
                var lessonName = SafeText(item.Name);
                var className = SafeText(item.ClassName);
                var teacherName = SafeText(item.TeacherName, "Atanmadı");
                var teacherBranch = SafeText(item.TeacherBranch);
                var icon = LessonIcon(lessonName);

                <article class="lessons-v2-card"
                         data-lesson="@lessonName"
                         data-class="@className"
                         data-teacher="@teacherName"
                         data-branch="@teacherBranch">

                    <div class="lessons-v2-top">
                        <div class="lessons-v2-icon">
                            @icon
                        </div>

                        <div class="lessons-v2-title">
                            <h3>@lessonName</h3>
                            <p>@className sınıfı için tanımlı ders</p>
                        </div>
                    </div>

                    <div class="lessons-v2-tags">
                        <span class="lessons-v2-tag lesson">
                            📘 @lessonName
                        </span>

                        <span class="lessons-v2-tag class">
                            🏫 @className
                        </span>

                        <span class="lessons-v2-tag teacher">
                            👨‍🏫 @teacherName
                        </span>

                        <span class="lessons-v2-tag branch">
                            📚 @teacherBranch
                        </span>
                    </div>

                    <div class="lessons-v2-details">
                        <div class="lessons-v2-detail-row">
                            <span>📘</span>
                            <strong>Ders</strong>
                            <b>@lessonName</b>
                        </div>

                        <div class="lessons-v2-detail-row">
                            <span>🏫</span>
                            <strong>Sınıf</strong>
                            <b>@className</b>
                        </div>

                        <div class="lessons-v2-detail-row">
                            <span>👨‍🏫</span>
                            <strong>Öğretmen</strong>
                            <b>@teacherName</b>
                        </div>

                        <div class="lessons-v2-detail-row">
                            <span>📚</span>
                            <strong>Branş</strong>
                            <b>@teacherBranch</b>
                        </div>
                    </div>

                    <div class="lessons-v2-footer-note">
                        Bu atamaya bağlı aktif ödevler öğretmen panelinde kullanılabilir.
                        <span>Silme işleminde bu ders bağlantılı aktif ödevler de pasife alınır.</span>
                    </div>

                    <div class="lessons-v2-actions-row">
                        <a asp-controller="Lessons"
                           asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="lessons-v2-edit">
                            ✏️ Düzenle
                        </a>

                        <form asp-controller="Lessons"
                              asp-action="Delete"
                              method="post"
                              data-delete="true"
                              data-delete-name="@lessonName">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@item.Id" />

                            <button type="submit" class="lessons-v2-delete">
                                🗑️ Sil
                            </button>
                        </form>
                    </div>
                </article>
            }
        </section>

        <div id="noLessonResult" class="lessons-v2-empty" style="display:none;">
            <div>
                <div class="lessons-v2-empty-icon">🔍</div>
                Aradığınız kritere uygun ders ataması bulunamadı.
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const lessonSearchInput = document.getElementById("lessonSearchInput");
        const lessonCards = Array.from(document.querySelectorAll(".lessons-v2-card"));
        const visibleLessonCount = document.getElementById("visibleLessonCount");
        const noLessonResult = document.getElementById("noLessonResult");

        function normalizeLessonText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterLessons() {
            const query = normalizeLessonText(lessonSearchInput?.value || "");
            let count = 0;

            lessonCards.forEach(card => {
                const lesson = normalizeLessonText(card.dataset.lesson || "");
                const className = normalizeLessonText(card.dataset.class || "");
                const teacher = normalizeLessonText(card.dataset.teacher || "");
                const branch = normalizeLessonText(card.dataset.branch || "");

                const searchable = `${lesson} ${className} ${teacher} ${branch}`;
                const show = query === "" || searchable.includes(query);

                card.style.display = show ? "" : "none";

                if (show) {
                    count++;
                }
            });

            if (visibleLessonCount) {
                visibleLessonCount.textContent = count;
            }

            if (noLessonResult) {
                noLessonResult.style.display = count === 0 ? "grid" : "none";
            }
        }

        if (lessonSearchInput) {
            lessonSearchInput.addEventListener("input", function (event) {
                event.preventDefault();
                filterLessons();
            });

            lessonSearchInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        filterLessons();
    </script>
}