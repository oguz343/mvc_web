@model mvc_web.Controllers.LessonEditPageModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Ders Ataması Düzenle";

    var classes = Model.Classes ?? new List<mvc_web.Services.ClassOption>();
    var teachers = Model.Teachers ?? new List<mvc_web.Services.TeacherOption>();

    var defaultLessons = new List<string>
    {
        "Matematik",
        "Fizik",
        "Kimya",
        "Biyoloji",
        "Edebiyat",
        "Tarih",
        "Coğrafya",
        "İngilizce",
        "Din Kültürü",
        "Beden Eğitimi"
    };

    var isCustomLesson = !defaultLessons.Contains(Model.Name);
}

<div class="form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    @if (classes.Count == 0)
    {
        <div class="alert alert-warning">
            Ders düzenlemek için önce <strong>Sınıflar</strong> ekranından sınıf oluşturmalısınız.
        </div>
    }

    @if (teachers.Count == 0)
    {
        <div class="alert alert-warning">
            Ders düzenlemek için önce <strong>Kullanıcılar</strong> ekranından öğretmen oluşturmalısınız.
        </div>
    }

    <form asp-controller="Lessons" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-grid">
            <div class="form-group">
                <label class="form-label" for="lessonSelect">Ders Adı</label>
                <select class="form-control" id="lessonSelect" name="@(isCustomLesson ? "" : "name")">
                    @foreach (var lessonName in defaultLessons)
                    {
                        <option value="@lessonName" selected="@(Model.Name == lessonName)">
                            @lessonName
                        </option>
                    }
                    <option value="Diğer" selected="@isCustomLesson">Diğer</option>
                </select>
            </div>

            <div class="form-group" id="customLessonGroup" style="display:none;">
                <label class="form-label" for="customLessonInput">Özel Ders Adı</label>
                <input class="form-control"
                       id="customLessonInput"
                       value="@(isCustomLesson ? Model.Name : "")"
                       placeholder="Ders adını yaz" />
            </div>

            <div class="form-group full">
                <label class="form-label" for="className">Sınıf</label>
                <select class="form-control" id="className" name="className">
                    <option value="">Sınıf seç</option>
                    @foreach (var classItem in classes)
                    {
                        <option value="@classItem.Name" selected="@(Model.ClassName == classItem.Name)">
                            @classItem.Name
                        </option>
                    }
                </select>
            </div>

            <div class="form-group full">
                <label class="form-label" for="teacherNo">Öğretmen</label>
                <select class="form-control" id="teacherNo" name="teacherNo">
                    <option value="">Öğretmen seç</option>
                    @foreach (var teacher in teachers)
                    {
                        <option value="@teacher.Number" selected="@(Model.TeacherNo == teacher.Number)">
                            @teacher.Name - @teacher.Branch - No: @teacher.Number
                        </option>
                    }
                </select>
            </div>
        </div>

        <div style="height: 22px;"></div>

        <div class="alert alert-warning">
            Güncel öğretmen no: <strong>@Model.TeacherNo</strong>
        </div>

        <div class="page-actions">
            <button class="btn btn-primary" type="submit" @(classes.Count == 0 || teachers.Count == 0 ? "disabled" : "")>
                Değişiklikleri Kaydet
            </button>

            <a class="btn btn-light" asp-controller="Lessons" asp-action="Index">
                Geri Dön
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const lessonSelect = document.getElementById("lessonSelect");
        const customGroup = document.getElementById("customLessonGroup");
        const customInput = document.getElementById("customLessonInput");

        function updateLessonInput() {
            if (lessonSelect.value === "Diğer") {
                customGroup.style.display = "flex";
                customInput.setAttribute("name", "name");
                lessonSelect.removeAttribute("name");
            } else {
                customGroup.style.display = "none";
                customInput.removeAttribute("name");
                lessonSelect.setAttribute("name", "name");
            }
        }

        lessonSelect.addEventListener("change", updateLessonInput);
        updateLessonInput();
    </script>
}
