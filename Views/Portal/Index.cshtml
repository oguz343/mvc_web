 @model mvc_web.Models.PortalViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Kullanıcı Paneli";

    var isStudent = Model.Role == "Öğrenci";
    var icon = Model.Role == "Veli" ? "👪" : "🎒";
    var color = Model.Role == "Veli" ? "#f59e0b" : "#4f46e5";
}

<div class="portal-page">
    <div class="portal-shell">
        <div class="portal-header">
            <div class="portal-avatar" style="background:@color">
                @icon
            </div>

            <div>
                <h1>Hoş geldin, @Model.Name</h1>
                <p>@Model.Role • No: @Model.Number</p>

                @if (!string.IsNullOrWhiteSpace(Model.ClassName))
                {
                    <p>Sınıf: @Model.ClassName</p>
                }

                @if (Model.Role == "Veli" && !string.IsNullOrWhiteSpace(Model.LinkedStudentNo))
                {
                    <p>Bağlı öğrenci no: @Model.LinkedStudentNo</p>
                }
            </div>

            <a asp-controller="Auth" asp-action="Logout" class="logout-btn">
                Çıkış Yap
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger">
                @TempData["Error"]
            </div>
        }

        <div class="stats-grid">
            <div class="stat-card">
                <span>Rol</span>
                <strong>@Model.Role</strong>
            </div>

            <div class="stat-card">
                <span>Duyuru</span>
                <strong>@Model.Announcements.Count</strong>
            </div>

            <div class="stat-card">
                <span>Ödev</span>
                <strong>@Model.Homeworks.Count</strong>
            </div>
        </div>

        <div class="section-title">Duyurular</div>

        @if (!Model.Announcements.Any())
        {
            <div class="empty-box">Henüz görüntülenecek duyuru yok.</div>
        }
        else
        {
            <div class="announcement-list">
                @foreach (var item in Model.Announcements)
                {
                    <div class="announcement-card">
                        <div class="announcement-top">
                            <div class="announcement-icon">📢</div>

                            <div>
                                <h3>@item.Title</h3>
                                <span>@item.Author • @item.Target • @(item.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</span>
                            </div>
                        </div>

                        <p>@item.Content</p>
                    </div>
                }
            </div>
        }

        <div class="section-title homework-title">Ödevler</div>

        @if (!Model.Homeworks.Any())
        {
            <div class="empty-box">Henüz görüntülenecek ödev yok.</div>
        }
        else
        {
            <div class="homework-list">
                @foreach (var homework in Model.Homeworks)
                {
                    <div class="homework-card">
                        <div class="homework-top">
                            <div>
                                <h3>@homework.Title</h3>

                                <span>
                                    @homework.TeacherName • @homework.ClassName
                                    @if (homework.DueDate != null)
                                    {
                                        <text> • Son tarih: @homework.DueDate?.ToString("dd.MM.yyyy HH:mm")</text>
                                    }
                                </span>
                            </div>

                            @if (homework.IsSubmitted)
                            {
                                <span class="submitted-badge">Teslim Edildi</span>
                            }
                            else
                            {
                                <span class="pending-badge">Bekliyor</span>
                            }
                        </div>

                        <p>@homework.Description</p>

                        @if (homework.IsSubmitted)
                        {
                            <div class="submission-box">
                                <strong>Teslim bilgisi:</strong>

                                @if (!string.IsNullOrWhiteSpace(homework.SubmissionText))
                                {
                                    <div>@homework.SubmissionText</div>
                                }

                                @if (!string.IsNullOrWhiteSpace(homework.SubmissionFileUrl))
                                {
                                    <a href="@homework.SubmissionFileUrl" target="_blank">
                                        Dosyayı Aç
                                    </a>
                                }

                                <span>
                                    Teslim tarihi: @(homework.SubmittedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                </span>

                                @if (!string.IsNullOrWhiteSpace(homework.Grade) || !string.IsNullOrWhiteSpace(homework.Feedback))
                                {
                                    <div class="grade-box">
                                        <strong>Değerlendirme:</strong>

                                        <div>
                                            <b>Not:</b> @(string.IsNullOrWhiteSpace(homework.Grade) ? "-" : homework.Grade)
                                        </div>

                                        <div>
                                            <b>Geri dönüş:</b> @(string.IsNullOrWhiteSpace(homework.Feedback) ? "-" : homework.Feedback)
                                        </div>

                                        <span>
                                            Değerlendirme tarihi: @(homework.EvaluatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                        </span>
                                    </div>
                                }
                                else
                                {
                                    <div class="waiting-grade-box">
                                        Öğretmen henüz değerlendirme yapmadı.
                                    </div>
                                }
                            </div>
                        }

                        @if (isStudent)
                        {
                            <form asp-controller="Portal"
                                  asp-action="SubmitHomework"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="submit-form">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="homeworkId" value="@homework.Id" />
                                <input type="hidden" name="homeworkCollection" value="@homework.CollectionName" />

                                <label>Cevap / Açıklama</label>
                                <textarea name="answerText" placeholder="Ödev açıklamanızı yazın...">@homework.SubmissionText</textarea>

                                <label>Dosya Yükle</label>

                                <div class="lux-file-upload">
                                    <label class="lux-file-label">
                                        <input type="file"
                                               name="file"
                                               class="lux-file-input"
                                               accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.txt,.zip" />

                                        <div class="lux-file-icon">
                                            📎
                                        </div>

                                        <div class="lux-file-content">
                                            <strong>Dosya seç veya buraya tıkla</strong>
                                            <span>PDF, Word, görsel, TXT veya ZIP yükleyebilirsin.</span>
                                        </div>

                                        <div class="lux-file-button">
                                            Dosya Seç
                                        </div>
                                    </label>

                                    <div class="lux-file-selected">
                                        <span class="lux-file-name">Henüz dosya seçilmedi</span>

                                        <button type="button" class="lux-file-clear">
                                            Kaldır
                                        </button>
                                    </div>
                                </div>

                                <button type="submit">
                                    @(homework.IsSubmitted ? "Teslimi Güncelle" : "Ödev Teslim Et")
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="parent-info">
                                Veli hesabı ödev teslim edemez, sadece bağlı öğrencinin teslim durumunu, notunu ve geri dönüşünü görüntüler.
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    .portal-page {
        min-height: calc(100vh - 60px);
        background: #f6f7fb;
        padding: 24px;
    }

    .portal-shell {
        max-width: 1100px;
        margin: 0 auto;
    }

    .portal-header {
        background: #fff;
        border-radius: 30px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 18px 40px rgba(15,23,42,.06);
        margin-bottom: 20px;
    }

    .portal-avatar {
        width: 70px;
        height: 70px;
        border-radius: 24px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 34px;
    }

    .portal-header h1 {
        margin: 0;
        color: #111827;
        font-size: 30px;
        font-weight: 900;
    }

    .portal-header p {
        margin: 4px 0 0;
        color: #64748b;
        font-weight: 800;
    }

    .logout-btn {
        margin-left: auto;
        background: #fee2e2;
        color: #991b1b;
        text-decoration: none;
        padding: 13px 18px;
        border-radius: 16px;
        font-weight: 900;
    }

    .alert {
        padding: 14px 18px;
        border-radius: 18px;
        margin-bottom: 18px;
        font-weight: 800;
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
        margin-bottom: 22px;
    }

    .stat-card {
        background: #fff;
        border-radius: 24px;
        padding: 22px;
        box-shadow: 0 18px 40px rgba(15,23,42,.06);
    }

    .stat-card span {
        display: block;
        color: #64748b;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .stat-card strong {
        color: #111827;
        font-size: 28px;
        font-weight: 900;
    }

    .section-title {
        font-size: 26px;
        font-weight: 900;
        color: #111827;
        margin: 10px 0 16px;
    }

    .homework-title {
        margin-top: 30px;
    }

    .announcement-list,
    .homework-list {
        display: grid;
        gap: 16px;
    }

    .announcement-card,
    .homework-card {
        background: #fff;
        border-radius: 26px;
        padding: 22px;
        box-shadow: 0 18px 40px rgba(15,23,42,.06);
    }

    .announcement-top,
    .homework-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 12px;
    }

    .announcement-icon {
        width: 52px;
        height: 52px;
        border-radius: 18px;
        background: #eef2ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
    }

    .announcement-card h3,
    .homework-card h3 {
        margin: 0;
        color: #111827;
        font-weight: 900;
    }

    .announcement-card span,
    .homework-card span {
        color: #64748b;
        font-weight: 700;
    }

    .announcement-card p,
    .homework-card p {
        color: #334155;
        font-weight: 700;
        line-height: 1.5;
    }

    .submitted-badge,
    .pending-badge {
        border-radius: 999px;
        padding: 8px 12px;
        font-weight: 900;
        white-space: nowrap;
    }

    .submitted-badge {
        background: #dcfce7;
        color: #166534;
    }

    .pending-badge {
        background: #ffedd5;
        color: #c2410c;
    }

    .submission-box {
        background: #ecfdf5;
        color: #047857;
        border-radius: 18px;
        padding: 14px;
        display: grid;
        gap: 8px;
        font-weight: 800;
        margin: 14px 0;
    }

    .submission-box a {
        color: #0369a1;
        font-weight: 900;
    }

    .grade-box {
        background: #eef2ff;
        color: #3730a3;
        border-radius: 16px;
        padding: 14px;
        display: grid;
        gap: 6px;
        margin-top: 10px;
        font-weight: 800;
    }

    .grade-box strong {
        color: #312e81;
    }

    .waiting-grade-box {
        background: #ffedd5;
        color: #9a3412;
        border-radius: 16px;
        padding: 12px 14px;
        margin-top: 10px;
        font-weight: 900;
    }

    .submit-form {
        margin-top: 16px;
        display: grid;
        gap: 10px;
    }

    .submit-form label {
        color: #111827;
        font-weight: 900;
    }

    .submit-form textarea {
        width: 100%;
        min-height: 110px;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 14px;
        font-weight: 700;
        resize: vertical;
    }

    .submit-form button {
        border: 0;
        background: #4f46e5;
        color: #fff;
        border-radius: 18px;
        min-height: 52px;
        font-weight: 900;
        cursor: pointer;
    }

    .submit-form button:hover {
        background: #4338ca;
    }

    .lux-file-upload {
        display: grid;
        gap: 10px;
    }

    .lux-file-label {
        border: 2px dashed #c7d2fe;
        background:
            radial-gradient(circle at top left, rgba(79, 70, 229, .10), transparent 35%),
            linear-gradient(135deg, #f8fafc, #eef2ff);
        border-radius: 22px;
        padding: 18px;
        display: grid;
        grid-template-columns: 54px 1fr auto;
        align-items: center;
        gap: 14px;
        cursor: pointer;
        transition: .18s ease;
    }

    .lux-file-label:hover {
        border-color: #4f46e5;
        background:
            radial-gradient(circle at top left, rgba(79, 70, 229, .16), transparent 35%),
            linear-gradient(135deg, #ffffff, #eef2ff);
        transform: translateY(-1px);
        box-shadow: 0 16px 34px rgba(79, 70, 229, .14);
    }

    .lux-file-label.has-file {
        border-color: #10b981;
        background:
            radial-gradient(circle at top left, rgba(16, 185, 129, .12), transparent 35%),
            linear-gradient(135deg, #f8fafc, #ecfdf5);
    }

    .lux-file-input {
        display: none !important;
    }

    .lux-file-icon {
        width: 54px;
        height: 54px;
        border-radius: 18px;
        background: #4f46e5;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        box-shadow: 0 12px 24px rgba(79, 70, 229, .25);
    }

    .lux-file-label.has-file .lux-file-icon {
        background: #10b981;
        box-shadow: 0 12px 24px rgba(16, 185, 129, .25);
    }

    .lux-file-content {
        display: grid;
        gap: 4px;
    }

    .lux-file-content strong {
        color: #111827;
        font-size: 16px;
        font-weight: 900;
    }

    .lux-file-content span {
        color: #64748b;
        font-size: 13px;
        font-weight: 800;
    }

    .lux-file-button {
        background: #4f46e5;
        color: #fff;
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 900;
        white-space: nowrap;
    }

    .lux-file-label.has-file .lux-file-button {
        background: #10b981;
    }

    .lux-file-selected {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        background: #f8fafc;
        border: 1px solid #e5e7eb;
        border-radius: 18px;
        padding: 12px 14px;
    }

    .lux-file-name {
        color: #334155;
        font-weight: 900;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .lux-file-clear {
        border: 0;
        background: #fee2e2;
        color: #991b1b;
        border-radius: 14px;
        padding: 9px 12px;
        font-weight: 900;
        cursor: pointer;
        display: none;
    }

    .lux-file-clear.show {
        display: inline-flex;
    }

    .lux-file-clear:hover {
        background: #fecaca;
    }

    .parent-info {
        background: #fff7ed;
        color: #9a3412;
        border-radius: 18px;
        padding: 14px;
        font-weight: 800;
        margin-top: 14px;
    }

    .empty-box {
        background: #fff;
        border-radius: 24px;
        padding: 30px;
        text-align: center;
        color: #64748b;
        font-weight: 800;
    }

    @@media (max-width: 680px) {
        .portal-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .logout-btn {
            margin-left: 0;
            width: 100%;
            text-align: center;
        }

        .homework-top {
            flex-direction: column;
            align-items: flex-start;
        }

        .lux-file-label {
            grid-template-columns: 1fr;
            text-align: center;
        }

        .lux-file-icon {
            margin: 0 auto;
        }

        .lux-file-button {
            width: 100%;
            text-align: center;
        }

        .lux-file-selected {
            flex-direction: column;
            align-items: stretch;
        }

        .lux-file-clear {
            justify-content: center;
        }
    }
</style>

@section Scripts {
    <script>
        document.querySelectorAll(".lux-file-upload").forEach(upload => {
            const input = upload.querySelector(".lux-file-input");
            const fileName = upload.querySelector(".lux-file-name");
            const clearBtn = upload.querySelector(".lux-file-clear");
            const label = upload.querySelector(".lux-file-label");

            input.addEventListener("change", function () {
                if (this.files && this.files.length > 0) {
                    fileName.textContent = this.files[0].name;
                    clearBtn.classList.add("show");
                    label.classList.add("has-file");
                } else {
                    fileName.textContent = "Henüz dosya seçilmedi";
                    clearBtn.classList.remove("show");
                    label.classList.remove("has-file");
                }
            });

            clearBtn.addEventListener("click", function () {
                input.value = "";
                fileName.textContent = "Henüz dosya seçilmedi";
                clearBtn.classList.remove("show");
                label.classList.remove("has-file");
            });
        });
    </script>
}