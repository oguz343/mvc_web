@model mvc_web.Models.PortalViewModel

@{
    Layout = "_Layout";

    var role = Model.Role ?? "";
    var isParent = role.Equals("Veli", StringComparison.OrdinalIgnoreCase);
    var isStudent = !isParent;

    ViewData["Title"] = isParent ? "Veli Paneli" : "Öğrenci Paneli";

    var submittedHomeworkCount = Model.Homeworks.Count(x => x.IsSubmitted);
    var pendingHomeworkCount = Model.Homeworks.Count - submittedHomeworkCount;
    var gradedHomeworkCount = Model.Homeworks.Count(x => !string.IsNullOrWhiteSpace(x.Grade) || !string.IsNullOrWhiteSpace(x.Feedback));
    var now = DateTime.Now;
    var lateHomeworkCount = Model.Homeworks.Count(x => !x.IsSubmitted && x.DueDate != null && x.DueDate.Value < now);
    var soonHomeworkCount = Model.Homeworks.Count(x => !x.IsSubmitted && x.DueDate != null && x.DueDate.Value >= now && x.DueDate.Value <= now.AddDays(2));
    var lessonOptions = Model.Homeworks
        .Select(x => (x.LessonName ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
    var teacherOptions = Model.Homeworks
        .Select(x => (x.TeacherName ?? "").Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(x => x)
        .ToList();
    var orderedHomeworks = Model.Homeworks
        .OrderBy(HomeworkPriority)
        .ThenBy(x => x.DueDate ?? DateTime.MaxValue)
        .ThenBy(x => x.Title)
        .ToList();
    var nextHomework = Model.Homeworks
        .Where(x => !x.IsSubmitted)
        .OrderBy(x => x.DueDate ?? DateTime.MaxValue)
        .FirstOrDefault();

    var progressPercent = Model.Homeworks.Count == 0
        ? 0
        : Math.Round((double)submittedHomeworkCount / Model.Homeworks.Count * 100);

    string SafeText(string value, string fallback = "-")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    string DateText(DateTime? date)
    {
        return date?.ToString("dd.MM.yyyy HH:mm") ?? "-";
    }

    string DueStatusClass(DateTime? date, bool isSubmitted)
    {
        if (isSubmitted)
        {
            return "done";
        }

        if (date == null)
        {
            return "neutral";
        }

        if (date.Value < DateTime.Now)
        {
            return "late";
        }

        if (date.Value <= DateTime.Now.AddDays(2))
        {
            return "soon";
        }

        return "normal";
    }

    string DueStatusText(DateTime? date, bool isSubmitted)
    {
        if (isSubmitted)
        {
            return "Teslim Edildi";
        }

        if (date == null)
        {
            return "Tarih Yok";
        }

        if (date.Value < DateTime.Now)
        {
            return "Süresi Geçti";
        }

        if (date.Value <= DateTime.Now.AddDays(2))
        {
            return "Yaklaşıyor";
        }

        return "Bekliyor";
    }

    int HomeworkPriority(mvc_web.Models.PortalHomeworkItem homework)
    {
        var isGraded = !string.IsNullOrWhiteSpace(homework.Grade) || !string.IsNullOrWhiteSpace(homework.Feedback);

        if (!homework.IsSubmitted && homework.DueDate != null && homework.DueDate.Value < DateTime.Now)
        {
            return 0;
        }

        if (!homework.IsSubmitted && homework.DueDate != null && homework.DueDate.Value <= DateTime.Now.AddDays(2))
        {
            return 1;
        }

        if (!homework.IsSubmitted)
        {
            return 2;
        }

        return isGraded ? 4 : 3;
    }
}

<div class="portal-v2">
    <section class="portal-v2-hero">
        <div>
            <div class="portal-v2-kicker">
                @(isParent ? "Veli İzleme Paneli" : "Öğrenci Paneli")
            </div>

            <div class="portal-v2-title-row">
                <div class="portal-v2-avatar">
                    @(isParent ? "V" : "Ö")
                </div>

                <div>
                    <h1>Hoş geldin, @Model.Name</h1>
                    <p class="portal-v2-hero-text">
                        @(isStudent
                            ? "Ödevlerini, duyurularını, teslim durumunu ve öğretmen geri dönüşlerini bu panelden takip edebilirsin."
                            : "Bağlı öğrencinin ödevlerini, teslim durumunu, notlarını ve öğretmen geri dönüşlerini bu panelden izleyebilirsin.")
                    </p>
                </div>
            </div>

            <div class="portal-v2-identity">
                <span class="portal-v2-chip">@Model.Role</span>
                <span class="portal-v2-chip">No: @Model.Number</span>

                @if (!string.IsNullOrWhiteSpace(Model.ClassName))
                {
                    <span class="portal-v2-chip">Sınıf: @Model.ClassName</span>
                }

                @if (isParent && !string.IsNullOrWhiteSpace(Model.LinkedStudentNo))
                {
                    <span class="portal-v2-chip">Bağlı öğrenci: @Model.LinkedStudentNo</span>
                }
            </div>
        </div>

        <div>
            <div class="portal-v2-progress-card">
                <strong>%@progressPercent</strong>
                <span>Teslim ilerlemesi</span>

                <div class="portal-v2-progress-rail">
                    <div class="portal-v2-progress-fill" style="--progress-percent: @progressPercent%;"></div>
                </div>
            </div>

            <div class="portal-v2-next-card">
                <strong>@(nextHomework == null ? "Bekleyen teslim yok" : nextHomework.Title)</strong>
                <span>
                    @(nextHomework == null
                        ? "Şu anda teslim bekleyen ödev görünmüyor."
                        : $"Son tarih: {DateText(nextHomework.DueDate)}")
                </span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="portal-v2-alert success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="portal-v2-alert error">@TempData["Error"]</div>
    }

    <section class="portal-v2-stat-grid">
        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">D</div>
            <div>
                <strong>@Model.Announcements.Count</strong>
                <span>Duyuru</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">Ö</div>
            <div>
                <strong>@Model.Homeworks.Count</strong>
                <span>Toplam Ödev</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">T</div>
            <div>
                <strong>@submittedHomeworkCount</strong>
                <span>Teslim Edilen</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">B</div>
            <div>
                <strong>@pendingHomeworkCount</strong>
                <span>Bekleyen</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">!</div>
            <div>
                <strong>@lateHomeworkCount</strong>
                <span>Süresi Geçen</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">Y</div>
            <div>
                <strong>@soonHomeworkCount</strong>
                <span>Yaklaşan</span>
            </div>
        </div>

        <div class="portal-v2-stat-card">
            <div class="portal-v2-stat-icon">N</div>
            <div>
                <strong>@gradedHomeworkCount</strong>
                <span>Notlandırılan</span>
            </div>
        </div>
    </section>

    <section class="portal-v2-main-grid">
        <div class="portal-v2-panel">
            <div class="portal-v2-panel-head">
                <div>
                    <h2>Duyurular</h2>
                    <p>Okuldan ve öğretmenlerden gelen bilgilendirmeler.</p>
                </div>

                <span class="portal-v2-section-badge">@Model.Announcements.Count kayıt</span>
            </div>

            @if (!Model.Announcements.Any())
            {
                <div class="portal-v2-empty">Henüz görüntülenecek duyuru yok.</div>
            }
            else
            {
                <div class="portal-v2-announcement-list">
                    @foreach (var item in Model.Announcements)
                    {
                        <article class="portal-v2-announcement-card">
                            <div class="portal-v2-announcement-top">
                                <div class="portal-v2-card-icon">D</div>

                                <div class="portal-v2-card-title">
                                    <h3>@item.Title</h3>
                                    <span>@SafeText(item.Author) - @SafeText(item.Target) - @DateText(item.CreatedAt)</span>
                                </div>

                                <span class="portal-v2-status normal">Duyuru</span>
                            </div>

                            <p class="portal-v2-card-content">@item.Content</p>
                        </article>
                    }
                </div>
            }
        </div>

        <div class="portal-v2-panel">
            <div class="portal-v2-panel-head">
                <div>
                    <h2>Ödevler</h2>
                    <p>@(isStudent ? "Ödevlerini teslim et, güncelle ve değerlendirmeleri takip et." : "Bağlı öğrencinin teslim ve değerlendirme durumunu takip et.")</p>
                </div>

                <span class="portal-v2-section-badge">@Model.Homeworks.Count kayıt</span>
            </div>

            <div class="portal-v2-homework-tools">
                <input id="portalHomeworkSearch"
                       class="portal-v2-homework-search"
                       type="search"
                       placeholder="Ödev, ders veya öğretmen ara..."
                       autocomplete="off" />

                <div class="portal-v2-filter-group" aria-label="Ödev filtresi">
                    <button type="button" class="portal-v2-filter active" data-filter="all">Tümü</button>
                    <button type="button" class="portal-v2-filter" data-filter="urgent">Acil</button>
                    <button type="button" class="portal-v2-filter" data-filter="late">Süresi Geçen</button>
                    <button type="button" class="portal-v2-filter" data-filter="pending">Bekleyen</button>
                    <button type="button" class="portal-v2-filter" data-filter="submitted">Teslim</button>
                    <button type="button" class="portal-v2-filter" data-filter="graded">Notlanan</button>
                </div>

                <div class="portal-v2-filter-selects">
                    <select id="portalHomeworkLesson" class="portal-v2-filter-select" aria-label="Ders filtresi">
                        <option value="">Tüm dersler</option>
                        @foreach (var lesson in lessonOptions)
                        {
                            <option value="@lesson">@lesson</option>
                        }
                    </select>

                    <select id="portalHomeworkTeacher" class="portal-v2-filter-select" aria-label="Öğretmen filtresi">
                        <option value="">Tüm öğretmenler</option>
                        @foreach (var teacher in teacherOptions)
                        {
                            <option value="@teacher">@teacher</option>
                        }
                    </select>
                </div>
            </div>

            @if (!Model.Homeworks.Any())
            {
                <div class="portal-v2-empty">Henüz görüntülenecek ödev yok.</div>
            }
            else
            {
                <div class="portal-v2-homework-list">
                    @foreach (var homework in orderedHomeworks)
                    {
                        var statusClass = DueStatusClass(homework.DueDate, homework.IsSubmitted);
                        var statusText = DueStatusText(homework.DueDate, homework.IsSubmitted);
                        var isGraded = !string.IsNullOrWhiteSpace(homework.Grade) || !string.IsNullOrWhiteSpace(homework.Feedback);
                        var filterStatus = !homework.IsSubmitted ? "pending" : (isGraded ? "graded" : "submitted");
                        var lessonText = SafeText(homework.LessonName, "");
                        var hasTeacherAttachment = !string.IsNullOrWhiteSpace(homework.AttachmentFileUrl);

                        <article class="portal-v2-homework-card"
                                 data-status="@filterStatus"
                                 data-urgency="@statusClass"
                                 data-lesson="@homework.LessonName"
                                 data-teacher="@homework.TeacherName"
                                 data-search="@($"{homework.Title} {homework.Description} {homework.LessonName} {homework.TeacherName} {homework.ClassName} {statusText} {DateText(homework.DueDate)}")">
                            <div class="portal-v2-homework-top">
                                <div class="portal-v2-card-icon">Ö</div>

                                <div class="portal-v2-card-title">
                                    <h3>@homework.Title</h3>
                                    <span>
                                        @if (!string.IsNullOrWhiteSpace(lessonText))
                                        {
                                            <text>@lessonText - </text>
                                        }
                                        @SafeText(homework.TeacherName)
                                        - @SafeText(homework.ClassName)
                                        @if (homework.DueDate != null)
                                        {
                                            <text> - Son tarih: @DateText(homework.DueDate)</text>
                                        }
                                    </span>
                                </div>

                                <span class="portal-v2-status @statusClass">@statusText</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(homework.Description) || hasTeacherAttachment)
                            {
                                <div class="portal-v2-teacher-note">
                                    <div>
                                        <strong>Öğretmen yönergesi</strong>
                                        <p>@(string.IsNullOrWhiteSpace(homework.Description) ? "Bu ödev için ayrıca açıklama eklenmemiş." : homework.Description)</p>
                                    </div>

                                    @if (hasTeacherAttachment)
                                    {
                                        <a class="portal-v2-resource-link"
                                           href="@homework.AttachmentFileUrl"
                                           target="_blank"
                                           rel="noopener noreferrer">
                                            Öğretmen ekini aç
                                        </a>
                                    }
                                </div>
                            }

                            @if (homework.IsSubmitted)
                            {
                                <div class="portal-v2-detail-grid">
                                    <div class="portal-v2-submission-box">
                                        <strong>@(isParent ? "Öğrenci teslimi" : "Senin teslimin")</strong>

                                        @if (!string.IsNullOrWhiteSpace(homework.SubmissionText))
                                        {
                                            <div class="portal-v2-answer-text">@homework.SubmissionText</div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(homework.SubmissionFileUrl))
                                        {
                                            <a class="portal-v2-student-file-link"
                                               href="@homework.SubmissionFileUrl"
                                               target="_blank"
                                               rel="noopener noreferrer">
                                                Teslim dosyasını aç
                                            </a>
                                        }

                                        <span>Teslim tarihi: @DateText(homework.SubmittedAt)</span>
                                    </div>

                                    @if (isGraded)
                                    {
                                        <div class="portal-v2-grade-box">
                                            <strong>Değerlendirme</strong>
                                            <div><b>Not:</b> @(string.IsNullOrWhiteSpace(homework.Grade) ? "-" : homework.Grade)</div>
                                            <div><b>Geri dönüş:</b> @(string.IsNullOrWhiteSpace(homework.Feedback) ? "-" : homework.Feedback)</div>
                                            <span>Değerlendirme tarihi: @DateText(homework.EvaluatedAt)</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="portal-v2-waiting-box">Öğretmen henüz değerlendirme yapmadı.</div>
                                    }
                                </div>
                            }

                            @if (isStudent)
                            {
                                <details class="portal-v2-action-details">
                                    <summary>@(homework.IsSubmitted ? "Teslimini düzenle" : "Teslim alanını aç")</summary>

                                    <form asp-controller="Portal"
                                          asp-action="SubmitHomework"
                                          method="post"
                                          enctype="multipart/form-data"
                                          class="portal-v2-submit-form">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="homeworkId" value="@homework.Id" />
                                        <input type="hidden" name="homeworkCollection" value="@homework.CollectionName" />

                                        <label>Senin cevabın / açıklaman</label>
                                        <textarea name="answerText" placeholder="Teslim açıklamanı veya cevabını yaz...">@homework.SubmissionText</textarea>

                                        <label>Senin teslim dosyan</label>
                                        <div class="portal-v2-file-box">
                                            <label class="portal-v2-file-label">
                                                <input type="file"
                                                       name="file"
                                                       class="portal-v2-file-input"
                                                       accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.txt,.zip" />

                                                <div class="portal-v2-file-text">
                                                    <strong>Teslim dosyası seç</strong>
                                                    <span>PDF, Word, görsel, TXT veya ZIP yükleyebilirsin.</span>
                                                </div>

                                                <div class="portal-v2-file-button">Dosya Seç</div>
                                            </label>

                                            <div class="portal-v2-file-selected">
                                                <span class="portal-v2-file-name">Henüz dosya seçilmedi</span>
                                                <button type="button" class="portal-v2-file-clear">Kaldır</button>
                                            </div>
                                        </div>

                                        <button type="submit" class="portal-v2-submit-button">
                                            @(homework.IsSubmitted ? "Teslimi Güncelle" : "Ödevi Teslim Et")
                                        </button>
                                    </form>
                                </details>
                            }
                            else
                            {
                                <div class="portal-v2-parent-box">
                                    Veli hesabı ödev teslim edemez. Sadece bağlı öğrencinin teslim durumunu, notunu ve öğretmen geri dönüşünü görüntüler.
                                </div>
                            }
                        </article>
                    }
                </div>
                <div id="portalHomeworkNoResult" class="portal-v2-empty" style="display:none;">Aradığınız kritere uygun ödev bulunamadı.</div>
            }
        </div>
    </section>
</div>

@section Scripts {
    <script>
        document.addEventListener("change", function (event) {
            const input = event.target.closest(".portal-v2-file-input");

            if (!input) {
                return;
            }

            const box = input.closest(".portal-v2-file-box");
            const selected = box?.querySelector(".portal-v2-file-selected");
            const name = box?.querySelector(".portal-v2-file-name");

            if (!selected || !name) {
                return;
            }

            if (input.files && input.files.length > 0) {
                name.textContent = input.files[0].name;
                selected.classList.add("active");
            } else {
                name.textContent = "Henüz dosya seçilmedi";
                selected.classList.remove("active");
            }
        });

        document.addEventListener("click", function (event) {
            const clearButton = event.target.closest(".portal-v2-file-clear");

            if (!clearButton) {
                return;
            }

            const box = clearButton.closest(".portal-v2-file-box");
            const input = box?.querySelector(".portal-v2-file-input");
            const selected = box?.querySelector(".portal-v2-file-selected");
            const name = box?.querySelector(".portal-v2-file-name");

            if (input) {
                input.value = "";
            }

            if (name) {
                name.textContent = "Henüz dosya seçilmedi";
            }

            if (selected) {
                selected.classList.remove("active");
            }
        });

        const portalHomeworkSearch = document.getElementById("portalHomeworkSearch");
        const portalHomeworkLesson = document.getElementById("portalHomeworkLesson");
        const portalHomeworkTeacher = document.getElementById("portalHomeworkTeacher");
        const portalHomeworkCards = Array.from(document.querySelectorAll(".portal-v2-homework-card"));
        const portalHomeworkFilters = Array.from(document.querySelectorAll(".portal-v2-filter"));
        const portalHomeworkNoResult = document.getElementById("portalHomeworkNoResult");
        let portalHomeworkFilter = "all";

        function normalizePortalText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterPortalHomeworks() {
            const query = normalizePortalText(portalHomeworkSearch?.value || "");
            const lesson = normalizePortalText(portalHomeworkLesson?.value || "");
            const teacher = normalizePortalText(portalHomeworkTeacher?.value || "");
            let visibleCount = 0;

            portalHomeworkCards.forEach(card => {
                const searchable = normalizePortalText(card.dataset.search || "");
                const status = card.dataset.status || "";
                const urgency = card.dataset.urgency || "";
                const cardLesson = normalizePortalText(card.dataset.lesson || "");
                const cardTeacher = normalizePortalText(card.dataset.teacher || "");
                const matchesQuery = query === "" || searchable.includes(query);
                const matchesLesson = lesson === "" || cardLesson === lesson;
                const matchesTeacher = teacher === "" || cardTeacher === teacher;
                const matchesStatus =
                    portalHomeworkFilter === "all" ||
                    status === portalHomeworkFilter ||
                    (portalHomeworkFilter === "urgent" && (urgency === "late" || urgency === "soon")) ||
                    (portalHomeworkFilter === "late" && urgency === "late");
                const show = matchesQuery && matchesLesson && matchesTeacher && matchesStatus;

                card.style.display = show ? "" : "none";

                if (show) {
                    visibleCount++;
                }
            });

            if (portalHomeworkNoResult) {
                portalHomeworkNoResult.style.display = visibleCount === 0 ? "grid" : "none";
            }
        }

        if (portalHomeworkSearch) {
            portalHomeworkSearch.addEventListener("input", filterPortalHomeworks);
            portalHomeworkSearch.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        [portalHomeworkLesson, portalHomeworkTeacher].forEach(select => {
            if (select) {
                select.addEventListener("change", filterPortalHomeworks);
            }
        });

        portalHomeworkFilters.forEach(button => {
            button.addEventListener("click", function () {
                portalHomeworkFilter = button.dataset.filter || "all";
                portalHomeworkFilters.forEach(item => item.classList.toggle("active", item === button));
                filterPortalHomeworks();
            });
        });

        filterPortalHomeworks();
    </script>
}

