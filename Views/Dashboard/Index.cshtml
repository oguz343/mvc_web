@using System.Collections
@using System.Reflection

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Okul Yönetim Paneli";
    ViewData["PageTitle"] = "Okul Yönetim Paneli";
    ViewData["PageSubtitle"] = "Kullanıcıları, sınıfları, ödevleri, teslimatları ve şifre taleplerini tek yerden takip edin.";

    int GetInt(params string[] keys)
    {
        foreach (var key in keys)
        {
            if (ViewData.ContainsKey(key) && ViewData[key] != null && int.TryParse(ViewData[key]?.ToString(), out var value))
            {
                return value;
            }
        }

        return 0;
    }

    string GetText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    List<object> GetRecentUsers()
    {
        object? raw =
            ViewData["RecentUsers"] ??
            ViewData["LastUsers"] ??
            ViewData["Users"] ??
            ViewData["recentUsers"];

        if (raw == null && Model != null)
        {
            raw = Model;
        }

        if (raw is IEnumerable enumerable && raw is not string)
        {
            return enumerable.Cast<object>().Take(6).ToList();
        }

        return new List<object>();
    }

    var studentCount = GetInt("StudentCount", "StudentsCount", "OgrenciCount", "OgrenciSayisi");
    var teacherCount = GetInt("TeacherCount", "TeachersCount", "OgretmenCount", "OgretmenSayisi");
    var parentCount = GetInt("ParentCount", "ParentsCount", "VeliCount", "VeliSayisi");
    var submissionCount = GetInt("SubmissionCount", "SubmissionsCount", "TeslimCount", "TeslimSayisi");
    var classCount = GetInt("ClassCount", "ClassesCount", "SinifCount", "SinifSayisi");
    var lessonCount = GetInt("LessonCount", "LessonsCount", "DersCount", "DersSayisi");
    var announcementCount = GetInt("AnnouncementCount", "AnnouncementsCount", "DuyuruCount", "DuyuruSayisi");
    var passwordRequestCount = GetInt("PasswordRequestCount", "PasswordRequestsCount", "SifreTalebiCount", "SifreTalepSayisi");
    var recentUsers = GetRecentUsers();

    var activeUsers = studentCount + teacherCount + parentCount;
    var assignedWork = lessonCount;
    var pendingPercent = submissionCount <= 0 ? 0 : Math.Min(100, passwordRequestCount * 100 / Math.Max(1, submissionCount));
    var activePercent = activeUsers <= 0 ? 0 : 100;
    var assignmentPercent = assignedWork <= 0 ? 0 : 100;
}

<div class="neo-dashboard">
    <section class="metric-grid">
        <a class="metric-card purple" asp-controller="Users" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Öğrenci</span>
                <strong>@studentCount</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card green" asp-controller="Users" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Öğretmen</span>
                <strong>@teacherCount</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card orange" asp-controller="Users" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Veli</span>
                <strong>@parentCount</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card blue" asp-controller="Submissions" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Teslim</span>
                <strong>@submissionCount</strong>
                <small>Bu ay</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card violet" asp-controller="Lessons" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Ders Ataması</span>
                <strong>@lessonCount</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card red" asp-controller="Announcements" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Duyuru</span>
                <strong>@announcementCount</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card teal" asp-controller="PasswordRequests" asp-action="Index">
            <div class="metric-icon"></div>
            <div>
                <span>Şifre Talebi</span>
                <strong>@passwordRequestCount</strong>
                <small>Bekleyen</small>
            </div>
            <i></i>
        </a>

        <a class="metric-card pink" asp-controller="AdminAccount" asp-action="ChangePassword">
            <div class="metric-icon"></div>
            <div>
                <span>Yönetici Ataması</span>
                <strong>0</strong>
                <small>Toplam</small>
            </div>
            <i></i>
        </a>
    </section>

    <section class="progress-grid">
        <a class="progress-card purple" asp-controller="Users" asp-action="Index">
            <div class="progress-icon"></div>
            <div class="progress-content">
                <span>Aktif Kullanıcı</span>
                <strong>@activeUsers</strong>
                <small>Bu ay sisteme giriş yapan kullanıcılar</small>
                <div class="progress-track"><b style="width:@activePercent%"></b></div>
            </div>
            <em>%@activePercent</em>
        </a>

        <a class="progress-card green" asp-controller="Lessons" asp-action="Index">
            <div class="progress-icon"></div>
            <div class="progress-content">
                <span>Ödev Atandı</span>
                <strong>@assignedWork</strong>
                <small>Toplam ödev atandı</small>
                <div class="progress-track"><b style="width:@assignmentPercent%"></b></div>
            </div>
            <em>%@assignmentPercent</em>
        </a>

        <a class="progress-card orange" asp-controller="PasswordRequests" asp-action="Index">
            <div class="progress-icon"></div>
            <div class="progress-content">
                <span>Onay Bekleyen</span>
                <strong>@passwordRequestCount</strong>
                <small>Şifre talebi onay bekliyor</small>
                <div class="progress-track"><b style="width:@pendingPercent%"></b></div>
            </div>
            <em>%@pendingPercent</em>
        </a>
    </section>

    <section class="neo-bottom-grid">
        <div class="neo-panel">
            <div class="neo-panel-head">
                <div>
                    <h3>Son Eklenen Kullanıcılar</h3>
                    <p>Sisteme son kaydolan kullanıcılar</p>
                </div>
                <a asp-controller="Users" asp-action="Index">Tümünü Gör</a>
            </div>

            @if (!recentUsers.Any())
            {
                <div class="neo-empty">Henüz kullanıcı kaydı görünmüyor.</div>
            }
            else
            {
                <div class="neo-table-wrap">
                    <table class="neo-table">
                        <thead>
                            <tr>
                                <th>Ad Soyad</th>
                                <th>Rol</th>
                                <th>Numara</th>
                                <th>Detay</th>
                                <th>Kayıt Tarihi</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in recentUsers)
                            {
                                var name = GetText(user, "Name", "name");
                                var role = GetText(user, "Role", "role");
                                var number = GetText(user, "SchoolNo", "schoolNo", "Number", "number");
                                var className = GetText(user, "ClassName", "className");
                                var branch = GetText(user, "Branch", "branch");
                                var linkedStudent = GetText(user, "LinkedStudentNo", "linkedStudentNo");
                                var createdAt = GetText(user, "CreatedAt", "createdAt");
                                var initial = string.IsNullOrWhiteSpace(name) ? "?" : name.Substring(0, 1).ToUpperInvariant();
                                var detail = role == "Öğrenci"
                                    ? $"Sınıf: {(string.IsNullOrWhiteSpace(className) ? "-" : className)}"
                                    : role == "Öğretmen"
                                        ? $"Branş: {(string.IsNullOrWhiteSpace(branch) ? "-" : branch)}"
                                        : role == "Veli"
                                            ? $"Bağlı öğrenci: {(string.IsNullOrWhiteSpace(linkedStudent) ? "-" : linkedStudent)}"
                                            : "-";

                                <tr>
                                    <td>
                                        <span class="person-cell"><b>@initial</b>@(string.IsNullOrWhiteSpace(name) ? "-" : name)</span>
                                    </td>
                                    <td><span class="neo-role">@role</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(number) ? "-" : number)</td>
                                    <td>@detail</td>
                                    <td>@(string.IsNullOrWhiteSpace(createdAt) ? "-" : createdAt)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="neo-panel">
            <div class="neo-panel-head">
                <div>
                    <h3>Hızlı İşlemler</h3>
                    <p>Sık kullanılan yönetim araçları</p>
                </div>
            </div>

            <div class="action-list">
                <a asp-controller="PasswordRequests" asp-action="Index"><span></span><strong>Şifre Talepleri</strong><small>@(passwordRequestCount > 0 ? $"{passwordRequestCount} talep bekliyor" : "Açık şifre talebi yok")</small></a>
                <a asp-controller="Submissions" asp-action="Index"><span></span><strong>Teslim Hareketleri</strong><small>Öğretmenlerin son teslim işlemleri</small></a>
                <a asp-controller="Users" asp-action="Create"><span></span><strong>Yeni Kullanıcı</strong><small>Sisteme yeni kullanıcı ekle</small></a>
                <a asp-controller="Classes" asp-action="Create"><span></span><strong>Yeni Sınıf</strong><small>Yeni sınıf oluştur</small></a>
                <a asp-controller="Lessons" asp-action="Create"><span></span><strong>Yeni Ders Ataması</strong><small>Ders ataması yap</small></a>
                <a asp-controller="Announcements" asp-action="Create"><span></span><strong>Duyuru Yayınla</strong><small>Anons ve duyuru oluştur</small></a>
                <a asp-controller="AdminAccount" asp-action="ChangePassword"><span></span><strong>Admin Şifresi</strong><small>Sistem şifresini yönet</small></a>
            </div>
        </div>
    </section>
</div>
