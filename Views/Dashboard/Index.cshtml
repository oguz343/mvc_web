@using System.Collections
@using System.Reflection

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kontrol Paneli";

    int GetInt(params string[] keys)
    {
        foreach (var key in keys)
        {
            if (ViewData.ContainsKey(key) && ViewData[key] != null)
            {
                if (int.TryParse(ViewData[key]?.ToString(), out var value))
                {
                    return value;
                }
            }
        }

        return 0;
    }

    string GetText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    List<object> GetRecentUsers()
    {
        object? raw =
            ViewData["RecentUsers"] ??
            ViewData["LastUsers"] ??
            ViewData["Users"] ??
            ViewData["recentUsers"] ??
            null;

        if (raw == null && Model != null)
        {
            raw = Model;
        }

        if (raw is IEnumerable enumerable && raw is not string)
        {
            return enumerable.Cast<object>().Take(6).ToList();
        }

        return new List<object>();
    }

    var studentCount = GetInt("StudentCount", "StudentsCount", "OgrenciCount", "OgrenciSayisi");
    var teacherCount = GetInt("TeacherCount", "TeachersCount", "OgretmenCount", "OgretmenSayisi");
    var parentCount = GetInt("ParentCount", "ParentsCount", "VeliCount", "VeliSayisi");
    var submissionCount = GetInt("SubmissionCount", "SubmissionsCount", "TeslimCount", "TeslimSayisi");
    var classCount = GetInt("ClassCount", "ClassesCount", "SinifCount", "SinifSayisi");
    var lessonCount = GetInt("LessonCount", "LessonsCount", "DersCount", "DersSayisi");
    var announcementCount = GetInt("AnnouncementCount", "AnnouncementsCount", "DuyuruCount", "DuyuruSayisi");
    var passwordRequestCount = GetInt("PasswordRequestCount", "PasswordRequestsCount", "SifreTalebiCount", "SifreTalepSayisi");

    var recentUsers = GetRecentUsers();
    var totalUserCount = studentCount + teacherCount + parentCount;
    var setupCount = classCount + lessonCount;
    var visibleSchoolFlow = submissionCount + announcementCount;
    var userBalanceText = totalUserCount > 0
        ? $"{studentCount} öğrenci, {teacherCount} öğretmen, {parentCount} veli"
        : "Kullanıcı eklenince dağılım burada görünür.";
    var securityText = passwordRequestCount > 0
        ? $"{passwordRequestCount} şifre talebi bekliyor."
        : "Açık şifre talebi yok.";
}

<div class="dash-page">
    <section class="dash-hero">
        <div>
            <div class="dash-kicker">Genel Bakış</div>
            <h2>Okul yönetim paneli</h2>
            <p>Kullanıcıları, sınıfları, ödevleri, teslimleri ve şifre taleplerini tek yerden takip edin.</p>
        </div>

        <div class="dash-hero-card">
            <div class="dash-hero-icon">📊</div>
            <div>
                <strong>@totalUserCount</strong>
                <span>Toplam Kullanıcı</span>
            </div>
        </div>
    </section>

    <section class="dash-stats-grid">
        <a asp-controller="Users" asp-action="Index" class="dash-stat-card purple">
            <div class="dash-stat-icon">🎒</div>
            <div>
                <strong>@studentCount</strong>
                <span>Öğrenci</span>
            </div>
        </a>

        <a asp-controller="Users" asp-action="Index" class="dash-stat-card cyan">
            <div class="dash-stat-icon">👨‍🏫</div>
            <div>
                <strong>@teacherCount</strong>
                <span>Öğretmen</span>
            </div>
        </a>

        <a asp-controller="Users" asp-action="Index" class="dash-stat-card orange">
            <div class="dash-stat-icon">👪</div>
            <div>
                <strong>@parentCount</strong>
                <span>Veli</span>
            </div>
        </a>

        <a asp-controller="Submissions" asp-action="Index" class="dash-stat-card green">
            <div class="dash-stat-icon">📥</div>
            <div>
                <strong>@submissionCount</strong>
                <span>Teslim</span>
            </div>
        </a>

        <a asp-controller="Classes" asp-action="Index" class="dash-stat-card blue">
            <div class="dash-stat-icon">🏫</div>
            <div>
                <strong>@classCount</strong>
                <span>Sınıf</span>
            </div>
        </a>

        <a asp-controller="Lessons" asp-action="Index" class="dash-stat-card indigo">
            <div class="dash-stat-icon">📚</div>
            <div>
                <strong>@lessonCount</strong>
                <span>Ders Ataması</span>
            </div>
        </a>

        <a asp-controller="Announcements" asp-action="Index" class="dash-stat-card pink">
            <div class="dash-stat-icon">📣</div>
            <div>
                <strong>@announcementCount</strong>
                <span>Duyuru</span>
            </div>
        </a>

        <a asp-controller="PasswordRequests" asp-action="Index" class="dash-stat-card red">
            <div class="dash-stat-icon">🔐</div>
            <div>
                <strong>@passwordRequestCount</strong>
                <span>Şifre Talebi</span>
            </div>
        </a>
    </section>

    <section class="premium-insight-grid">
        <div class="premium-insight-card" style="--card-accent: rgba(79,70,229,.13); --icon-bg: #eef2ff; --icon-color: #4338ca;">
            <div class="premium-insight-top">
                <div class="premium-insight-icon">👥</div>
                <div>
                    <strong>@totalUserCount</strong>
                    <span>Kullanıcı dengesi</span>
                </div>
            </div>
            <p>@userBalanceText</p>
        </div>

        <div class="premium-insight-card" style="--card-accent: rgba(14,165,233,.14); --icon-bg: #e0f2fe; --icon-color: #0369a1;">
            <div class="premium-insight-top">
                <div class="premium-insight-icon">📚</div>
                <div>
                    <strong>@setupCount</strong>
                    <span>Akademik kurulum</span>
                </div>
            </div>
            <p>@classCount sınıf ve @lessonCount ders ataması aktif görünüyor.</p>
        </div>

        <div class="premium-insight-card" style="--card-accent: rgba(16,185,129,.14); --icon-bg: #dcfce7; --icon-color: #047857;">
            <div class="premium-insight-top">
                <div class="premium-insight-icon">✅</div>
                <div>
                    <strong>@submissionCount</strong>
                    <span>Ödev akışı</span>
                </div>
            </div>
            <p>@visibleSchoolFlow toplam teslim ve duyuru hareketi panelden takip ediliyor.</p>
        </div>

        <div class="premium-insight-card" style="--card-accent: rgba(244,63,94,.13); --icon-bg: #ffe4e6; --icon-color: #be123c;">
            <div class="premium-insight-top">
                <div class="premium-insight-icon">🛡️</div>
                <div>
                    <strong>@passwordRequestCount</strong>
                    <span>Güvenlik gündemi</span>
                </div>
            </div>
            <p>@securityText</p>
        </div>
    </section>

    <section class="dash-bottom-grid">
        <div class="dash-panel">
            <div class="dash-panel-head">
                <div>
                    <h3>Son Eklenen Kullanıcılar</h3>
                    <p>Firestore users koleksiyonundan son kayıtlar</p>
                </div>

                <a asp-controller="Users" asp-action="Index">
                    Tümünü Gör
                </a>
            </div>

            @if (!recentUsers.Any())
            {
                <div class="dash-empty">
                    Henüz kullanıcı kaydı görünmüyor.
                </div>
            }
            else
            {
                <div class="dash-table-wrap">
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Ad Soyad</th>
                                <th>Rol</th>
                                <th>Numara</th>
                                <th>Detay</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var user in recentUsers)
                            {
                                var name = GetText(user, "Name", "name");
                                var role = GetText(user, "Role", "role");
                                var number = GetText(user, "SchoolNo", "schoolNo", "Number", "number");
                                var className = GetText(user, "ClassName", "className");
                                var branch = GetText(user, "Branch", "branch");
                                var linkedStudent = GetText(user, "LinkedStudentNo", "linkedStudentNo");

                                var detail = role == "Öğrenci"
                                    ? $"Sınıf: {(string.IsNullOrWhiteSpace(className) ? "-" : className)}"
                                    : role == "Öğretmen"
                                        ? $"Branş: {(string.IsNullOrWhiteSpace(branch) ? "-" : branch)}"
                                        : role == "Veli"
                                            ? $"Bağlı öğrenci: {(string.IsNullOrWhiteSpace(linkedStudent) ? "-" : linkedStudent)}"
                                            : "-";

                                <tr>
                                    <td>
                                        <strong>@(string.IsNullOrWhiteSpace(name) ? "-" : name)</strong>
                                    </td>

                                    <td>
                                        <span class="role-pill">@role</span>
                                    </td>

                                    <td>@(string.IsNullOrWhiteSpace(number) ? "-" : number)</td>

                                    <td>@detail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="dash-panel quick-panel">
            <div class="dash-panel-head">
                <div>
                    <h3>Hızlı İşlemler</h3>
                    <p>Sık kullanılan yönetim araçları</p>
                </div>
            </div>

            <div class="premium-detail-feed">
                <div class="premium-feed-item" style="--feed-accent: rgba(244,63,94,.10); --feed-icon-bg: #ffe4e6; --feed-icon-color: #be123c;">
                    <div class="premium-feed-icon">🔐</div>
                    <div class="premium-feed-body">
                        <strong>Şifre talepleri</strong>
                        <span>@securityText</span>
                    </div>
                    <div class="premium-feed-tag">@passwordRequestCount</div>
                </div>

                <div class="premium-feed-item" style="--feed-accent: rgba(16,185,129,.10); --feed-icon-bg: #dcfce7; --feed-icon-color: #047857;">
                    <div class="premium-feed-icon">📥</div>
                    <div class="premium-feed-body">
                        <strong>Teslim hareketi</strong>
                        <span>Öğretmenlerin değerlendireceği son teslimler.</span>
                    </div>
                    <div class="premium-feed-tag">@submissionCount</div>
                </div>
            </div>

            <div class="quick-actions premium-section-spacer">
                <a asp-controller="Users" asp-action="Create">
                    <span>👥</span>
                    Yeni Kullanıcı
                </a>

                <a asp-controller="Classes" asp-action="Create">
                    <span>🏫</span>
                    Yeni Sınıf
                </a>

                <a asp-controller="Lessons" asp-action="Create">
                    <span>📚</span>
                    Yeni Ders Ataması
                </a>

                <a asp-controller="Announcements" asp-action="Create">
                    <span>📣</span>
                    Duyuru Yayınla
                </a>

                <a asp-controller="AdminAccount" asp-action="ChangePassword">
                    <span>🛡️</span>
                    Admin Şifresi
                </a>
            </div>
        </div>
    </section>
</div>

<style>
    .dash-page {
        display: grid;
        gap: 22px;
        padding: 2px;
    }

    .dash-hero {
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at 8% 12%, rgba(79, 70, 229, .20), transparent 32%),
            radial-gradient(circle at 94% 18%, rgba(6, 182, 212, .16), transparent 28%),
            linear-gradient(135deg, #ffffff, #f1f5fb);
        border: 1px solid rgba(203,213,225,.95);
        border-radius: 32px;
        padding: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 22px;
        box-shadow: 0 26px 70px rgba(15, 23, 42, .12);
    }

    .dash-hero::after {
        content: "";
        position: absolute;
        inset: auto -70px -120px auto;
        width: 270px;
        height: 270px;
        border-radius: 999px;
        background: rgba(79, 70, 229, .08);
        pointer-events: none;
    }

    .dash-kicker {
        width: fit-content;
        color: #3730a3;
        background: #eef2ff;
        border: 1px solid #c7d2fe;
        border-radius: 999px;
        padding: 7px 11px;
        font-weight: 950;
        font-size: 13px;
        margin-bottom: 10px;
    }

    .dash-hero h2 {
        margin: 0;
        color: #0f172a;
        font-size: 34px;
        font-weight: 950;
        letter-spacing: -.7px;
    }

    .dash-hero p {
        margin: 8px 0 0;
        color: #64748b;
        font-weight: 800;
        line-height: 1.5;
        max-width: 640px;
    }

    .dash-hero-card {
        position: relative;
        z-index: 1;
        min-width: 210px;
        background: rgba(255,255,255,.92);
        border: 1px solid #cbd5e1;
        border-radius: 26px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 18px 44px rgba(15, 23, 42, .12);
    }

    .dash-hero-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        background: linear-gradient(135deg, #4f46e5, #06b6d4);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 28px;
    }

    .dash-hero-card strong {
        display: block;
        color: #0f172a;
        font-size: 30px;
        font-weight: 950;
    }

    .dash-hero-card span {
        color: #64748b;
        font-weight: 850;
    }

    .dash-stats-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
    }

    .dash-stat-card {
        position: relative;
        overflow: hidden;
        background:
            linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.92));
        border: 1px solid #cbd5e1;
        border-radius: 28px;
        padding: 20px;
        display: flex;
        align-items: center;
        gap: 15px;
        text-decoration: none;
        box-shadow: 0 20px 48px rgba(15, 23, 42, .105);
        transition: .18s ease;
        min-height: 118px;
    }

    .dash-stat-card::before {
        content: "";
        position: absolute;
        inset: 0 auto 0 0;
        width: 7px;
        background: #4f46e5;
    }

    .dash-stat-card::after {
        content: "";
        position: absolute;
        right: -34px;
        top: -42px;
        width: 118px;
        height: 118px;
        border-radius: 999px;
        background: rgba(79, 70, 229, .08);
        pointer-events: none;
    }

    .dash-stat-card:hover {
        transform: translateY(-3px);
        border-color: #a5b4fc;
        box-shadow: 0 28px 62px rgba(15, 23, 42, .14);
    }

    .dash-stat-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 27px;
        flex: 0 0 auto;
        position: relative;
        z-index: 1;
    }

    .dash-stat-card strong {
        display: block;
        color: #0f172a;
        font-size: 32px;
        line-height: 1;
        font-weight: 950;
        position: relative;
        z-index: 1;
    }

    .dash-stat-card span {
        display: block;
        color: #64748b;
        font-weight: 900;
        margin-top: 6px;
        position: relative;
        z-index: 1;
    }

    .dash-stat-card.purple::before { background: #4f46e5; }
    .dash-stat-card.cyan::before { background: #0891b2; }
    .dash-stat-card.orange::before { background: #ea580c; }
    .dash-stat-card.green::before { background: #059669; }
    .dash-stat-card.blue::before { background: #2563eb; }
    .dash-stat-card.indigo::before { background: #6366f1; }
    .dash-stat-card.pink::before { background: #db2777; }
    .dash-stat-card.red::before { background: #dc2626; }

    .dash-stat-card.purple .dash-stat-icon {
        background: #eef2ff;
        color: #3730a3;
    }

    .dash-stat-card.cyan .dash-stat-icon {
        background: #cffafe;
        color: #0e7490;
    }

    .dash-stat-card.orange .dash-stat-icon {
        background: #ffedd5;
        color: #c2410c;
    }

    .dash-stat-card.green .dash-stat-icon {
        background: #dcfce7;
        color: #047857;
    }

    .dash-stat-card.blue .dash-stat-icon {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .dash-stat-card.indigo .dash-stat-icon {
        background: #e0e7ff;
        color: #4338ca;
    }

    .dash-stat-card.pink .dash-stat-icon {
        background: #fce7f3;
        color: #be185d;
    }

    .dash-stat-card.red .dash-stat-icon {
        background: #fee2e2;
        color: #b91c1c;
    }

    .dash-bottom-grid {
        display: grid;
        grid-template-columns: 1.45fr .85fr;
        gap: 18px;
    }

    .dash-panel {
        background:
            linear-gradient(135deg, rgba(255,255,255,.98), rgba(248,250,252,.94));
        border: 1px solid #cbd5e1;
        border-radius: 30px;
        padding: 22px;
        box-shadow: 0 20px 50px rgba(15, 23, 42, .10);
    }

    .dash-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 16px;
    }

    .dash-panel-head h3 {
        margin: 0;
        color: #0f172a;
        font-size: 22px;
        font-weight: 950;
    }

    .dash-panel-head p {
        margin: 5px 0 0;
        color: #64748b;
        font-weight: 800;
    }

    .dash-panel-head a {
        background: #eef2ff;
        color: #4338ca;
        text-decoration: none;
        border-radius: 16px;
        padding: 12px 16px;
        font-weight: 950;
        white-space: nowrap;
    }

    .dash-empty {
        background: #f8fafc;
        border-radius: 20px;
        padding: 22px;
        color: #64748b;
        font-weight: 900;
        text-align: center;
    }

    .dash-table-wrap {
        overflow-x: auto;
    }

    .dash-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 620px;
    }

    .dash-table th {
        text-align: left;
        padding: 14px 12px;
        color: #64748b;
        font-weight: 950;
        background: #f1f5f9;
        border-bottom: 1px solid #cbd5e1;
        white-space: nowrap;
    }

    .dash-table td {
        padding: 15px 12px;
        border-bottom: 1px solid #e2e8f0;
        color: #334155;
        font-weight: 800;
    }

    .dash-table td strong {
        color: #0f172a;
        font-weight: 950;
    }

    .role-pill {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        background: #f1f5f9;
        color: #334155;
        padding: 7px 11px;
        font-size: 12px;
        font-weight: 950;
    }

    .quick-actions {
        display: grid;
        gap: 12px;
    }

    .quick-actions a {
        min-height: 58px;
        background: #ffffff;
        border: 1px solid #cbd5e1;
        border-radius: 20px;
        color: #0f172a;
        text-decoration: none;
        font-weight: 950;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 16px;
        transition: .18s ease;
    }

    .quick-actions a:hover {
        background: #eef2ff;
        border-color: #c7d2fe;
        color: #3730a3;
        transform: translateX(3px);
        box-shadow: 0 14px 28px rgba(79, 70, 229, .12);
    }

    .quick-actions span {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        background: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

    @@media (max-width: 1180px) {
        .dash-stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .dash-bottom-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 720px) {
        .dash-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .dash-hero-card {
            width: 100%;
        }

        .dash-stats-grid {
            grid-template-columns: 1fr;
        }

        .dash-panel-head {
            flex-direction: column;
            align-items: flex-start;
        }

        .dash-panel-head a {
            width: 100%;
            text-align: center;
        }
    }
</style>
