@using System.Globalization
@{
    Layout = "_Layout";

    ViewData["Title"] = "Yeni Ödev Oluştur";

    var teacherName = GetText(ViewData["TeacherName"]);
    var teacherNo = GetText(ViewData["TeacherNo"]);
    var teacherBranch = GetText(ViewData["TeacherBranch"]);

    var lessons = ReadLessons(ViewData["Lessons"]);

    if (lessons.Count == 0)
    {
        lessons = ReadLessons(ViewData["TeacherLessons"]);
    }

    if (lessons.Count == 0)
    {
        lessons = ReadLessons(ViewData["MyLessons"]);
    }

    string error = TempData["Error"]?.ToString() ?? "";
    string success = TempData["Success"]?.ToString() ?? "";
}

<div class="teacher-create-page">
    <section class="create-hero">
        <div class="hero-glow hero-glow-one"></div>
        <div class="hero-glow hero-glow-two"></div>

        <div class="hero-content">
            <div class="hero-icon">
                <span>📝</span>
            </div>

            <div>
                <p class="eyebrow">Öğretmen Paneli</p>
                <h1>Yeni Ödev Oluştur</h1>
                <p class="hero-subtitle">
                    Size atanmış derslerden birini veya birkaçını seçerek öğrencilerinize ödev yayınlayın.
                </p>
            </div>
        </div>

        <div class="teacher-card">
            <div class="teacher-avatar">👨‍🏫</div>
            <div>
                <strong>@(string.IsNullOrWhiteSpace(teacherName) ? "Öğretmen" : teacherName)</strong>
                <span>No: @(string.IsNullOrWhiteSpace(teacherNo) ? "-" : teacherNo)</span>
                <span>Branş: @(string.IsNullOrWhiteSpace(teacherBranch) ? "-" : teacherBranch)</span>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="alert-card alert-error">
            <span>⚠️</span>
            <strong>@error</strong>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(success))
    {
        <div class="alert-card alert-success">
            <span>✅</span>
            <strong>@success</strong>
        </div>
    }

    <section class="create-grid">
        <div class="form-card">
            <div class="section-title">
                <div>
                    <p class="eyebrow">Ödev Bilgileri</p>
                    <h2>Ödev Detayları</h2>
                </div>
                <span class="lesson-count">@lessons.Count Ders</span>
            </div>

            @if (lessons.Count == 0)
            {
                <div class="empty-lessons">
                    <div class="empty-icon">📚</div>
                    <h3>Size atanmış ders bulunmuyor.</h3>
                    <p>
                        Admin panelinden önce öğretmene ders atanmalıdır.
                    </p>
                    <a class="ghost-link" asp-controller="Teacher" asp-action="Index">
                        Panele Dön
                    </a>
                </div>
            }
            else
            {
                <form asp-controller="Teacher" asp-action="CreateAssignment" method="post" class="premium-form">
                    @Html.AntiForgeryToken()

                    <div class="field-group">
                        <label for="lessonIds">Ders / Sınıf Seç</label>
                        <div class="select-wrap lesson-picker-grid" id="lessonIds">
                            <select class="legacy-lesson-select" name="lessonIds" multiple required>
                                @foreach (var lesson in lessons)
                                {
                                    <option value="@lesson.Id"
                                            data-name="@lesson.Name"
                                            data-class="@lesson.ClassName"
                                            data-branch="@lesson.Branch">
                                        @lesson.Name • @lesson.ClassName @(string.IsNullOrWhiteSpace(lesson.Branch) ? "" : $"• {lesson.Branch}")
                                    </option>
                                }
                            </select>
                            <div class="lesson-card-picker" id="lessonCardPicker"></div>
                        </div>
                        <small>Birden fazla ders/sınıf seçerseniz her atama için ayrı ödev oluşturulur.</small>
                    </div>

                    <input type="hidden" id="lessonName" name="lessonName" />
                    <input type="hidden" id="className" name="className" />

                    <div class="selected-lesson-preview" id="lessonPreview">
                        <div class="preview-icon">📘</div>
                        <div>
                            <strong>Ders seçilmedi</strong>
                            <span>Ödev yayınlamak için önce ders seçin.</span>
                        </div>
                    </div>

                    <div class="field-group">
                        <label for="title">Ödev Başlığı</label>
                        <input id="title"
                               name="title"
                               type="text"
                               placeholder="Örn: Fonksiyonlar çalışma kağıdı"
                               autocomplete="off"
                               required />
                    </div>

                    <div class="field-group">
                        <label for="description">Açıklama</label>
                        <textarea id="description"
                                  name="description"
                                  rows="5"
                                  placeholder="Ödev açıklamasını, yönergeleri veya yapılacakları yazın."></textarea>
                    </div>

                    <div class="two-col">
                        <div class="field-group">
                            <label for="dueDate">Son Teslim Tarihi</label>
                            <input id="dueDate"
                                   name="dueDate"
                                   type="datetime-local" />
                        </div>

                        <div class="field-group">
                            <label for="fileType">Teslim Türü</label>
                            <select id="fileType" name="fileType">
                                <option value="Metin / Link">Metin / Link</option>
                                <option value="Dosya">Dosya</option>
                                <option value="PDF">PDF</option>
                                <option value="Sunum">Sunum</option>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="submit-btn">
                        <span>🚀</span>
                        Ödevi Yayınla
                    </button>
                </form>
            }
        </div>

        <aside class="lessons-card">
            <div class="section-title mini">
                <div>
                    <p class="eyebrow">Atanmış Dersler</p>
                    <h2>Derslerim</h2>
                </div>
            </div>

            @if (lessons.Count == 0)
            {
                <div class="side-empty">
                    Henüz ders bulunmuyor.
                </div>
            }
            else
            {
                <div class="lesson-list">
                    @foreach (var lesson in lessons)
                    {
                        <div class="lesson-mini-card">
                            <div class="lesson-mini-icon">📘</div>
                            <div>
                                <strong>@lesson.Name</strong>
                                <span>@lesson.ClassName @(string.IsNullOrWhiteSpace(lesson.Branch) ? "" : $"• {lesson.Branch}")</span>
                            </div>
                        </div>
                    }
                </div>
            }
        </aside>
    </section>
</div>

