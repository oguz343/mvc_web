@using System.Collections
@using System.Reflection

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Yeni Ödev";
    ViewData["PageTitle"] = "Yeni Ödev Oluştur";
    ViewData["PageSubtitle"] = "Size atanmış derslerden birini seçerek öğrencilere yeni ödev yayınlayın.";

    var lessons = ListFrom(ViewData["Lessons"] ?? ViewData["TeacherLessons"] ?? ViewData["MyLessons"]);
    var teacherName = Text(ViewData["TeacherName"], "Öğretmen");
    var teacherBranch = Text(ViewData["TeacherBranch"], "-");
}

@functions {
    private List<object> ListFrom(object? raw)
    {
        if (raw == null || raw is string)
        {
            return new List<object>();
        }

        if (raw is IEnumerable enumerable)
        {
            return enumerable.Cast<object>().ToList();
        }

        return new List<object>();
    }

    private string Text(object? value, string fallback = "-")
    {
        var result = value?.ToString() ?? "";
        return string.IsNullOrWhiteSpace(result) ? fallback : result;
    }

    private string Get(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);
                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string First(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }
}

<style>
    .teacher-form-v2 {
        width: 100%;
        max-width: none;
        display: grid;
        gap: 18px;
    }

    .teacher-form-hero,
    .teacher-form-card,
    .teacher-form-side,
    .teacher-form-empty {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .teacher-form-hero {
        padding: 24px;
        border-radius: 32px;
    }

    .teacher-form-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .teacher-form-hero h1 {
        max-width: 840px;
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .teacher-form-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .teacher-form-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        align-items: start;
    }

    .teacher-form-card,
    .teacher-form-side,
    .teacher-form-empty {
        padding: 22px;
        border-radius: 30px;
    }

    .teacher-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .teacher-form-field {
        display: grid;
        gap: 8px;
    }

    .teacher-form-field.full {
        grid-column: 1 / -1;
    }

    .teacher-form-field label {
        color: #dbeafe;
        font-size: 13px;
        font-weight: 950;
    }

    .teacher-form-field input,
    .teacher-form-field select,
    .teacher-form-field textarea {
        width: 100%;
        min-height: 48px;
        padding: 0 13px;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .18);
        outline: none;
        color: #ffffff;
        background: rgba(7, 17, 31, .58);
        font-size: 14px;
        font-weight: 750;
    }

    .teacher-form-field textarea {
        min-height: 160px;
        padding-top: 13px;
        resize: vertical;
        line-height: 1.55;
    }

    .teacher-form-field input:focus,
    .teacher-form-field select:focus,
    .teacher-form-field textarea:focus {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .teacher-form-field option {
        color: #0f172a;
        background: #ffffff;
    }

    .teacher-form-submit-row {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    .teacher-form-submit,
    .teacher-form-back {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 950;
    }

    .teacher-form-submit {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-color: rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .teacher-form-back {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border-color: rgba(148, 163, 184, .18);
    }

    .teacher-form-side h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .teacher-form-side p {
        margin: 8px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.55;
    }

    .teacher-form-side-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .teacher-form-side-item {
        padding: 12px;
        border-radius: 16px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
    }

    .teacher-form-empty {
        min-height: 260px;
        display: grid;
        place-items: center;
        text-align: center;
        color: #94a3b8;
        font-weight: 850;
        line-height: 1.55;
    }

    @@media (max-width: 1100px) {
        .teacher-form-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .teacher-form-hero,
        .teacher-form-card,
        .teacher-form-side,
        .teacher-form-empty {
            border-radius: 22px;
            padding: 16px;
        }

        .teacher-form-grid {
            grid-template-columns: 1fr;
        }

        .teacher-form-submit-row {
            flex-direction: column;
            align-items: stretch;
        }

        .teacher-form-submit,
        .teacher-form-back {
            width: 100%;
        }
    }
</style>

<div class="teacher-form-v2">
    <section class="teacher-form-hero">
        <div class="teacher-form-kicker">Yeni Ödev</div>

        <h1>Öğrencileriniz için yeni ödev yayınlayın.</h1>

        <p>
            Ders atamanızı seçin, başlık ve açıklama girin. Sistem ödevi ilgili sınıf ve ders için yayınlar.
        </p>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!lessons.Any())
    {
        <div class="teacher-form-empty">
            Size atanmış ders bulunmuyor. Ödev oluşturmak için önce admin panelinden bu öğretmene ders ataması yapılmalı.
        </div>
    }
    else
    {
        <section class="teacher-form-layout">
            <form asp-controller="Teacher"
                  asp-action="CreateAssignment"
                  method="post"
                  class="teacher-form-card">

                @Html.AntiForgeryToken()

                <div class="teacher-form-grid">
                    <div class="teacher-form-field full">
                        <label>Ders / Sınıf Seçimi</label>

                        <select id="lessonSelect" name="lessonId" required>
                            <option value="">Ders seçin</option>

                            @foreach (var lesson in lessons)
                            {
                                var id = First(Get(lesson, "Id", "id"), Get(lesson, "lessonId", "LessonId"));
                                var lessonName = First(Get(lesson, "Name", "name"), Get(lesson, "LessonName", "lessonName"), Get(lesson, "Title", "title"), "Ders");
                                var className = First(Get(lesson, "ClassName", "className"), Get(lesson, "Class", "class"), Get(lesson, "TargetClass", "targetClass"), "-");

                                <option value="@id"
                                        data-lesson="@lessonName"
                                        data-class="@className">
                                    @lessonName · @className
                                </option>
                            }
                        </select>

                        <input type="hidden" id="lessonNameInput" name="lessonName" />
                        <input type="hidden" id="classNameInput" name="className" />
                    </div>

                    <div class="teacher-form-field full">
                        <label>Ödev Başlığı</label>
                        <input type="text"
                               name="title"
                               maxlength="120"
                               placeholder="Örn: Ünite 2 Problem Çözümü"
                               required />
                    </div>

                    <div class="teacher-form-field">
                        <label>Son Teslim Tarihi</label>
                        <input type="datetime-local" name="dueDate" />
                    </div>

                    <div class="teacher-form-field">
                        <label>Teslim Türü</label>
                        <select name="fileType">
                            <option value="Dosya">Dosya</option>
                            <option value="Metin">Metin</option>
                            <option value="Dosya veya Metin">Dosya veya Metin</option>
                            <option value="Link">Link</option>
                        </select>
                    </div>

                    <div class="teacher-form-field full">
                        <label>Açıklama</label>
                        <textarea name="description"
                                  placeholder="Öğrencilerin yapması gerekenleri net şekilde yazın."></textarea>
                    </div>
                </div>

                <div class="teacher-form-submit-row">
                    <a asp-controller="Teacher"
                       asp-action="Assignments"
                       class="teacher-form-back">
                        Vazgeç
                    </a>

                    <button type="submit" class="teacher-form-submit">
                        📝 Ödevi Yayınla
                    </button>
                </div>
            </form>

            <aside class="teacher-form-side">
                <h3>Öğretmen Bilgisi</h3>

                <p>
                    Ödev, giriş yapan öğretmen hesabına bağlı olarak oluşturulur.
                </p>

                <div class="teacher-form-side-list">
                    <div class="teacher-form-side-item">
                        👤 @teacherName
                    </div>

                    <div class="teacher-form-side-item">
                        📚 @teacherBranch
                    </div>

                    <div class="teacher-form-side-item">
                        🏫 @lessons.Count ders ataması mevcut
                    </div>
                </div>
            </aside>
        </section>
    }
</div>

@section Scripts {
    <script>
        const lessonSelect = document.getElementById("lessonSelect");
        const lessonNameInput = document.getElementById("lessonNameInput");
        const classNameInput = document.getElementById("classNameInput");

        function syncLessonFields() {
            const option = lessonSelect?.selectedOptions?.[0];

            if (!option) {
                return;
            }

            if (lessonNameInput) {
                lessonNameInput.value = option.dataset.lesson || "";
            }

            if (classNameInput) {
                classNameInput.value = option.dataset.class || "";
            }
        }

        if (lessonSelect) {
            lessonSelect.addEventListener("change", syncLessonFields);
            syncLessonFields();
        }
    </script>
}