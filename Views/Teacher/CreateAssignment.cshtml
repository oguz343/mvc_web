<script>
    (function () {
        const select = document.getElementById('lessonIds');
        const realSelect = select ? select.querySelector('select') : null;
        const cardPicker = document.getElementById('lessonCardPicker');
        const lessonNameInput = document.getElementById('lessonName');
        const classNameInput = document.getElementById('className');
        const preview = document.getElementById('lessonPreview');

        if (!select || !realSelect || !preview || !cardPicker) {
            return;
        }

        Array.from(realSelect.options).forEach(option => {
            const card = document.createElement('button');
            card.type = 'button';
            card.className = 'lesson-choice-card';
            card.innerHTML = `
                <span class="lesson-choice-check">✓</span>
                <span>
                    <strong>${escapeHtml(option.dataset.name || option.textContent || 'Ders')}</strong>
                    <span>${escapeHtml(option.dataset.class || '-')}${option.dataset.branch ? ' • ' + escapeHtml(option.dataset.branch) : ''}</span>
                </span>
            `;

            card.addEventListener('click', () => {
                option.selected = !option.selected;
                updatePreview();
            });

            cardPicker.appendChild(card);
        });

        function updatePreview() {
            const options = Array.from(realSelect.options || []);
            const selectedOptions = options.filter(option => option.selected);

            Array.from(cardPicker.children).forEach((card, index) => {
                card.classList.toggle('is-selected', options[index] && options[index].selected);
            });

            if (selectedOptions.length === 0) {
                if (lessonNameInput) lessonNameInput.value = '';
                if (classNameInput) classNameInput.value = '';

                preview.innerHTML = `
                    <div class="preview-icon">📘</div>
                    <div>
                        <strong>Ders seçilmedi</strong>
                        <span>Ödev yayınlamak için önce ders seçin.</span>
                    </div>
                `;
                return;
            }

            const first = selectedOptions[0];
            const name = first.dataset.name || first.textContent || 'Ders';
            const className = first.dataset.class || '-';

            if (lessonNameInput) lessonNameInput.value = name;
            if (classNameInput) classNameInput.value = className;

            const summary = selectedOptions
                .map(option => {
                    const itemName = option.dataset.name || option.textContent || 'Ders';
                    const itemClass = option.dataset.class || '-';
                    const itemBranch = option.dataset.branch || '';
                    return `${escapeHtml(itemName)} - ${escapeHtml(itemClass)}${itemBranch ? ' • ' + escapeHtml(itemBranch) : ''}`;
                })
                .join('<br>');

            preview.innerHTML = `
                <div class="preview-icon">📘</div>
                <div>
                    <strong>${selectedOptions.length} ders/sınıf seçildi</strong>
                    <span>${summary}</span>
                </div>
            `;
        }

        function escapeHtml(value) {
            return String(value)
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#039;');
        }

        realSelect.addEventListener('change', updatePreview);
        updatePreview();
    })();
</script>

@functions {
    public class LessonOption
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "Ders";
        public string ClassName { get; set; } = "-";
        public string Branch { get; set; } = "";
        public string TeacherName { get; set; } = "";
        public string TeacherNo { get; set; } = "";
    }

    private static List<LessonOption> ReadLessons(object? source)
    {
        var result = new List<LessonOption>();

        if (source == null)
        {
            return result;
        }

        if (source is IEnumerable<Dictionary<string, object>> dictionaryList)
        {
            foreach (var item in dictionaryList)
            {
                var lesson = FromDictionary(item);

                if (!string.IsNullOrWhiteSpace(lesson.Id))
                {
                    result.Add(lesson);
                }
            }

            return DistinctLessons(result);
        }

        if (source is IEnumerable<object> objectList)
        {
            foreach (var item in objectList)
            {
                if (item is Dictionary<string, object> dict)
                {
                    var lesson = FromDictionary(dict);

                    if (!string.IsNullOrWhiteSpace(lesson.Id))
                    {
                        result.Add(lesson);
                    }
                }
                else
                {
                    var lesson = FromObject(item);

                    if (!string.IsNullOrWhiteSpace(lesson.Id))
                    {
                        result.Add(lesson);
                    }
                }
            }

            return DistinctLessons(result);
        }

        return result;
    }

    private static List<LessonOption> DistinctLessons(List<LessonOption> lessons)
    {
        return lessons
            .GroupBy(x => Normalize($"{x.Id}_{x.Name}_{x.ClassName}"))
            .Select(x => x.First())
            .OrderBy(x => x.ClassName)
            .ThenBy(x => x.Name)
            .ToList();
    }

    private static LessonOption FromDictionary(Dictionary<string, object> data)
    {
        var id = FirstNonEmpty(
            GetText(data, "Id"),
            GetText(data, "id"),
            GetText(data, "LessonId"),
            GetText(data, "lessonId")
        );

        var name = FirstNonEmpty(
            GetText(data, "Name"),
            GetText(data, "name"),
            GetText(data, "LessonName"),
            GetText(data, "lessonName"),
            GetText(data, "Title"),
            GetText(data, "title"),
            GetText(data, "CourseName"),
            GetText(data, "courseName"),
            "Ders"
        );

        var className = NormalizeClassName(FirstNonEmpty(
            GetText(data, "ClassName"),
            GetText(data, "className"),
            GetText(data, "Class"),
            GetText(data, "class"),
            GetText(data, "TargetClass"),
            GetText(data, "targetClass"),
            "-"
        ));

        var branch = FirstNonEmpty(
            GetText(data, "Branch"),
            GetText(data, "branch"),
            GetText(data, "TeacherBranch"),
            GetText(data, "teacherBranch")
        );

        var teacherName = FirstNonEmpty(
            GetText(data, "TeacherName"),
            GetText(data, "teacherName"),
            GetText(data, "Teacher"),
            GetText(data, "teacher")
        );

        var teacherNo = FirstNonEmpty(
            GetText(data, "TeacherNo"),
            GetText(data, "teacherNo"),
            GetText(data, "TeacherNumber"),
            GetText(data, "teacherNumber")
        );

        return new LessonOption
        {
            Id = id,
            Name = name,
            ClassName = string.IsNullOrWhiteSpace(className) ? "-" : className,
            Branch = branch,
            TeacherName = teacherName,
            TeacherNo = teacherNo
        };
    }

    private static LessonOption FromObject(object item)
    {
        var type = item.GetType();

        string GetProperty(params string[] names)
        {
            foreach (var name in names)
            {
                var property = type.GetProperty(name);

                if (property == null)
                {
                    continue;
                }

                var value = property.GetValue(item)?.ToString();

                if (!string.IsNullOrWhiteSpace(value))
                {
                    return value.Trim();
                }
            }

            return "";
        }

        var id = FirstNonEmpty(
            GetProperty("Id", "id", "LessonId", "lessonId")
        );

        var name = FirstNonEmpty(
            GetProperty("Name", "name", "LessonName", "lessonName", "Title", "title", "CourseName", "courseName"),
            "Ders"
        );

        var className = NormalizeClassName(FirstNonEmpty(
            GetProperty("ClassName", "className", "Class", "class", "TargetClass", "targetClass"),
            "-"
        ));

        var branch = GetProperty("Branch", "branch", "TeacherBranch", "teacherBranch");

        return new LessonOption
        {
            Id = id,
            Name = name,
            ClassName = string.IsNullOrWhiteSpace(className) ? "-" : className,
            Branch = branch,
            TeacherName = GetProperty("TeacherName", "teacherName", "Teacher", "teacher"),
            TeacherNo = GetProperty("TeacherNo", "teacherNo", "TeacherNumber", "teacherNumber")
        };
    }

    private static string GetText(object? value)
    {
        return value?.ToString()?.Trim() ?? "";
    }

    private static string GetText(Dictionary<string, object> data, string key)
    {
        if (!data.TryGetValue(key, out var value) || value == null)
        {
            return "";
        }

        return value.ToString()?.Trim() ?? "";
    }

    private static string FirstNonEmpty(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value.Trim();
            }
        }

        return "";
    }

    private static string NormalizeClassName(string value)
    {
        var original = (value ?? "").Trim();

        if (string.IsNullOrWhiteSpace(original))
        {
            return "";
        }

        var text = original
            .ToUpperInvariant()
            .Replace("SINIF", "")
            .Replace("SİNİF", "")
            .Replace("ŞUBE", "")
            .Replace("SUBE", "")
            .Replace("_", "-")
            .Replace("/", "-")
            .Replace("\\", "-")
            .Replace(".", "-")
            .Replace(" ", "");

        var digits = new string(text.TakeWhile(char.IsDigit).ToArray());
        var letters = text.Length > digits.Length ? text.Substring(digits.Length) : "";

        if (!string.IsNullOrWhiteSpace(digits) && !string.IsNullOrWhiteSpace(letters))
        {
            return $"{digits}-{letters[0]}";
        }

        return original.ToUpperInvariant();
    }

    private static string Normalize(string value)
    {
        return (value ?? "")
            .Trim()
            .ToLowerInvariant()
            .Replace("ı", "i")
            .Replace("ğ", "g")
            .Replace("ü", "u")
            .Replace("ş", "s")
            .Replace("ö", "o")
            .Replace("ç", "c");
    }
}
