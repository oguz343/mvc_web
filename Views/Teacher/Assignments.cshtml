@model List<AssignmentViewModel>

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Ödevlerim";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="page-actions">
    <a class="btn btn-teacher" asp-controller="Teacher" asp-action="CreateAssignment">
        📝 Yeni Ödev Oluştur
    </a>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📝</div>
        <div class="empty-title">Henüz ödev vermediniz</div>
        <div class="empty-text">Size atanmış derslere ödev oluşturarak başlayabilirsiniz.</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var item in Model)
        {
            var statusBadge = item.Status == "Aktif"
                ? "badge-green"
                : item.Status == "Pasif"
                    ? "badge-red"
                    : "badge-orange";

            <div class="data-card">
                <div class="data-card-header">
                    <div class="data-card-icon">📝</div>
                    <div>
                        <div class="data-card-title">@item.Title</div>
                        <div class="data-card-subtitle">@item.Lesson • @item.ClassName</div>
                    </div>
                </div>

                <div class="badge-row">
                    <span class="badge badge-cyan">@item.Lesson</span>
                    <span class="badge badge-purple">@item.ClassName</span>
                    <span class="badge @statusBadge">@item.Status</span>
                </div>

                <div class="info-line">
                    <span>📅</span>
                    <span>Son teslim: <strong>@item.DueDate</strong></span>
                </div>

                <div class="info-line">
                    <span>📎</span>
                    <span>Tür: @item.Type</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(item.Description))
                {
                    <div class="announcement-preview">@item.Description</div>
                }

                <div class="card-actions">
                    <a class="btn btn-light"
                       asp-controller="Teacher"
                       asp-action="EditAssignment"
                       asp-route-id="@item.Id">
                        ✏️ Düzenle
                    </a>

                    <a class="btn btn-success" asp-controller="Teacher" asp-action="Submissions">
                        📤 Teslimler
                    </a>

                    <form asp-controller="Teacher"
                          asp-action="DeleteAssignment"
                          method="post"
                          onsubmit="return confirmDelete('Ödev silinsin mi?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-danger" type="submit">
                            🗑️ Sil
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}