@using System.Collections
@using System.Reflection
@model IEnumerable<object>

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Teslimler";
    ViewData["PageTitle"] = "Teslimler";
    ViewData["PageSubtitle"] = "Öğrencilerden gelen ödev teslimlerini inceleyin ve değerlendirin.";

    var submissions = (Model ?? Enumerable.Empty<object>()).ToList();

    if (!submissions.Any())
    {
        submissions = ListFrom(ViewData["Submissions"] ?? ViewData["RecentSubmissions"] ?? ViewData["LastSubmissions"]);
    }

    var totalCount = submissions.Count;
    var evaluatedCount = submissions.Count(IsEvaluated);
    var waitingCount = Math.Max(0, totalCount - evaluatedCount);
    var linkedCount = submissions.Count(x => !string.IsNullOrWhiteSpace(First(Get(x, "submissionFileUrl", "SubmissionFileUrl"), Get(x, "fileUrl", "FileUrl"), Get(x, "link", "Link"), Get(x, "answerLink", "AnswerLink"))));
    var classOptions = submissions
        .Select(x => First(Get(x, "className", "ClassName"), Get(x, "class", "Class"), Get(x, "targetClass", "TargetClass")))
        .Where(x => !string.IsNullOrWhiteSpace(x) && x != "-")
        .Distinct()
        .OrderBy(x => x)
        .ToList();
}

@functions {
    private List<object> ListFrom(object? raw)
    {
        if (raw == null || raw is string)
        {
            return new List<object>();
        }

        if (raw is IEnumerable enumerable)
        {
            return enumerable.Cast<object>().ToList();
        }

        return new List<object>();
    }

    private string Get(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);
                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string First(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private string Safe(string value, string fallback = "-")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private bool IsEvaluated(object item)
    {
        var status = Get(item, "status", "Status");
        var grade = First(Get(item, "grade", "Grade"), Get(item, "score", "Score"), Get(item, "point", "Point"), Get(item, "not", "Not"));
        var feedback = First(Get(item, "feedback", "Feedback"), Get(item, "comment", "Comment"), Get(item, "geriDonus", "GeriDonus"));

        return status.Contains("Değerlendir", StringComparison.OrdinalIgnoreCase)
            || status.Contains("Degerlendir", StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(grade)
            || !string.IsNullOrWhiteSpace(feedback);
    }

    private string DateText(string value)
    {
        return DateTime.TryParse(value, out var parsed)
            ? parsed.ToString("dd.MM.yyyy HH:mm")
            : Safe(value);
    }
}

<style>
    .teacher-sub-v2 {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .teacher-sub-hero,
    .teacher-sub-toolbar,
    .teacher-sub-card,
    .teacher-sub-empty {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .teacher-sub-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
    }

    .teacher-sub-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56,189,248,.10);
        border: 1px solid rgba(103,232,249,.20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .teacher-sub-hero h1 {
        margin: 14px 0 0;
        color: #fff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .teacher-sub-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .teacher-sub-summary {
        display: grid;
        grid-template-columns: repeat(2, minmax(0,1fr));
        gap: 10px;
    }

    .teacher-sub-summary-card {
        min-height: 106px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(255,255,255,.055);
        border: 1px solid rgba(148,163,184,.16);
    }

    .teacher-sub-summary-card strong {
        display: block;
        color: #fff;
        font-size: 30px;
        font-weight: 950;
    }

    .teacher-sub-summary-card span {
        display: block;
        margin-top: 6px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .teacher-sub-toolbar {
        display: grid;
        grid-template-columns: minmax(0,1fr) 220px auto;
        gap: 14px;
        padding: 16px;
        border-radius: 28px;
    }

    .teacher-sub-search {
        min-height: 54px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 15px;
        border-radius: 18px;
        background: rgba(7,17,31,.58);
        border: 1px solid rgba(148,163,184,.18);
    }

    .teacher-sub-search input {
        width: 100%;
        border: 0;
        outline: 0;
        color: #fff;
        background: transparent;
        font-size: 14px;
        font-weight: 800;
    }

    .teacher-sub-search input::placeholder {
        color: #64748b;
    }

    .teacher-sub-class-filter {
        min-height: 54px;
        padding: 0 13px;
        border-radius: 18px;
        color: #ffffff;
        background: rgba(7,17,31,.58);
        border: 1px solid rgba(148,163,184,.18);
        outline: none;
        font-size: 14px;
        font-weight: 850;
    }

    .teacher-sub-class-filter option {
        color: #0f172a;
        background: #ffffff;
    }

    .teacher-sub-visible {
        min-width: 170px;
        min-height: 54px;
        display: grid;
        align-content: center;
        padding: 0 15px;
        border-radius: 18px;
        color: #dbeafe;
        background: rgba(255,255,255,.055);
        border: 1px solid rgba(148,163,184,.16);
    }

    .teacher-sub-visible strong {
        color: #fff;
        font-size: 24px;
        font-weight: 950;
    }

    .teacher-sub-visible span {
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .teacher-sub-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(390px, 1fr));
        gap: 16px;
    }

    .teacher-sub-card {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-height: 100%;
        padding: 20px;
        border-radius: 28px;
        transition: .16s ease;
    }

    .teacher-sub-card:hover {
        transform: translateY(-2px);
        border-color: rgba(125,211,252,.28);
        box-shadow: 0 22px 54px rgba(0,0,0,.27);
    }

    .teacher-sub-top {
        display: grid;
        grid-template-columns: 58px minmax(0,1fr) auto;
        gap: 13px;
        align-items: center;
    }

    .teacher-sub-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        border-radius: 20px;
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 26px;
    }

    .teacher-sub-title h3 {
        margin: 0;
        color: #fff;
        font-size: 18px;
        font-weight: 950;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .teacher-sub-title p {
        margin: 5px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .teacher-sub-status {
        min-height: 31px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .teacher-sub-status.evaluated {
        color: #bfdbfe;
        background: rgba(37,99,235,.14);
        border-color: rgba(96,165,250,.20);
    }

    .teacher-sub-status.waiting {
        color: #fde68a;
        background: rgba(245,158,11,.13);
        border-color: rgba(251,191,36,.18);
    }

    .teacher-sub-info {
        display: grid;
        gap: 9px;
    }

    .teacher-sub-row {
        display: grid;
        grid-template-columns: 28px minmax(110px,.68fr) minmax(0,1fr);
        gap: 9px;
        align-items: center;
        padding: 10px 11px;
        border-radius: 16px;
        color: #94a3b8;
        background: rgba(255,255,255,.045);
        border: 1px solid rgba(148,163,184,.12);
        font-size: 13px;
        font-weight: 750;
    }

    .teacher-sub-row strong {
        color: #dbeafe;
        font-weight: 950;
    }

    .teacher-sub-row b {
        color: #fff;
        font-weight: 900;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .teacher-sub-answer,
    .teacher-sub-grade {
        display: grid;
        gap: 8px;
        padding: 14px;
        border-radius: 18px;
        background: rgba(255,255,255,.045);
        border: 1px solid rgba(148,163,184,.12);
    }

    .teacher-sub-answer strong,
    .teacher-sub-grade strong {
        color: #dbeafe;
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .teacher-sub-answer p,
    .teacher-sub-grade p {
        margin: 0;
        color: #cbd5e1;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.6;
        overflow-wrap: anywhere;
    }

    .teacher-sub-link,
    .teacher-sub-evaluate {
        width: fit-content;
        min-height: 38px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 12px;
        border-radius: 13px;
        text-decoration: none;
        font-size: 12px;
        font-weight: 950;
    }

    .teacher-sub-link {
        color: #67e8f9;
        background: rgba(56,189,248,.10);
        border: 1px solid rgba(103,232,249,.20);
    }

    .teacher-sub-evaluate {
        width: 100%;
        color: #fff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: 1px solid rgba(125,211,252,.22);
    }

    .teacher-sub-empty {
        min-height: 320px;
        display: grid;
        place-items: center;
        padding: 42px 24px;
        border-radius: 30px;
        color: #94a3b8;
        text-align: center;
        font-size: 15px;
        font-weight: 850;
    }

    @@media (max-width: 1100px) {
        .teacher-sub-hero,
        .teacher-sub-toolbar {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .teacher-sub-hero,
        .teacher-sub-card,
        .teacher-sub-empty {
            border-radius: 22px;
            padding: 16px;
        }

        .teacher-sub-summary,
        .teacher-sub-grid {
            grid-template-columns: 1fr;
        }

        .teacher-sub-top {
            grid-template-columns: 54px minmax(0,1fr);
        }

        .teacher-sub-status {
            grid-column: 1 / -1;
            justify-self: start;
        }

        .teacher-sub-row {
            grid-template-columns: 24px minmax(0,1fr);
        }

        .teacher-sub-row b {
            grid-column: 1 / -1;
            text-align: left;
        }
    }
</style>

<div class="teacher-sub-v2">
    <section class="teacher-sub-hero">
        <div>
            <div class="teacher-sub-kicker">Teslim Merkezi</div>

            <h1>Öğrenci teslimlerini değerlendirin.</h1>

            <p>
                Gelen ödev cevaplarını, dosya/linkleri ve değerlendirme durumlarını tek ekranda görün.
            </p>
        </div>

        <div class="teacher-sub-summary">
            <div class="teacher-sub-summary-card">
                <strong>@totalCount</strong>
                <span>Toplam Teslim</span>
            </div>

            <div class="teacher-sub-summary-card">
                <strong>@evaluatedCount</strong>
                <span>Değerlendirilen</span>
            </div>

            <div class="teacher-sub-summary-card">
                <strong>@waitingCount</strong>
                <span>Bekleyen</span>
            </div>

            <div class="teacher-sub-summary-card">
                <strong>@linkedCount</strong>
                <span>Dosya / Link</span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <section class="teacher-sub-toolbar">
        <div class="teacher-sub-search">
            <span>🔍</span>
            <input id="teacherSubmissionSearchInput" type="search" placeholder="Ödev, öğrenci no, sınıf veya ders ara..." autocomplete="off" />
        </div>

        <select id="teacherSubmissionClassFilter" class="teacher-sub-class-filter">
            <option value="">Tum siniflar</option>
            @foreach (var className in classOptions)
            {
                <option value="@className">@className</option>
            }
        </select>

        <div class="teacher-sub-visible">
            <strong id="visibleTeacherSubmissionCount">@submissions.Count</strong>
            <span>teslim gösteriliyor</span>
        </div>
    </section>

    @if (!submissions.Any())
    {
        <div class="teacher-sub-empty">
            Henüz öğrenci teslimi yok.
        </div>
    }
    else
    {
        <section class="teacher-sub-grid">
            @foreach (var item in submissions)
            {
                var id = First(Get(item, "Id", "id"), Get(item, "docId", "DocId"));
                var title = First(Get(item, "assignmentTitle", "AssignmentTitle"), Get(item, "homeworkTitle", "HomeworkTitle"), Get(item, "title", "Title"), Get(item, "name", "Name"), "Ödev");
                var studentNo = First(Get(item, "studentNo", "StudentNo"), Get(item, "studentNumber", "StudentNumber"), Get(item, "schoolNo", "SchoolNo"), Get(item, "number", "Number"), "-");
                var lesson = First(Get(item, "lessonName", "LessonName"), Get(item, "lesson", "Lesson"), Get(item, "courseName", "CourseName"), Get(item, "course", "Course"), "-");
                var className = First(Get(item, "className", "ClassName"), Get(item, "class", "Class"), Get(item, "targetClass", "TargetClass"), "-");
                var answer = First(Get(item, "answerText", "AnswerText"), Get(item, "answer", "Answer"), Get(item, "content", "Content"), Get(item, "submissionText", "SubmissionText"), "Öğrenci açıklama yazmamış.");
                var link = First(Get(item, "submissionFileUrl", "SubmissionFileUrl"), Get(item, "fileUrl", "FileUrl"), Get(item, "link", "Link"), Get(item, "answerLink", "AnswerLink"));
                var grade = First(Get(item, "grade", "Grade"), Get(item, "score", "Score"), Get(item, "point", "Point"), Get(item, "not", "Not"));
                var feedback = First(Get(item, "feedback", "Feedback"), Get(item, "comment", "Comment"), Get(item, "geriDonus", "GeriDonus"));
                var submittedAt = First(Get(item, "submittedAt", "SubmittedAt"), Get(item, "createdAt", "CreatedAt"));
                var evaluated = IsEvaluated(item);

                <article class="teacher-sub-card"
                         data-class="@className"
                         data-search="@($"{title} {studentNo} {lesson} {className} {answer}")">

                    <div class="teacher-sub-top">
                        <div class="teacher-sub-icon">📥</div>

                        <div class="teacher-sub-title">
                            <h3>@title</h3>
                            <p>Öğrenci No: @studentNo</p>
                        </div>

                        <span class="teacher-sub-status @(evaluated ? "evaluated" : "waiting")">
                            @(evaluated ? "Değerlendirildi" : "Bekliyor")
                        </span>
                    </div>

                    <div class="teacher-sub-info">
                        <div class="teacher-sub-row">
                            <span>📚</span>
                            <strong>Ders</strong>
                            <b>@lesson</b>
                        </div>

                        <div class="teacher-sub-row">
                            <span>🏫</span>
                            <strong>Sınıf</strong>
                            <b>@className</b>
                        </div>

                        <div class="teacher-sub-row">
                            <span>⏰</span>
                            <strong>Teslim</strong>
                            <b>@DateText(submittedAt)</b>
                        </div>
                    </div>

                    <div class="teacher-sub-answer">
                        <strong>Öğrenci Cevabı</strong>
                        <p>@answer</p>

                        @if (!string.IsNullOrWhiteSpace(link))
                        {
                            <a href="@link" target="_blank" rel="noopener noreferrer" class="teacher-sub-link">
                                Dosya / Link Aç
                            </a>
                        }
                    </div>

                    <div class="teacher-sub-grade">
                        <strong>Değerlendirme</strong>
                        <p><b>Not:</b> @Safe(grade)</p>
                        <p><b>Geri dönüş:</b> @Safe(feedback)</p>
                    </div>

                    <a asp-controller="Teacher"
                       asp-action="GradeSubmission"
                       asp-route-id="@id"
                       class="teacher-sub-evaluate">
                        ✅ Değerlendir
                    </a>
                </article>
            }
        </section>

        <div id="noTeacherSubmissionResult" class="teacher-sub-empty" style="display:none;">
            Aradığınız kritere uygun teslim bulunamadı.
        </div>
    }
</div>

@section Scripts {
    <script>
        const teacherSubmissionSearchInput = document.getElementById("teacherSubmissionSearchInput");
        const teacherSubmissionClassFilter = document.getElementById("teacherSubmissionClassFilter");
        const teacherSubmissionCards = Array.from(document.querySelectorAll(".teacher-sub-card"));
        const visibleTeacherSubmissionCount = document.getElementById("visibleTeacherSubmissionCount");
        const noTeacherSubmissionResult = document.getElementById("noTeacherSubmissionResult");

        function normalizeTeacherSubmissionText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterTeacherSubmissions() {
            const query = normalizeTeacherSubmissionText(teacherSubmissionSearchInput?.value || "");
            const selectedClass = normalizeTeacherSubmissionText(teacherSubmissionClassFilter?.value || "");
            let count = 0;

            teacherSubmissionCards.forEach(card => {
                const searchable = normalizeTeacherSubmissionText(card.dataset.search || "");
                const cardClass = normalizeTeacherSubmissionText(card.dataset.class || "");
                const matchesQuery = query === "" || searchable.includes(query);
                const matchesClass = selectedClass === "" || cardClass === selectedClass;
                const show = matchesQuery && matchesClass;

                card.style.display = show ? "" : "none";

                if (show) {
                    count++;
                }
            });

            if (visibleTeacherSubmissionCount) {
                visibleTeacherSubmissionCount.textContent = count;
            }

            if (noTeacherSubmissionResult) {
                noTeacherSubmissionResult.style.display = count === 0 ? "grid" : "none";
            }
        }

        if (teacherSubmissionSearchInput) {
            teacherSubmissionSearchInput.addEventListener("input", filterTeacherSubmissions);
            teacherSubmissionSearchInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        if (teacherSubmissionClassFilter) {
            teacherSubmissionClassFilter.addEventListener("change", filterTeacherSubmissions);
        }

        filterTeacherSubmissions();
    </script>
}
