@using System.Collections
@using System.Reflection

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Öğretmen Paneli";
    ViewData["PageTitle"] = "Öğretmen Paneli";
    ViewData["PageSubtitle"] = "Derslerinizi, ödevlerinizi ve öğrenci teslimlerini tek ekranda takip edin.";

    var teacherName = Text(ViewData["TeacherName"], "Öğretmen");
    var teacherNo = Text(ViewData["TeacherNo"], "-");
    var teacherBranch = Text(ViewData["TeacherBranch"], "-");

    var lessons = ListFrom(ViewData["Lessons"] ?? ViewData["TeacherLessons"] ?? ViewData["MyLessons"]);
    var assignments = ListFrom(ViewData["Assignments"] ?? ViewData["Homeworks"] ?? ViewData["TeacherAssignments"] ?? ViewData["MyAssignments"]);
    var submissions = ListFrom(ViewData["Submissions"] ?? ViewData["RecentSubmissions"] ?? ViewData["LastSubmissions"]);

    var lessonCount = IntValue(ViewData["LessonCount"], lessons.Count);
    var assignmentCount = IntValue(ViewData["AssignmentCount"], assignments.Count);
    var submissionCount = IntValue(ViewData["SubmissionCount"], submissions.Count);
    var evaluatedCount = IntValue(ViewData["EvaluatedCount"], submissions.Count(IsEvaluated));
    var waitingCount = Math.Max(0, submissionCount - evaluatedCount);
}

@functions {
    private List<object> ListFrom(object? raw)
    {
        if (raw == null || raw is string)
        {
            return new List<object>();
        }

        if (raw is IEnumerable enumerable)
        {
            return enumerable.Cast<object>().ToList();
        }

        return new List<object>();
    }

    private string Text(object? value, string fallback = "-")
    {
        var result = value?.ToString() ?? "";
        return string.IsNullOrWhiteSpace(result) ? fallback : result;
    }

    private int IntValue(object? value, int fallback = 0)
    {
        return int.TryParse(value?.ToString(), out var parsed) ? parsed : fallback;
    }

    private string Get(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);
                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string First(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private bool IsEvaluated(object item)
    {
        var status = Get(item, "status", "Status");
        var grade = First(Get(item, "grade", "Grade"), Get(item, "score", "Score"), Get(item, "point", "Point"), Get(item, "not", "Not"));
        var feedback = First(Get(item, "feedback", "Feedback"), Get(item, "comment", "Comment"), Get(item, "geriDonus", "GeriDonus"));

        return status.Contains("Değerlendir", StringComparison.OrdinalIgnoreCase)
            || status.Contains("Degerlendir", StringComparison.OrdinalIgnoreCase)
            || !string.IsNullOrWhiteSpace(grade)
            || !string.IsNullOrWhiteSpace(feedback);
    }

    private string DateText(object? value)
    {
        if (value == null)
        {
            return "-";
        }

        if (value is DateTime date)
        {
            return date.ToString("dd.MM.yyyy HH:mm");
        }

        return DateTime.TryParse(value.ToString(), out var parsed)
            ? parsed.ToString("dd.MM.yyyy HH:mm")
            : "-";
    }
}

<style>
    .teacher-v2 {
        display: grid;
        gap: 18px;
        width: 100%;
    }

    .teacher-v2-hero,
    .teacher-v2-panel,
    .teacher-v2-card,
    .teacher-v2-stat {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .teacher-v2-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
    }

    .teacher-v2-hero::after {
        content: "";
        position: absolute;
        width: 390px;
        height: 390px;
        right: -190px;
        top: -190px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .22);
        pointer-events: none;
    }

    .teacher-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .teacher-v2-hero h1 {
        max-width: 820px;
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .teacher-v2-hero p {
        max-width: 760px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .teacher-v2-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .teacher-v2-primary,
    .teacher-v2-soft {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 15px;
        border-radius: 15px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        transition: .16s ease;
    }

    .teacher-v2-primary {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: 1px solid rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .teacher-v2-soft {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border: 1px solid rgba(148, 163, 184, .18);
    }

    .teacher-v2-primary:hover,
    .teacher-v2-soft:hover {
        transform: translateY(-1px);
    }

    .teacher-v2-profile {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 12px;
    }

    .teacher-v2-profile-card {
        padding: 18px;
        border-radius: 24px;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .teacher-v2-profile-card strong {
        display: block;
        color: #ffffff;
        font-size: 28px;
        font-weight: 950;
        letter-spacing: -.04em;
    }

    .teacher-v2-profile-card span {
        display: block;
        margin-top: 7px;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .teacher-v2-mini-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .teacher-v2-mini {
        min-height: 86px;
        padding: 14px;
        border-radius: 20px;
        background: rgba(255, 255, 255, .050);
        border: 1px solid rgba(148, 163, 184, .14);
    }

    .teacher-v2-mini strong {
        display: block;
        color: #ffffff;
        font-size: 24px;
        font-weight: 950;
    }

    .teacher-v2-mini span {
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .teacher-v2-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(170px, 1fr));
        gap: 14px;
    }

    .teacher-v2-stat {
        min-height: 122px;
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 18px;
        border-radius: 25px;
    }

    .teacher-v2-stat-icon {
        width: 54px;
        height: 54px;
        flex: 0 0 54px;
        display: grid;
        place-items: center;
        border-radius: 19px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 24px;
    }

    .teacher-v2-stat strong {
        display: block;
        color: #ffffff;
        font-size: 32px;
        font-weight: 950;
        line-height: 1;
    }

    .teacher-v2-stat span {
        display: block;
        margin-top: 6px;
        color: #aab8cf;
        font-size: 13px;
        font-weight: 850;
    }

    .teacher-v2-main-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(340px, .65fr);
        gap: 18px;
        align-items: start;
    }

    .teacher-v2-panel {
        padding: 20px;
        border-radius: 28px;
    }

    .teacher-v2-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        margin-bottom: 14px;
        padding-bottom: 14px;
        border-bottom: 1px solid rgba(148, 163, 184, .14);
    }

    .teacher-v2-panel-head h2 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
        letter-spacing: -.025em;
    }

    .teacher-v2-panel-head p {
        margin: 5px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
    }

    .teacher-v2-list {
        display: grid;
        gap: 10px;
    }

    .teacher-v2-row {
        display: grid;
        grid-template-columns: 46px minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        padding: 12px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
    }

    .teacher-v2-row-icon {
        width: 46px;
        height: 46px;
        display: grid;
        place-items: center;
        border-radius: 16px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 21px;
    }

    .teacher-v2-row-title {
        color: #ffffff;
        font-size: 14px;
        font-weight: 950;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .teacher-v2-row-text {
        margin-top: 4px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 800;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .teacher-v2-pill {
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        border-radius: 999px;
        color: #bfdbfe;
        background: rgba(37, 99, 235, .14);
        border: 1px solid rgba(96, 165, 250, .20);
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
    }

    .teacher-v2-empty {
        min-height: 170px;
        display: grid;
        place-items: center;
        text-align: center;
        padding: 24px;
        border-radius: 20px;
        color: #94a3b8;
        background: rgba(255, 255, 255, .040);
        border: 1px dashed rgba(148, 163, 184, .20);
        font-weight: 850;
        line-height: 1.55;
    }

    @@media (max-width: 1180px) {
        .teacher-v2-hero,
        .teacher-v2-main-grid {
            grid-template-columns: 1fr;
        }

        .teacher-v2-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 680px) {
        .teacher-v2-hero,
        .teacher-v2-panel {
            border-radius: 22px;
            padding: 16px;
        }

        .teacher-v2-stats,
        .teacher-v2-mini-grid {
            grid-template-columns: 1fr;
        }

        .teacher-v2-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .teacher-v2-primary,
        .teacher-v2-soft {
            width: 100%;
        }

        .teacher-v2-row {
            grid-template-columns: 44px minmax(0, 1fr);
        }

        .teacher-v2-pill {
            grid-column: 1 / -1;
            justify-self: start;
        }
    }
</style>

<div class="teacher-v2">
    <section class="teacher-v2-hero">
        <div>
            <div class="teacher-v2-kicker">Öğretmen Merkezi</div>

            <h1>Merhaba, @teacherName</h1>

            <p>
                Size atanmış dersleri, oluşturduğunuz ödevleri ve gelen öğrenci teslimlerini
                koyu tema ile daha düzenli şekilde takip edin.
            </p>

            <div class="teacher-v2-actions">
                <a asp-controller="Teacher" asp-action="CreateAssignment" class="teacher-v2-primary">
                    📝 Yeni Ödev Oluştur
                </a>

                <a asp-controller="Teacher" asp-action="Assignments" class="teacher-v2-soft">
                    📚 Ödevlerim
                </a>

                <a asp-controller="Teacher" asp-action="Submissions" class="teacher-v2-soft">
                    📥 Teslimler
                </a>
            </div>
        </div>

        <div class="teacher-v2-profile">
            <div class="teacher-v2-profile-card">
                <strong>@teacherBranch</strong>
                <span>Branş / Alan</span>
            </div>

            <div class="teacher-v2-mini-grid">
                <div class="teacher-v2-mini">
                    <strong>@teacherNo</strong>
                    <span>Öğretmen No</span>
                </div>

                <div class="teacher-v2-mini">
                    <strong>@lessonCount</strong>
                    <span>Atanmış Ders</span>
                </div>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <section class="teacher-v2-stats">
        <div class="teacher-v2-stat">
            <div class="teacher-v2-stat-icon">📚</div>
            <div>
                <strong>@lessonCount</strong>
                <span>Ders Ataması</span>
            </div>
        </div>

        <div class="teacher-v2-stat">
            <div class="teacher-v2-stat-icon">📝</div>
            <div>
                <strong>@assignmentCount</strong>
                <span>Ödev</span>
            </div>
        </div>

        <div class="teacher-v2-stat">
            <div class="teacher-v2-stat-icon">📥</div>
            <div>
                <strong>@submissionCount</strong>
                <span>Teslim</span>
            </div>
        </div>

        <div class="teacher-v2-stat">
            <div class="teacher-v2-stat-icon">✅</div>
            <div>
                <strong>@evaluatedCount</strong>
                <span>Değerlendirilen</span>
            </div>
        </div>
    </section>

    <section class="teacher-v2-main-grid">
        <div class="teacher-v2-panel">
            <div class="teacher-v2-panel-head">
                <div>
                    <h2>Son Teslimler</h2>
                    <p>Öğrencilerden gelen en son teslimler.</p>
                </div>

                <a asp-controller="Teacher" asp-action="Submissions" class="teacher-v2-soft">
                    Tümü
                </a>
            </div>

            @if (!submissions.Any())
            {
                <div class="teacher-v2-empty">
                    Henüz öğrenci teslimi yok.
                </div>
            }
            else
            {
                <div class="teacher-v2-list">
                    @foreach (var item in submissions.Take(5))
                    {
                        var title = First(Get(item, "assignmentTitle", "AssignmentTitle"), Get(item, "homeworkTitle", "HomeworkTitle"), Get(item, "title", "Title"), "Ödev");
                        var studentNo = First(Get(item, "studentNo", "StudentNo"), Get(item, "number", "Number"), "-");
                        var className = First(Get(item, "className", "ClassName"), Get(item, "class", "Class"), "-");
                        var evaluated = IsEvaluated(item);

                        <div class="teacher-v2-row">
                            <div class="teacher-v2-row-icon">📥</div>

                            <div>
                                <div class="teacher-v2-row-title">@title</div>
                                <div class="teacher-v2-row-text">Öğrenci No: @studentNo · Sınıf: @className</div>
                            </div>

                            <span class="teacher-v2-pill">
                                @(evaluated ? "Değerlendirildi" : "Bekliyor")
                            </span>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="teacher-v2-panel">
            <div class="teacher-v2-panel-head">
                <div>
                    <h2>Hızlı İşlemler</h2>
                    <p>Sık kullanılan öğretmen işlemleri.</p>
                </div>
            </div>

            <div class="teacher-v2-list">
                <a asp-controller="Teacher" asp-action="CreateAssignment" class="teacher-v2-row" style="text-decoration:none;">
                    <div class="teacher-v2-row-icon">📝</div>
                    <div>
                        <div class="teacher-v2-row-title">Yeni Ödev Oluştur</div>
                        <div class="teacher-v2-row-text">Ders ve sınıf seçerek yeni ödev yayınla.</div>
                    </div>
                    <span class="teacher-v2-pill">Git</span>
                </a>

                <a asp-controller="Teacher" asp-action="Assignments" class="teacher-v2-row" style="text-decoration:none;">
                    <div class="teacher-v2-row-icon">📚</div>
                    <div>
                        <div class="teacher-v2-row-title">Ödevlerimi Gör</div>
                        <div class="teacher-v2-row-text">Aktif ödevleri düzenle veya sil.</div>
                    </div>
                    <span class="teacher-v2-pill">Git</span>
                </a>

                <a asp-controller="Teacher" asp-action="Submissions" class="teacher-v2-row" style="text-decoration:none;">
                    <div class="teacher-v2-row-icon">✅</div>
                    <div>
                        <div class="teacher-v2-row-title">Teslimleri Değerlendir</div>
                        <div class="teacher-v2-row-text">@waitingCount teslim değerlendirme bekliyor.</div>
                    </div>
                    <span class="teacher-v2-pill">Git</span>
                </a>
            </div>
        </div>
    </section>
</div>