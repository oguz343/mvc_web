@using System.Reflection
@model List<mvc_web.Models.SubmissionViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Teslimler";

    var submissions = Model ?? new List<mvc_web.Models.SubmissionViewModel>();
    var totalCount = submissions.Count;
    var completedCount = submissions.Count(x => IsEvaluated(x));
    var pendingCount = totalCount - completedCount;
}

@functions {
    private string GetText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(
                key,
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase
            );

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string FirstNonEmpty(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private bool IsEvaluated(object item)
    {
        var status = GetText(item, "Status");
        var grade = GetText(item, "Grade", "Score", "Point", "Not");
        var feedback = GetText(item, "Feedback", "Comment", "GeriDonus");

        return status.ToLower().Contains("değer") ||
               status.ToLower().Contains("deger") ||
               !string.IsNullOrWhiteSpace(grade) ||
               !string.IsNullOrWhiteSpace(feedback);
    }
}

<div class="page-shell">
    <section class="page-header-card">
        <div>
            <div class="eyebrow">Yönetim Paneli</div>
            <h1>Teslimler</h1>
            <p>Öğrenci teslimlerini buradan görüntüleyebilir, kontrol edebilir ve gerekirse silebilirsiniz.</p>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <section class="stats-grid">
        <article class="stat-card">
            <div class="stat-icon primary">📤</div>
            <div>
                <h3>@totalCount</h3>
                <p>Toplam Teslim</p>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon success">✅</div>
            <div>
                <h3>@completedCount</h3>
                <p>Değerlendirildi</p>
            </div>
        </article>

        <article class="stat-card">
            <div class="stat-icon warning">⏳</div>
            <div>
                <h3>@pendingCount</h3>
                <p>Bekleyen</p>
            </div>
        </article>
    </section>

    @if (!submissions.Any())
    {
        <div class="empty-state">
            Henüz teslim bulunmuyor.
        </div>
    }
    else
    {
        <section class="table-card">
            <div class="table-card-header">
                <div>
                    <h3>Teslim Listesi</h3>
                    <p>Notlandırma ve geri dönüş öğretmen panelinden yapılır.</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="premium-table">
                    <thead>
                        <tr>
                            <th>Ödev</th>
                            <th>Ders / Sınıf</th>
                            <th>Öğrenci No</th>
                            <th>Öğretmen</th>
                            <th>Cevap</th>
                            <th>Link</th>
                            <th>Durum</th>
                            <th>Not</th>
                            <th>Geri Dönüş</th>
                            <th>İşlem</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in submissions)
                        {
                            var id = GetText(item, "Id");

                            var assignmentTitle = FirstNonEmpty(
                                GetText(item, "AssignmentTitle"),
                                GetText(item, "HomeworkTitle"),
                                GetText(item, "Title"),
                                GetText(item, "AssignmentName"),
                                "Ödev"
                            );

                            var lessonName = FirstNonEmpty(
                                GetText(item, "LessonName"),
                                GetText(item, "Lesson"),
                                GetText(item, "CourseName"),
                                GetText(item, "Course"),
                                "-"
                            );

                            var className = FirstNonEmpty(
                                GetText(item, "ClassName"),
                                GetText(item, "Class"),
                                GetText(item, "TargetClass"),
                                "-"
                            );

                            var studentNo = FirstNonEmpty(
                                GetText(item, "StudentNo"),
                                GetText(item, "StudentNumber"),
                                GetText(item, "SchoolNo"),
                                GetText(item, "Number"),
                                "-"
                            );

                            var teacherName = FirstNonEmpty(
                                GetText(item, "TeacherName"),
                                GetText(item, "Teacher"),
                                "-"
                            );

                            var answer = FirstNonEmpty(
                                GetText(item, "AnswerText"),
                                GetText(item, "Answer"),
                                GetText(item, "Content"),
                                GetText(item, "Text"),
                                "-"
                            );

                            var answerLink = FirstNonEmpty(
                                GetText(item, "AnswerLink"),
                                GetText(item, "FileUrl"),
                                GetText(item, "SubmissionFileUrl"),
                                GetText(item, "Link"),
                                GetText(item, "Url")
                            );

                            var status = FirstNonEmpty(
                                GetText(item, "Status"),
                                IsEvaluated(item) ? "Değerlendirildi" : "Bekliyor"
                            );

                            var score = FirstNonEmpty(
                                GetText(item, "Score"),
                                GetText(item, "Grade"),
                                GetText(item, "Point"),
                                GetText(item, "Not"),
                                "-"
                            );

                            var feedback = FirstNonEmpty(
                                GetText(item, "Feedback"),
                                GetText(item, "Comment"),
                                GetText(item, "GeriDonus"),
                                "-"
                            );

                            <tr>
                                <td>
                                    <strong>@assignmentTitle</strong>
                                </td>

                                <td>
                                    @lessonName
                                    <br />
                                    <span style="color:#64748b;">@className</span>
                                </td>

                                <td>@studentNo</td>

                                <td>@teacherName</td>

                                <td>@answer</td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(answerLink))
                                    {
                                        <a href="@answerLink" target="_blank" class="table-link">Linki Aç</a>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>
                                    @if (IsEvaluated(item))
                                    {
                                        <span class="badge-pill badge-success">@status</span>
                                    }
                                    else
                                    {
                                        <span class="badge-pill badge-warning">@status</span>
                                    }
                                </td>

                                <td>@score</td>

                                <td>@feedback</td>

                                <td>
                                    <form asp-controller="Submissions"
                                          asp-action="Delete"
                                          method="post"
                                          class="inline-form js-delete-form"
                                          data-delete-name="@assignmentTitle">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@id" />
                                        <button type="submit" class="btn-danger">🗑️ Sil</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>