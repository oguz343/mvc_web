@using System.Reflection
@model List<mvc_web.Models.SubmissionViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Teslimler";
    ViewData["PageTitle"] = "Teslimler";
    ViewData["PageSubtitle"] = "Öğrenci ödev teslimlerini, cevapları, linkleri ve değerlendirme durumlarını koyu tema ile takip edin.";

    var submissions = Model ?? new List<mvc_web.Models.SubmissionViewModel>();
    var totalCount = submissions.Count;
    var evaluatedCount = submissions.Count(x => IsEvaluated(x));
    var pendingCount = totalCount - evaluatedCount;
    var linkedCount = submissions.Count(x => !string.IsNullOrWhiteSpace(FirstNonEmpty(GetText(x, "Link"), GetText(x, "FileUrl"), GetText(x, "SubmissionFileUrl"))));
}

@functions {
    private string GetText(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(
                key,
                BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase
            );

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string FirstNonEmpty(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private bool IsEvaluated(object item)
    {
        var status = GetText(item, "Status");
        var grade = GetText(item, "Grade", "Score", "Point", "Not");
        var feedback = GetText(item, "Feedback", "Comment", "GeriDonus");

        return status.ToLower().Contains("değer") ||
               status.ToLower().Contains("deger") ||
               !string.IsNullOrWhiteSpace(grade) ||
               !string.IsNullOrWhiteSpace(feedback);
    }

    private string SafeText(string value, string fallback = "-")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }
}

<style>
    .submissions-v2 {
        width: 100%;
        max-width: none;
        display: grid;
        gap: 18px;
    }

    .submissions-v2-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .15), transparent 34%),
            radial-gradient(circle at 100% 0%, rgba(139, 92, 246, .18), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .94), rgba(17, 24, 39, .86));
        border: 1px solid rgba(148, 163, 184, .20);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .28);
        backdrop-filter: blur(18px);
    }

    .submissions-v2-hero::after {
        content: "";
        position: absolute;
        width: 390px;
        height: 390px;
        right: -180px;
        top: -190px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .22);
        pointer-events: none;
    }

    .submissions-v2-hero-main,
    .submissions-v2-hero-side {
        position: relative;
        z-index: 1;
    }

    .submissions-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .submissions-v2-hero h2 {
        max-width: 780px;
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .submissions-v2-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .submissions-v2-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .submissions-v2-soft-action {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 15px;
        border-radius: 15px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border: 1px solid rgba(148, 163, 184, .18);
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        transition: .16s ease;
    }

    .submissions-v2-soft-action:hover {
        transform: translateY(-1px);
    }

    .submissions-v2-hero-side {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .submissions-v2-summary-card {
        min-height: 106px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .submissions-v2-summary-card strong {
        display: block;
        color: #ffffff;
        font-size: 30px;
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.04em;
    }

    .submissions-v2-summary-card span {
        display: block;
        margin-top: 7px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .submissions-v2-alert {
        padding: 15px 17px;
        border-radius: 18px;
        font-weight: 850;
        line-height: 1.5;
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .submissions-v2-alert.success {
        color: #bbf7d0;
        background: rgba(34, 197, 94, .12);
        border-color: rgba(74, 222, 128, .20);
    }

    .submissions-v2-alert.error {
        color: #fecaca;
        background: rgba(239, 68, 68, .12);
        border-color: rgba(248, 113, 113, .20);
    }

    .submissions-v2-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px;
        padding: 16px;
        border-radius: 28px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .08), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .84));
        border: 1px solid rgba(148, 163, 184, .18);
        box-shadow: 0 16px 44px rgba(0, 0, 0, .20);
        backdrop-filter: blur(16px);
    }

    .submissions-v2-search {
        min-height: 54px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 15px;
        border-radius: 18px;
        background: rgba(7, 17, 31, .58);
        border: 1px solid rgba(148, 163, 184, .18);
        transition: .15s ease;
    }

    .submissions-v2-search:focus-within {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .submissions-v2-search input {
        width: 100%;
        border: 0;
        outline: 0;
        color: #ffffff;
        background: transparent;
        font-size: 14px;
        font-weight: 800;
    }

    .submissions-v2-search input::placeholder {
        color: #64748b;
    }

    .submissions-v2-visible-box {
        min-width: 170px;
        min-height: 54px;
        display: grid;
        align-content: center;
        padding: 0 15px;
        border-radius: 18px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .submissions-v2-visible-box strong {
        color: #ffffff;
        font-size: 24px;
        font-weight: 950;
        line-height: 1;
    }

    .submissions-v2-visible-box span {
        margin-top: 4px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .submissions-v2-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(390px, 1fr));
        gap: 16px;
    }

    .submissions-v2-card {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-height: 100%;
        padding: 20px;
        border-radius: 28px;
        background:
            radial-gradient(circle at 100% 0%, rgba(56, 189, 248, .075), transparent 36%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        border: 1px solid rgba(148, 163, 184, .18);
        box-shadow: 0 16px 44px rgba(0, 0, 0, .22);
        backdrop-filter: blur(16px);
        transition: .16s ease;
    }

    .submissions-v2-card:hover {
        transform: translateY(-2px);
        border-color: rgba(125, 211, 252, .28);
        box-shadow: 0 22px 54px rgba(0, 0, 0, .27);
    }

    .submissions-v2-card::after {
        content: "";
        position: absolute;
        width: 180px;
        height: 180px;
        right: -92px;
        top: -104px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .13);
        pointer-events: none;
    }

    .submissions-v2-top {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr) auto;
        gap: 13px;
        align-items: center;
    }

    .submissions-v2-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        border-radius: 20px;
        color: #ffffff;
        background:
            radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .28), transparent 28%),
            linear-gradient(135deg, #2563eb, #7c3aed 58%, #06b6d4);
        box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
        font-size: 26px;
    }

    .submissions-v2-title {
        min-width: 0;
    }

    .submissions-v2-title h3 {
        margin: 0;
        color: #ffffff;
        font-size: 18px;
        font-weight: 950;
        line-height: 1.2;
        letter-spacing: -.025em;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .submissions-v2-title p {
        margin: 5px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .submissions-v2-status {
        min-height: 31px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 950;
        white-space: nowrap;
        border: 1px solid transparent;
    }

    .submissions-v2-status.evaluated {
        color: #bfdbfe;
        background: rgba(37, 99, 235, .14);
        border-color: rgba(96, 165, 250, .20);
    }

    .submissions-v2-status.waiting {
        color: #fde68a;
        background: rgba(245, 158, 11, .13);
        border-color: rgba(251, 191, 36, .18);
    }

    .submissions-v2-details {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 9px;
    }

    .submissions-v2-detail-row {
        display: grid;
        grid-template-columns: 28px minmax(110px, .68fr) minmax(0, 1fr);
        gap: 9px;
        align-items: center;
        padding: 10px 11px;
        border-radius: 16px;
        color: #94a3b8;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 750;
    }

    .submissions-v2-detail-row strong {
        color: #dbeafe;
        font-weight: 950;
    }

    .submissions-v2-detail-row b {
        min-width: 0;
        color: #ffffff;
        font-weight: 900;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .submissions-v2-answer-box,
    .submissions-v2-grade-box {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 8px;
        padding: 14px;
        border-radius: 18px;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
    }

    .submissions-v2-answer-box strong,
    .submissions-v2-grade-box strong {
        color: #dbeafe;
        font-size: 12px;
        font-weight: 950;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .submissions-v2-answer-box p,
    .submissions-v2-grade-box p {
        margin: 0;
        color: #cbd5e1;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.6;
        overflow-wrap: anywhere;
    }

    .submissions-v2-link {
        width: fit-content;
        min-height: 36px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 12px;
        border-radius: 13px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        text-decoration: none;
        font-size: 12px;
        font-weight: 950;
    }

    .submissions-v2-actions-row {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
        margin-top: auto;
    }

    .submissions-v2-delete {
        width: 100%;
        min-height: 45px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 15px;
        border: 1px solid rgba(248, 113, 113, .24);
        color: #ffffff;
        background: rgba(239, 68, 68, .82);
        cursor: pointer;
        font-size: 13px;
        font-weight: 950;
        transition: .15s ease;
    }

    .submissions-v2-delete:hover {
        transform: translateY(-1px);
    }

    .submissions-v2-empty {
        min-height: 320px;
        display: grid;
        place-items: center;
        padding: 42px 24px;
        border-radius: 30px;
        color: #94a3b8;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .08), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .84));
        border: 1px dashed rgba(148, 163, 184, .20);
        box-shadow: 0 18px 46px rgba(0, 0, 0, .22);
        text-align: center;
        font-size: 15px;
        font-weight: 850;
    }

    .submissions-v2-empty-icon {
        width: 76px;
        height: 76px;
        display: grid;
        place-items: center;
        margin: 0 auto 15px;
        border-radius: 26px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 34px;
    }

    @@media (max-width: 1200px) {
        .submissions-v2-hero,
        .submissions-v2-toolbar {
            grid-template-columns: 1fr;
        }

        .submissions-v2-visible-box {
            min-width: 0;
        }
    }

    @@media (max-width: 760px) {
        .submissions-v2-hero {
            border-radius: 22px;
            padding: 16px;
        }

        .submissions-v2-hero-side {
            grid-template-columns: 1fr;
        }

        .submissions-v2-grid {
            grid-template-columns: 1fr;
        }

        .submissions-v2-card {
            border-radius: 22px;
            padding: 16px;
        }

        .submissions-v2-top {
            grid-template-columns: 54px minmax(0, 1fr);
        }

        .submissions-v2-status {
            grid-column: 1 / -1;
            justify-self: start;
        }

        .submissions-v2-detail-row {
            grid-template-columns: 24px minmax(0, 1fr);
        }

        .submissions-v2-detail-row b {
            grid-column: 1 / -1;
            text-align: left;
        }
    }
</style>

<div class="submissions-v2">
    <section class="submissions-v2-hero">
        <div class="submissions-v2-hero-main">
            <div class="submissions-v2-kicker">
                Teslim Merkezi
            </div>

            <h2>Öğrenci teslimleri daha okunabilir.</h2>

            <p>
                Öğrenci cevaplarını, teslim linklerini, ders ve sınıf bilgisini, not ve geri dönüş durumunu
                tek ekranda koyu tema ile takip edin.
            </p>

            <div class="submissions-v2-actions">
                <a asp-controller="Reports" asp-action="Index" class="submissions-v2-soft-action">
                    📈 Raporlara Git
                </a>

                <a asp-controller="Dashboard" asp-action="Index" class="submissions-v2-soft-action">
                    📊 Kontrol Paneli
                </a>
            </div>
        </div>

        <div class="submissions-v2-hero-side">
            <div class="submissions-v2-summary-card">
                <strong>@totalCount</strong>
                <span>Toplam Teslim</span>
            </div>

            <div class="submissions-v2-summary-card">
                <strong>@evaluatedCount</strong>
                <span>Değerlendirilen</span>
            </div>

            <div class="submissions-v2-summary-card">
                <strong>@pendingCount</strong>
                <span>Bekleyen</span>
            </div>

            <div class="submissions-v2-summary-card">
                <strong>@linkedCount</strong>
                <span>Dosya / Link</span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="submissions-v2-alert success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="submissions-v2-alert error">
            @TempData["Error"]
        </div>
    }

    <section class="submissions-v2-toolbar">
        <div class="submissions-v2-search">
            <span>🔍</span>

            <input id="submissionSearchInput"
                   type="search"
                   placeholder="Öğrenci no, ödev, ders, sınıf veya öğretmen ara..."
                   autocomplete="off" />
        </div>

        <div class="submissions-v2-visible-box">
            <strong id="visibleSubmissionCount">@submissions.Count</strong>
            <span>teslim gösteriliyor</span>
        </div>
    </section>

    @if (!submissions.Any())
    {
        <div class="submissions-v2-empty">
            <div>
                <div class="submissions-v2-empty-icon">📥</div>
                Henüz öğrenci teslimi bulunmuyor.
            </div>
        </div>
    }
    else
    {
        <section class="submissions-v2-grid">
            @foreach (var item in submissions)
            {
                var id = GetText(item, "Id");
                var assignmentTitle = FirstNonEmpty(GetText(item, "AssignmentTitle"), GetText(item, "HomeworkTitle"), "Ödev");
                var lesson = FirstNonEmpty(GetText(item, "Lesson"), GetText(item, "LessonName"), "-");
                var className = FirstNonEmpty(GetText(item, "ClassName"), "-");
                var teacherName = FirstNonEmpty(GetText(item, "TeacherName"), "-");
                var studentName = FirstNonEmpty(GetText(item, "StudentName"), "-");
                var studentNo = FirstNonEmpty(GetText(item, "StudentNo"), GetText(item, "Number"), "-");
                var answer = FirstNonEmpty(GetText(item, "Answer"), GetText(item, "SubmissionText"), "Öğrenci açıklama yazmamış.");
                var link = FirstNonEmpty(GetText(item, "Link"), GetText(item, "FileUrl"), GetText(item, "SubmissionFileUrl"));
                var status = FirstNonEmpty(GetText(item, "Status"), "Teslim Edildi");
                var grade = FirstNonEmpty(GetText(item, "Grade"), GetText(item, "Score"), GetText(item, "Point"));
                var feedback = FirstNonEmpty(GetText(item, "Feedback"), GetText(item, "Comment"));
                var evaluated = IsEvaluated(item);

                <article class="submissions-v2-card"
                         data-search="@($"{studentName} {studentNo} {assignmentTitle} {lesson} {className} {teacherName} {answer}")">

                    <div class="submissions-v2-top">
                        <div class="submissions-v2-icon">
                            📥
                        </div>

                        <div class="submissions-v2-title">
                            <h3>@assignmentTitle</h3>
                            <p>Öğrenci No: @studentNo</p>
                        </div>

                        <span class="submissions-v2-status @(evaluated ? "evaluated" : "waiting")">
                            @(evaluated ? "Değerlendirildi" : "Bekliyor")
                        </span>
                    </div>

                    <div class="submissions-v2-details">
                        <div class="submissions-v2-detail-row">
                            <span>🎒</span>
                            <strong>Öğrenci</strong>
                            <b>@studentName</b>
                        </div>

                        <div class="submissions-v2-detail-row">
                            <span>📚</span>
                            <strong>Ders</strong>
                            <b>@lesson</b>
                        </div>

                        <div class="submissions-v2-detail-row">
                            <span>🏫</span>
                            <strong>Sınıf</strong>
                            <b>@className</b>
                        </div>

                        <div class="submissions-v2-detail-row">
                            <span>👨‍🏫</span>
                            <strong>Öğretmen</strong>
                            <b>@teacherName</b>
                        </div>

                        <div class="submissions-v2-detail-row">
                            <span>📌</span>
                            <strong>Durum</strong>
                            <b>@status</b>
                        </div>
                    </div>

                    <div class="submissions-v2-answer-box">
                        <strong>Öğrenci Cevabı</strong>
                        <p>@answer</p>

                        @if (!string.IsNullOrWhiteSpace(link))
                        {
                            <a href="@link" target="_blank" rel="noopener noreferrer" class="submissions-v2-link">
                                Dosya / Link Aç
                            </a>
                        }
                    </div>

                    <div class="submissions-v2-grade-box">
                        <strong>Değerlendirme</strong>
                        <p><b>Not:</b> @SafeText(grade)</p>
                        <p><b>Geri dönüş:</b> @SafeText(feedback)</p>
                    </div>

                    <div class="submissions-v2-actions-row">
                        <form asp-controller="Submissions"
                              asp-action="Delete"
                              method="post"
                              data-delete="true"
                              data-delete-name="@assignmentTitle">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@id" />

                            <button type="submit" class="submissions-v2-delete">
                                🗑️ Sil
                            </button>
                        </form>
                    </div>
                </article>
            }
        </section>

        <div id="noSubmissionResult" class="submissions-v2-empty" style="display:none;">
            <div>
                <div class="submissions-v2-empty-icon">🔍</div>
                Aradığınız kritere uygun teslim bulunamadı.
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const submissionSearchInput = document.getElementById("submissionSearchInput");
        const submissionCards = Array.from(document.querySelectorAll(".submissions-v2-card"));
        const visibleSubmissionCount = document.getElementById("visibleSubmissionCount");
        const noSubmissionResult = document.getElementById("noSubmissionResult");

        function normalizeSubmissionText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterSubmissions() {
            const query = normalizeSubmissionText(submissionSearchInput?.value || "");
            let count = 0;

            submissionCards.forEach(card => {
                const searchable = normalizeSubmissionText(card.dataset.search || "");
                const show = query === "" || searchable.includes(query);

                card.style.display = show ? "" : "none";

                if (show) {
                    count++;
                }
            });

            if (visibleSubmissionCount) {
                visibleSubmissionCount.textContent = count;
            }

            if (noSubmissionResult) {
                noSubmissionResult.style.display = count === 0 ? "grid" : "none";
            }
        }

        if (submissionSearchInput) {
            submissionSearchInput.addEventListener("input", function (event) {
                event.preventDefault();
                filterSubmissions();
            });

            submissionSearchInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        filterSubmissions();
    </script>
}
