@using System.Collections
@using System.Reflection
@model IEnumerable<object>

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Duyurular";
    ViewData["PageTitle"] = "Duyurular";
    ViewData["PageSubtitle"] = "Okul yönetimi ve öğretmen akışındaki duyuruları takip edin.";

    var announcements = (Model ?? Enumerable.Empty<object>()).ToList();

    if (!announcements.Any())
    {
        announcements = ListFrom(ViewData["Announcements"] ?? ViewData["TeacherAnnouncements"] ?? ViewData["Duyurular"]);
    }

    var totalCount = announcements.Count;
    var todayCount = announcements.Count(x => IsToday(GetDate(x, "CreatedAt", "createdAt", "Date", "date", "PublishedAt", "publishedAt")));
    var adminCount = announcements.Count(x => First(Get(x, "Author", "author"), Get(x, "CreatedBy", "createdBy")).Contains("admin", StringComparison.OrdinalIgnoreCase));
}

@functions {
    private List<object> ListFrom(object? raw)
    {
        if (raw == null || raw is string)
        {
            return new List<object>();
        }

        if (raw is IEnumerable enumerable)
        {
            return enumerable.Cast<object>().ToList();
        }

        return new List<object>();
    }

    private string Get(object? item, params string[] keys)
    {
        if (item == null)
        {
            return "";
        }

        if (item is IDictionary<string, object> dict)
        {
            foreach (var key in keys)
            {
                if (dict.TryGetValue(key, out var value) && value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        var type = item.GetType();

        foreach (var key in keys)
        {
            var prop = type.GetProperty(key, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);

            if (prop != null)
            {
                var value = prop.GetValue(item);

                if (value != null)
                {
                    return value.ToString() ?? "";
                }
            }
        }

        return "";
    }

    private string First(params string[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "";
    }

    private DateTime? GetDate(object? item, params string[] keys)
    {
        var text = Get(item, keys);

        if (DateTime.TryParse(text, out var date))
        {
            return date;
        }

        return null;
    }

    private bool IsToday(DateTime? date)
    {
        return date != null && date.Value.Date == DateTime.Today;
    }

    private string DateText(DateTime? date)
    {
        return date?.ToString("dd.MM.yyyy HH:mm") ?? "-";
    }
}

<style>
    .ta-v2 {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .ta-v2-hero,
    .ta-v2-toolbar,
    .ta-v2-card,
    .ta-v2-empty {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .ta-v2-hero {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
    }

    .ta-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .ta-v2-hero h1 {
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .ta-v2-hero p {
        max-width: 780px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .ta-v2-summary {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .ta-v2-summary-card {
        min-height: 106px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .ta-v2-summary-card strong {
        display: block;
        color: #ffffff;
        font-size: 30px;
        font-weight: 950;
    }

    .ta-v2-summary-card span {
        display: block;
        margin-top: 6px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .ta-v2-toolbar {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 14px;
        padding: 16px;
        border-radius: 28px;
    }

    .ta-v2-search {
        min-height: 54px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 0 15px;
        border-radius: 18px;
        background: rgba(7, 17, 31, .58);
        border: 1px solid rgba(148, 163, 184, .18);
    }

    .ta-v2-search input {
        width: 100%;
        border: 0;
        outline: 0;
        color: #ffffff;
        background: transparent;
        font-size: 14px;
        font-weight: 800;
    }

    .ta-v2-search input::placeholder {
        color: #64748b;
    }

    .ta-v2-visible {
        min-width: 170px;
        min-height: 54px;
        display: grid;
        align-content: center;
        padding: 0 15px;
        border-radius: 18px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .ta-v2-visible strong {
        color: #ffffff;
        font-size: 24px;
        font-weight: 950;
    }

    .ta-v2-visible span {
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .ta-v2-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(370px, 1fr));
        gap: 16px;
    }

    .ta-v2-card {
        position: relative;
        overflow: hidden;
        display: grid;
        gap: 15px;
        min-height: 100%;
        padding: 20px;
        border-radius: 28px;
        transition: .16s ease;
    }

    .ta-v2-card:hover {
        transform: translateY(-2px);
        border-color: rgba(125, 211, 252, .28);
        box-shadow: 0 22px 54px rgba(0, 0, 0, .27);
    }

    .ta-v2-top {
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr);
        gap: 13px;
        align-items: center;
    }

    .ta-v2-icon {
        width: 58px;
        height: 58px;
        display: grid;
        place-items: center;
        border-radius: 20px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 26px;
    }

    .ta-v2-title h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
        line-height: 1.2;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .ta-v2-title p {
        margin: 5px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .ta-v2-content {
        padding: 14px;
        border-radius: 18px;
        color: #cbd5e1;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 750;
        line-height: 1.65;
        overflow-wrap: anywhere;
    }

    .ta-v2-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .ta-v2-tag {
        min-height: 31px;
        display: inline-flex;
        align-items: center;
        padding: 0 10px;
        border-radius: 999px;
        color: #bfdbfe;
        background: rgba(37, 99, 235, .14);
        border: 1px solid rgba(96, 165, 250, .20);
        font-size: 12px;
        font-weight: 950;
    }

    .ta-v2-empty {
        min-height: 320px;
        display: grid;
        place-items: center;
        padding: 42px 24px;
        border-radius: 30px;
        color: #94a3b8;
        text-align: center;
        font-size: 15px;
        font-weight: 850;
    }

    @@media (max-width: 1100px) {
        .ta-v2-hero,
        .ta-v2-toolbar {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .ta-v2-hero,
        .ta-v2-card,
        .ta-v2-empty {
            border-radius: 22px;
            padding: 16px;
        }

        .ta-v2-summary,
        .ta-v2-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="ta-v2">
    <section class="ta-v2-hero">
        <div>
            <div class="ta-v2-kicker">Duyuru Akışı</div>

            <h1>Okul duyurularını takip edin.</h1>

            <p>
                Yönetimden ve sistemden gelen duyuruları koyu tema içinde daha okunabilir şekilde görüntüleyin.
            </p>
        </div>

        <div class="ta-v2-summary">
            <div class="ta-v2-summary-card">
                <strong>@totalCount</strong>
                <span>Toplam Duyuru</span>
            </div>

            <div class="ta-v2-summary-card">
                <strong>@todayCount</strong>
                <span>Bugünkü</span>
            </div>

            <div class="ta-v2-summary-card">
                <strong>@adminCount</strong>
                <span>Admin Kaynaklı</span>
            </div>

            <div class="ta-v2-summary-card">
                <strong>@Math.Max(0, totalCount - adminCount)</strong>
                <span>Diğer</span>
            </div>
        </div>
    </section>

    <section class="ta-v2-toolbar">
        <div class="ta-v2-search">
            <span>🔍</span>
            <input id="teacherAnnouncementSearchInput" type="search" placeholder="Duyuru başlığı veya içerik ara..." autocomplete="off" />
        </div>

        <div class="ta-v2-visible">
            <strong id="visibleTeacherAnnouncementCount">@announcements.Count</strong>
            <span>duyuru gösteriliyor</span>
        </div>
    </section>

    @if (!announcements.Any())
    {
        <div class="ta-v2-empty">
            Henüz duyuru yok.
        </div>
    }
    else
    {
        <section class="ta-v2-grid">
            @foreach (var item in announcements)
            {
                var title = First(Get(item, "Title", "title"), "Duyuru");
                var content = First(Get(item, "Content", "content"), Get(item, "Message", "message"), "-");
                var target = First(Get(item, "Target", "target"), Get(item, "Audience", "audience"), "Öğretmen");
                var author = First(Get(item, "Author", "author"), Get(item, "CreatedBy", "createdBy"), "Admin");
                var date = DateText(GetDate(item, "CreatedAt", "createdAt", "Date", "date", "PublishedAt", "publishedAt"));

                <article class="ta-v2-card"
                         data-search="@($"{title} {content} {target} {author}")">

                    <div class="ta-v2-top">
                        <div class="ta-v2-icon">📣</div>

                        <div class="ta-v2-title">
                            <h3>@title</h3>
                            <p>@date tarihinde yayınlandı</p>
                        </div>
                    </div>

                    <div class="ta-v2-tags">
                        <span class="ta-v2-tag">🎯 @target</span>
                        <span class="ta-v2-tag">✍️ @author</span>
                    </div>

                    <div class="ta-v2-content">
                        @content
                    </div>
                </article>
            }
        </section>

        <div id="noTeacherAnnouncementResult" class="ta-v2-empty" style="display:none;">
            Aradığınız kritere uygun duyuru bulunamadı.
        </div>
    }
</div>

@section Scripts {
    <script>
        const teacherAnnouncementSearchInput = document.getElementById("teacherAnnouncementSearchInput");
        const teacherAnnouncementCards = Array.from(document.querySelectorAll(".ta-v2-card"));
        const visibleTeacherAnnouncementCount = document.getElementById("visibleTeacherAnnouncementCount");
        const noTeacherAnnouncementResult = document.getElementById("noTeacherAnnouncementResult");

        function normalizeTeacherAnnouncementText(value) {
            return (value || "")
                .toString()
                .toLocaleLowerCase("tr-TR")
                .replaceAll("ı", "i")
                .replaceAll("ğ", "g")
                .replaceAll("ü", "u")
                .replaceAll("ş", "s")
                .replaceAll("ö", "o")
                .replaceAll("ç", "c")
                .replaceAll("İ", "i")
                .trim();
        }

        function filterTeacherAnnouncements() {
            const query = normalizeTeacherAnnouncementText(teacherAnnouncementSearchInput?.value || "");
            let count = 0;

            teacherAnnouncementCards.forEach(card => {
                const searchable = normalizeTeacherAnnouncementText(card.dataset.search || "");
                const show = query === "" || searchable.includes(query);

                card.style.display = show ? "" : "none";

                if (show) {
                    count++;
                }
            });

            if (visibleTeacherAnnouncementCount) {
                visibleTeacherAnnouncementCount.textContent = count;
            }

            if (noTeacherAnnouncementResult) {
                noTeacherAnnouncementResult.style.display = count === 0 ? "grid" : "none";
            }
        }

        if (teacherAnnouncementSearchInput) {
            teacherAnnouncementSearchInput.addEventListener("input", filterTeacherAnnouncements);
            teacherAnnouncementSearchInput.addEventListener("keydown", function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                }
            });
        }

        filterTeacherAnnouncements();
    </script>
}