@model List<mvc_web.Models.TeacherAnnouncementViewModel>

@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Duyurular";
    ViewData["PageTitle"] = "Duyurular";
    ViewData["PageSubtitle"] = "Admin tarafından öğretmenlere yayınlanan duyuruları görüntüleyin.";

    var announcements = Model ?? new List<mvc_web.Models.TeacherAnnouncementViewModel>();
}

<div class="teacher-announcements-page">
    <section class="announcements-hero">
        <div>
            <div class="hero-kicker">Öğretmen Paneli</div>
            <h1>Duyurular</h1>
            <p>Admin tarafından öğretmenlere veya tüm okula gönderilen duyurular burada görünür.</p>
        </div>

        <div class="announcement-count-card">
            <div class="count-icon">📣</div>
            <div>
                <strong>@announcements.Count</strong>
                <span>Duyuru</span>
            </div>
        </div>
    </section>

    @if (!announcements.Any())
    {
        <div class="empty-announcement">
            <div class="empty-icon">📭</div>
            <h2>Henüz duyuru yok</h2>
            <p>Admin öğretmenlere veya tüm okula duyuru yayınladığında burada görünecek.</p>
        </div>
    }
    else
    {
        <section class="announcement-grid">
            @foreach (var item in announcements)
            {
                <article class="announcement-card-premium">
                    <div class="announcement-top">
                        <div class="announcement-icon">📢</div>

                        <div>
                            <h2>@item.Title</h2>
                            <p>
                                @item.Author tarafından yayınlandı
                            </p>
                        </div>
                    </div>

                    <div class="announcement-content">
                        @item.Content
                    </div>

                    <div class="announcement-footer">
                        <span class="target-pill">
                            🎯 @item.Target
                        </span>

                        <span class="date-pill">
                            🕒 @(item.CreatedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                        </span>
                    </div>
                </article>
            }
        </section>
    }
</div>

<style>
    .teacher-announcements-page {
        display: grid;
        gap: 20px;
    }

    .announcements-hero {
        background:
            radial-gradient(circle at top left, rgba(6, 182, 212, .16), transparent 34%),
            linear-gradient(135deg, #ffffff, #f8fafc);
        border: 1px solid rgba(255,255,255,.75);
        box-shadow: 0 22px 55px rgba(15, 23, 42, .08);
        border-radius: 32px;
        padding: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 22px;
    }

    .hero-kicker {
        color: #06b6d4;
        font-size: 13px;
        font-weight: 950;
        margin-bottom: 4px;
    }

    .announcements-hero h1 {
        margin: 0;
        color: #0f172a;
        font-size: 34px;
        font-weight: 950;
        letter-spacing: -.8px;
    }

    .announcements-hero p {
        margin: 8px 0 0;
        color: #64748b;
        font-weight: 800;
        line-height: 1.5;
    }

    .announcement-count-card {
        min-width: 170px;
        background: #fff;
        border: 1px solid #eef2f7;
        border-radius: 26px;
        padding: 18px;
        display: flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, .07);
    }

    .count-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        background: #cffafe;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 27px;
    }

    .announcement-count-card strong {
        display: block;
        color: #0f172a;
        font-size: 30px;
        font-weight: 950;
        line-height: 1;
    }

    .announcement-count-card span {
        display: block;
        margin-top: 6px;
        color: #64748b;
        font-weight: 900;
    }

    .announcement-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 18px;
    }

    .announcement-card-premium {
        background: #fff;
        border: 1px solid #eef2f7;
        border-radius: 30px;
        padding: 22px;
        display: grid;
        gap: 16px;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
        transition: .18s ease;
    }

    .announcement-card-premium:hover {
        transform: translateY(-3px);
        box-shadow: 0 24px 55px rgba(15, 23, 42, .10);
    }

    .announcement-top {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .announcement-icon {
        width: 58px;
        height: 58px;
        border-radius: 20px;
        background: #fef3c7;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 27px;
        flex: 0 0 auto;
    }

    .announcement-top h2 {
        margin: 0;
        color: #0f172a;
        font-size: 22px;
        font-weight: 950;
        word-break: break-word;
    }

    .announcement-top p {
        margin: 4px 0 0;
        color: #64748b;
        font-weight: 850;
    }

    .announcement-content {
        background: #f8fafc;
        border: 1px solid #eef2f7;
        color: #334155;
        border-radius: 18px;
        padding: 15px;
        min-height: 90px;
        font-weight: 800;
        line-height: 1.55;
        word-break: break-word;
    }

    .announcement-footer {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .target-pill,
    .date-pill {
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        font-weight: 950;
    }

    .target-pill {
        background: #eef2ff;
        color: #3730a3;
    }

    .date-pill {
        background: #dcfce7;
        color: #166534;
    }

    .empty-announcement {
        background: #fff;
        border: 1px dashed #cbd5e1;
        border-radius: 30px;
        padding: 44px;
        text-align: center;
        box-shadow: 0 18px 42px rgba(15, 23, 42, .07);
    }

    .empty-icon {
        font-size: 46px;
        margin-bottom: 12px;
    }

    .empty-announcement h2 {
        margin: 0;
        color: #0f172a;
        font-size: 25px;
        font-weight: 950;
    }

    .empty-announcement p {
        color: #64748b;
        font-weight: 850;
    }

    @@media (max-width: 760px) {
        .announcements-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .announcement-count-card {
            width: 100%;
        }

        .announcement-grid {
            grid-template-columns: 1fr;
        }
    }
</style>