@model List<PasswordRequestViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Şifre Talepleri";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="request-create-panel">
    <div>
        <div class="section-title">Test Talebi Oluştur</div>
        <div class="section-subtitle">
            Gerçek kullanıcı talebi yoksa sistemi test etmek için örnek talep ekleyebilirsin.
        </div>
    </div>

    <form asp-controller="PasswordRequests" asp-action="CreateTest" method="post" class="inline-request-form">
        @Html.AntiForgeryToken()

        <input class="form-control compact-input" name="Name" placeholder="Ad Soyad" />
        <input class="form-control compact-input" name="Number" placeholder="Numara" />

        <select class="form-control compact-input" name="Role">
            <option value="Öğrenci">Öğrenci</option>
            <option value="Öğretmen">Öğretmen</option>
            <option value="Veli">Veli</option>
        </select>

        <button class="btn btn-primary" type="submit">
            ➕ Test Talebi
        </button>
    </form>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">🔐</div>
        <div class="empty-title">Henüz şifre talebi yok</div>
        <div class="empty-text">Şifre sıfırlama talepleri burada görünecek.</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var item in Model)
        {
            var roleBadge = item.Role == "Öğretmen"
                ? "badge-cyan"
                : item.Role == "Veli"
                    ? "badge-orange"
                    : "badge-purple";

            var statusBadge = item.Status == "Onaylandı"
                ? "badge-green"
                : item.Status == "Reddedildi"
                    ? "badge-red"
                    : "badge-orange";

            <div class="data-card">
                <div class="data-card-header">
                    <div class="data-card-icon">🔐</div>
                    <div>
                        <div class="data-card-title">@item.Name</div>
                        <div class="data-card-subtitle">No: @item.Number</div>
                    </div>
                </div>

                <div class="badge-row">
                    <span class="badge @roleBadge">@item.Role</span>
                    <span class="badge @statusBadge">@item.Status</span>
                </div>

                <div class="info-line">
                    <span>📝</span>
                    <span>@item.Note</span>
                </div>

                <div class="card-actions">
                    <form asp-controller="PasswordRequests" asp-action="Approve" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-success" type="submit" @(item.Status == "Onaylandı" ? "disabled" : "")>
                            ✅ Onayla
                        </button>
                    </form>

                    <form asp-controller="PasswordRequests" asp-action="Reject" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-warning" type="submit" @(item.Status == "Reddedildi" ? "disabled" : "")>
                            ❌ Reddet
                        </button>
                    </form>

                    <form asp-controller="PasswordRequests" asp-action="Delete" method="post" onsubmit="return confirmDelete('Şifre talebi silinsin mi?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@item.Id" />
                        <button class="btn btn-danger" type="submit">
                            🗑️ Sil
                        </button>
                    </form>
                </div>
            </div>
        }
    </div>
}