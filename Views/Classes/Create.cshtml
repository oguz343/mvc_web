@model mvc_web.Models.ClassViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Yeni Sınıf";
    ViewData["PageTitle"] = "Yeni Sınıf";
    ViewData["PageSubtitle"] = "Sınıf seviyesini, şubesini, kapasitesini ve sınıf öğretmenini seçerek yeni sınıf oluşturun.";

    var teachers = Model?.Teachers ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<style>
    .final-form-page {
        width: 100%;
        display: grid;
        gap: 18px;
    }

    .final-form-hero,
    .final-form-card,
    .final-form-side {
        border: 1px solid rgba(148, 163, 184, .18);
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .10), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        box-shadow: 0 18px 48px rgba(0, 0, 0, .24);
        backdrop-filter: blur(16px);
    }

    .final-form-hero {
        padding: 24px;
        border-radius: 32px;
    }

    .final-form-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .final-form-hero h1 {
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .final-form-hero p {
        max-width: 820px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .final-form-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 18px;
        align-items: start;
    }

    .final-form-card,
    .final-form-side {
        padding: 22px;
        border-radius: 30px;
    }

    .final-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .final-form-field {
        display: grid;
        gap: 8px;
    }

    .final-form-field.full {
        grid-column: 1 / -1;
    }

    .final-form-field label {
        color: #dbeafe;
        font-size: 13px;
        font-weight: 950;
    }

    .final-form-field input,
    .final-form-field select,
    .final-form-field textarea {
        width: 100%;
        min-height: 48px;
        padding: 0 13px;
        border-radius: 15px;
        border: 1px solid rgba(148, 163, 184, .18);
        outline: none;
        color: #ffffff;
        background: rgba(7, 17, 31, .58);
        font-size: 14px;
        font-weight: 750;
    }

    .final-form-field textarea {
        min-height: 150px;
        padding-top: 13px;
        resize: vertical;
        line-height: 1.55;
    }

    .final-form-field input:focus,
    .final-form-field select:focus,
    .final-form-field textarea:focus {
        border-color: rgba(103, 232, 249, .45);
        box-shadow: 0 0 0 4px rgba(56, 189, 248, .09);
    }

    .final-form-field option {
        color: #0f172a;
        background: #ffffff;
    }

    .final-form-actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 16px;
    }

    .final-form-save,
    .final-form-back {
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 16px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 14px;
        font-weight: 950;
    }

    .final-form-save {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border-color: rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .final-form-back {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border-color: rgba(148, 163, 184, .18);
    }

    .final-form-side h3 {
        margin: 0;
        color: #ffffff;
        font-size: 20px;
        font-weight: 950;
    }

    .final-form-side p {
        margin: 8px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 750;
        line-height: 1.55;
    }

    .final-note-list {
        display: grid;
        gap: 10px;
        margin-top: 16px;
    }

    .final-note {
        padding: 12px;
        border-radius: 16px;
        color: #dbeafe;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 800;
        line-height: 1.45;
    }

    @@media (max-width: 1100px) {
        .final-form-layout {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .final-form-hero,
        .final-form-card,
        .final-form-side {
            border-radius: 22px;
            padding: 16px;
        }

        .final-form-grid {
            grid-template-columns: 1fr;
        }

        .final-form-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .final-form-save,
        .final-form-back {
            width: 100%;
        }
    }
</style>

<div class="final-form-page">
    <section class="final-form-hero">
        <div class="final-form-kicker">Sınıf Oluştur</div>

        <h1>Yeni sınıf oluşturun.</h1>

        <p>
            9, 10, 11, 12 seviyelerinden birini ve A-E arası şube seçerek sınıfı oluşturun. İsterseniz sınıf öğretmenini de mevcut öğretmenlerden seçebilirsiniz.
        </p>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <section class="final-form-layout">
        <form asp-controller="Classes"
              asp-action="Create"
              method="post"
              class="final-form-card">

            @Html.AntiForgeryToken()

            <div class="final-form-grid">
                <div class="final-form-field">
                    <label>Sınıf Seviyesi</label>
                    <select asp-for="Grade" name="Grade" required>
                        <option value="">Seviye seçin</option>
                        <option value="9">9. Sınıf</option>
                        <option value="10">10. Sınıf</option>
                        <option value="11">11. Sınıf</option>
                        <option value="12">12. Sınıf</option>
                    </select>
                </div>

                <div class="final-form-field">
                    <label>Şube</label>
                    <select asp-for="Branch" name="Branch" required>
                        <option value="">Şube seçin</option>
                        <option value="A">A Şubesi</option>
                        <option value="B">B Şubesi</option>
                        <option value="C">C Şubesi</option>
                        <option value="D">D Şubesi</option>
                        <option value="E">E Şubesi</option>
                    </select>
                </div>

                <div class="final-form-field">
                    <label>Kapasite</label>
                    <input asp-for="Capacity"
                           name="Capacity"
                           type="number"
                           min="1"
                           max="80"
                           value="30"
                           required />
                </div>

                <div class="final-form-field">
                    <label>Sınıf Öğretmeni</label>
                    <select asp-for="TeacherId" name="TeacherId">
                        <option value="">Öğretmen seçilmedi</option>

                        @foreach (var teacher in teachers.Where(x => !string.IsNullOrWhiteSpace(x.Value)))
                        {
                            <option value="@teacher.Value">
                                @teacher.Text
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="final-form-actions">
                <a asp-controller="Classes"
                   asp-action="Index"
                   class="final-form-back">
                    Vazgeç
                </a>

                <button type="submit" class="final-form-save">
                    🏫 Sınıf Oluştur
                </button>
            </div>
        </form>

        <aside class="final-form-side">
            <h3>Sınıf Kuralları</h3>

            <p>
                Sınıf oluştururken şube adı serbest yazılmaz. Sistem düzenli kalması için seviye ve şube listeden seçilir.
            </p>

            <div class="final-note-list">
                <div class="final-note">🏫 Örnek sınıf adı: 9-A</div>
                <div class="final-note">👨‍🏫 Sınıf öğretmeni mevcut öğretmenlerden seçilir.</div>
                <div class="final-note">👥 Kapasite doluluk oranı sınıflar sayfasında görünür.</div>
            </div>
        </aside>
    </section>
</div>
