@model List<mvc_web.Models.ClassViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sınıflar";
    ViewData["PageTitle"] = "Sınıflar";
    ViewData["PageSubtitle"] = "Sınıfları, kontenjanları, öğrenci sayılarını ve sınıf öğretmenlerini koyu tema ile daha düzenli şekilde yönetin.";

    var classes = Model ?? new List<mvc_web.Models.ClassViewModel>();

    var totalClassCount = classes.Count;
    var totalStudentCount = classes.Sum(x => x.StudentCount < 0 ? 0 : x.StudentCount);
    var totalCapacity = classes.Sum(x => x.Capacity <= 0 ? 30 : x.Capacity);
    var assignedTeacherCount = classes.Count(x => !string.IsNullOrWhiteSpace(x.TeacherName));
    var averageFill = totalCapacity <= 0 ? 0 : Math.Min(100, (int)Math.Round((double)totalStudentCount * 100 / totalCapacity));

    string FillClass(int percent)
    {
        if (percent >= 90)
        {
            return "danger";
        }

        if (percent >= 70)
        {
            return "warning";
        }

        if (percent >= 40)
        {
            return "normal";
        }

        return "low";
    }
}

<style>
    .classes-v2 {
        width: 100%;
        max-width: none;
        display: grid;
        gap: 18px;
    }

    .classes-v2-hero {
        position: relative;
        overflow: hidden;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 380px;
        gap: 18px;
        padding: 24px;
        border-radius: 32px;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .15), transparent 34%),
            radial-gradient(circle at 100% 0%, rgba(139, 92, 246, .18), transparent 34%),
            linear-gradient(135deg, rgba(15, 23, 42, .94), rgba(17, 24, 39, .86));
        border: 1px solid rgba(148, 163, 184, .20);
        box-shadow: 0 24px 70px rgba(0, 0, 0, .28);
        backdrop-filter: blur(18px);
    }

    .classes-v2-hero::after {
        content: "";
        position: absolute;
        width: 390px;
        height: 390px;
        right: -180px;
        top: -190px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .22);
        pointer-events: none;
    }

    .classes-v2-hero-main,
    .classes-v2-hero-side {
        position: relative;
        z-index: 1;
    }

    .classes-v2-kicker {
        width: fit-content;
        min-height: 30px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border-radius: 999px;
        color: #67e8f9;
        background: rgba(56, 189, 248, .10);
        border: 1px solid rgba(103, 232, 249, .20);
        font-size: 11px;
        font-weight: 950;
        letter-spacing: .16em;
        text-transform: uppercase;
    }

    .classes-v2-hero h2 {
        max-width: 760px;
        margin: 14px 0 0;
        color: #ffffff;
        font-size: clamp(34px, 3.8vw, 58px);
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.06em;
    }

    .classes-v2-hero p {
        max-width: 760px;
        margin: 14px 0 0;
        color: #aab8cf;
        font-size: 15px;
        font-weight: 700;
        line-height: 1.65;
    }

    .classes-v2-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 20px;
    }

    .classes-v2-primary-action,
    .classes-v2-soft-action {
        min-height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 0 15px;
        border-radius: 15px;
        text-decoration: none;
        font-size: 13px;
        font-weight: 950;
        transition: .16s ease;
    }

    .classes-v2-primary-action {
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        border: 1px solid rgba(125, 211, 252, .22);
        box-shadow: 0 14px 30px rgba(37, 99, 235, .24);
    }

    .classes-v2-soft-action {
        color: #dbeafe;
        background: rgba(255, 255, 255, .060);
        border: 1px solid rgba(148, 163, 184, .18);
    }

    .classes-v2-primary-action:hover,
    .classes-v2-soft-action:hover {
        transform: translateY(-1px);
    }

    .classes-v2-hero-side {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .classes-v2-summary-card {
        min-height: 106px;
        padding: 16px;
        border-radius: 22px;
        background: rgba(255, 255, 255, .055);
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .classes-v2-summary-card strong {
        display: block;
        color: #ffffff;
        font-size: 30px;
        font-weight: 950;
        line-height: 1;
        letter-spacing: -.04em;
    }

    .classes-v2-summary-card span {
        display: block;
        margin-top: 7px;
        color: #94a3b8;
        font-size: 12px;
        font-weight: 850;
    }

    .classes-v2-alert {
        padding: 15px 17px;
        border-radius: 18px;
        font-weight: 850;
        line-height: 1.5;
        border: 1px solid rgba(148, 163, 184, .16);
    }

    .classes-v2-alert.success {
        color: #bbf7d0;
        background: rgba(34, 197, 94, .12);
        border-color: rgba(74, 222, 128, .20);
    }

    .classes-v2-alert.error {
        color: #fecaca;
        background: rgba(239, 68, 68, .12);
        border-color: rgba(248, 113, 113, .20);
    }

    .classes-v2-empty {
        min-height: 320px;
        display: grid;
        place-items: center;
        padding: 42px 24px;
        border-radius: 30px;
        color: #94a3b8;
        background:
            radial-gradient(circle at 0% 0%, rgba(56, 189, 248, .08), transparent 34%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .84));
        border: 1px dashed rgba(148, 163, 184, .20);
        box-shadow: 0 18px 46px rgba(0, 0, 0, .22);
        text-align: center;
        font-size: 15px;
        font-weight: 850;
    }

    .classes-v2-empty-icon {
        width: 76px;
        height: 76px;
        display: grid;
        place-items: center;
        margin: 0 auto 15px;
        border-radius: 26px;
        color: #ffffff;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        font-size: 34px;
    }

    .classes-v2-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(370px, 1fr));
        gap: 16px;
    }

    .classes-v2-card {
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        gap: 15px;
        min-height: 100%;
        padding: 20px;
        border-radius: 28px;
        background:
            radial-gradient(circle at 100% 0%, rgba(56, 189, 248, .075), transparent 36%),
            linear-gradient(135deg, rgba(17, 25, 46, .94), rgba(15, 23, 42, .86));
        border: 1px solid rgba(148, 163, 184, .18);
        box-shadow: 0 16px 44px rgba(0, 0, 0, .22);
        backdrop-filter: blur(16px);
        transition: .16s ease;
    }

    .classes-v2-card:hover {
        transform: translateY(-2px);
        border-color: rgba(125, 211, 252, .28);
        box-shadow: 0 22px 54px rgba(0, 0, 0, .27);
    }

    .classes-v2-card::after {
        content: "";
        position: absolute;
        width: 180px;
        height: 180px;
        right: -92px;
        top: -104px;
        border-radius: 999px;
        background: rgba(99, 102, 241, .13);
        pointer-events: none;
    }

    .classes-v2-top {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 64px minmax(0, 1fr);
        gap: 14px;
        align-items: center;
    }

    .classes-v2-icon {
        width: 64px;
        height: 64px;
        display: grid;
        place-items: center;
        border-radius: 22px;
        color: #ffffff;
        background:
            radial-gradient(circle at 28% 20%, rgba(255, 255, 255, .28), transparent 28%),
            linear-gradient(135deg, #2563eb, #7c3aed 58%, #06b6d4);
        box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
        font-size: 30px;
    }

    .classes-v2-title {
        min-width: 0;
    }

    .classes-v2-title h3 {
        margin: 0;
        color: #ffffff;
        font-size: 23px;
        font-weight: 950;
        line-height: 1.15;
        letter-spacing: -.035em;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .classes-v2-title p {
        margin: 6px 0 0;
        color: #94a3b8;
        font-size: 13px;
        font-weight: 850;
    }

    .classes-v2-tags {
        position: relative;
        z-index: 1;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }

    .classes-v2-tag {
        min-height: 31px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 10px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 950;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .classes-v2-tag.primary {
        color: #bfdbfe;
        background: rgba(37, 99, 235, .14);
        border-color: rgba(96, 165, 250, .20);
    }

    .classes-v2-tag.success {
        color: #bbf7d0;
        background: rgba(34, 197, 94, .13);
        border-color: rgba(74, 222, 128, .20);
    }

    .classes-v2-tag.warning {
        color: #fde68a;
        background: rgba(245, 158, 11, .13);
        border-color: rgba(251, 191, 36, .18);
    }

    .classes-v2-tag.danger {
        color: #fecaca;
        background: rgba(239, 68, 68, .13);
        border-color: rgba(248, 113, 113, .20);
    }

    .classes-v2-details {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 9px;
    }

    .classes-v2-detail-row {
        display: grid;
        grid-template-columns: 28px minmax(120px, .7fr) minmax(0, 1fr);
        gap: 9px;
        align-items: center;
        padding: 10px 11px;
        border-radius: 16px;
        color: #94a3b8;
        background: rgba(255, 255, 255, .045);
        border: 1px solid rgba(148, 163, 184, .12);
        font-size: 13px;
        font-weight: 750;
    }

    .classes-v2-detail-row strong {
        color: #dbeafe;
        font-weight: 950;
    }

    .classes-v2-detail-row b {
        min-width: 0;
        color: #ffffff;
        font-weight: 900;
        text-align: right;
        overflow-wrap: anywhere;
    }

    .classes-v2-progress {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 9px;
        padding: 14px;
        border-radius: 18px;
        background: rgba(7, 17, 31, .42);
        border: 1px solid rgba(148, 163, 184, .13);
    }

    .classes-v2-progress-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        color: #dbeafe;
        font-size: 13px;
        font-weight: 900;
    }

    .classes-v2-progress-head span:last-child {
        color: #ffffff;
        font-weight: 950;
    }

    .classes-v2-progress-rail {
        height: 10px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(148, 163, 184, .16);
    }

    .classes-v2-progress-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(135deg, #38bdf8, #6366f1);
    }

    .classes-v2-progress-fill.low {
        background: linear-gradient(135deg, #38bdf8, #2563eb);
    }

    .classes-v2-progress-fill.normal {
        background: linear-gradient(135deg, #22c55e, #14b8a6);
    }

    .classes-v2-progress-fill.warning {
        background: linear-gradient(135deg, #f59e0b, #f97316);
    }

    .classes-v2-progress-fill.danger {
        background: linear-gradient(135deg, #ef4444, #dc2626);
    }

    .classes-v2-actions-row {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-top: auto;
    }

    .classes-v2-edit,
    .classes-v2-delete {
        min-height: 45px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 15px;
        border: 1px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 13px;
        font-weight: 950;
        transition: .15s ease;
    }

    .classes-v2-edit {
        color: #ffffff;
        background: rgba(56, 189, 248, .11);
        border-color: rgba(125, 211, 252, .22);
    }

    .classes-v2-delete {
        width: 100%;
        color: #ffffff;
        background: rgba(239, 68, 68, .82);
        border-color: rgba(248, 113, 113, .24);
    }

    .classes-v2-edit:hover,
    .classes-v2-delete:hover {
        transform: translateY(-1px);
    }

    @@media (max-width: 1200px) {
        .classes-v2-hero {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 760px) {
        .classes-v2-hero {
            border-radius: 22px;
            padding: 16px;
        }

        .classes-v2-hero-side {
            grid-template-columns: 1fr;
        }

        .classes-v2-actions {
            flex-direction: column;
            align-items: stretch;
        }

        .classes-v2-primary-action,
        .classes-v2-soft-action {
            width: 100%;
        }

        .classes-v2-grid {
            grid-template-columns: 1fr;
        }

        .classes-v2-card {
            border-radius: 22px;
            padding: 16px;
        }

        .classes-v2-top {
            grid-template-columns: 56px minmax(0, 1fr);
        }

        .classes-v2-icon {
            width: 56px;
            height: 56px;
            font-size: 26px;
        }

        .classes-v2-detail-row {
            grid-template-columns: 24px minmax(0, 1fr);
        }

        .classes-v2-detail-row b {
            grid-column: 1 / -1;
            text-align: left;
        }

        .classes-v2-actions-row {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="classes-v2">
    <section class="classes-v2-hero">
        <div class="classes-v2-hero-main">
            <div class="classes-v2-kicker">
                Sınıf Merkezi
            </div>

            <h2>Sınıflar artık daha net ve daha düzenli.</h2>

            <p>
                Sınıf seviyelerini, şubeleri, kontenjanları, öğrenci sayılarını ve sınıf öğretmenlerini
                tek ekranda koyu tema ile daha rahat takip edin.
            </p>

            <div class="classes-v2-actions">
                <a asp-controller="Classes"
                   asp-action="Create"
                   class="classes-v2-primary-action">
                    🏫 Yeni Sınıf
                </a>

                <a asp-controller="Users"
                   asp-action="Index"
                   class="classes-v2-soft-action">
                    👥 Kullanıcılar
                </a>

                <a asp-controller="Lessons"
                   asp-action="Index"
                   class="classes-v2-soft-action">
                    📚 Ders Atamaları
                </a>
            </div>
        </div>

        <div class="classes-v2-hero-side">
            <div class="classes-v2-summary-card">
                <strong>@totalClassCount</strong>
                <span>Toplam Sınıf</span>
            </div>

            <div class="classes-v2-summary-card">
                <strong>@totalStudentCount</strong>
                <span>Toplam Öğrenci</span>
            </div>

            <div class="classes-v2-summary-card">
                <strong>@assignedTeacherCount</strong>
                <span>Öğretmen Atanmış</span>
            </div>

            <div class="classes-v2-summary-card">
                <strong>%@averageFill</strong>
                <span>Genel Doluluk</span>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="classes-v2-alert success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="classes-v2-alert error">
            @TempData["Error"]
        </div>
    }

    @if (!classes.Any())
    {
        <div class="classes-v2-empty">
            <div>
                <div class="classes-v2-empty-icon">🏫</div>
                Henüz sınıf eklenmedi.
            </div>
        </div>
    }
    else
    {
        <section class="classes-v2-grid">
            @foreach (var item in classes)
            {
                var className = string.IsNullOrWhiteSpace(item.Name) ? $"{item.Grade}-{item.Branch}" : item.Name;
                var teacherName = string.IsNullOrWhiteSpace(item.TeacherName) ? "Atanmadı" : item.TeacherName;
                var teacherBranch = string.IsNullOrWhiteSpace(item.TeacherBranch) ? "-" : item.TeacherBranch;
                var grade = item.Grade.ToString();
                var branch = string.IsNullOrWhiteSpace(item.Branch) ? "-" : item.Branch;
                var studentCount = item.StudentCount < 0 ? 0 : item.StudentCount;
                var capacity = item.Capacity <= 0 ? 30 : item.Capacity;
                var percent = Math.Min(100, (int)Math.Round((double)studentCount * 100 / capacity));
                var fillClass = FillClass(percent);

                <article class="classes-v2-card">
                    <div class="classes-v2-top">
                        <div class="classes-v2-icon">
                            🏫
                        </div>

                        <div class="classes-v2-title">
                            <h3>@className</h3>
                            <p>@grade. sınıf • @branch şubesi</p>
                        </div>
                    </div>

                    <div class="classes-v2-tags">
                        <span class="classes-v2-tag primary">
                            @className
                        </span>

                        <span class="classes-v2-tag @(percent >= 90 ? "danger" : percent >= 70 ? "warning" : "success")">
                            @studentCount / @capacity Öğrenci
                        </span>

                        @if (string.IsNullOrWhiteSpace(item.TeacherName))
                        {
                            <span class="classes-v2-tag warning">
                                Öğretmen Atanmadı
                            </span>
                        }
                        else
                        {
                            <span class="classes-v2-tag success">
                                Öğretmen Atandı
                            </span>
                        }
                    </div>

                    <div class="classes-v2-details">
                        <div class="classes-v2-detail-row">
                            <span>👨‍🏫</span>
                            <strong>Sınıf Öğretmeni</strong>
                            <b>@teacherName</b>
                        </div>

                        <div class="classes-v2-detail-row">
                            <span>📚</span>
                            <strong>Branş</strong>
                            <b>@teacherBranch</b>
                        </div>

                        <div class="classes-v2-detail-row">
                            <span>👥</span>
                            <strong>Kapasite</strong>
                            <b>@capacity kişi</b>
                        </div>

                        <div class="classes-v2-detail-row">
                            <span>🎒</span>
                            <strong>Kayıtlı Öğrenci</strong>
                            <b>@studentCount kişi</b>
                        </div>
                    </div>

                    <div class="classes-v2-progress">
                        <div class="classes-v2-progress-head">
                            <span>Doluluk oranı</span>
                            <span>%@percent</span>
                        </div>

                        <div class="classes-v2-progress-rail">
                            <div class="classes-v2-progress-fill @fillClass"
                                 style="width:@percent%">
                            </div>
                        </div>
                    </div>

                    <div class="classes-v2-actions-row">
                        <a asp-controller="Classes"
                           asp-action="Edit"
                           asp-route-id="@item.Id"
                           class="classes-v2-edit">
                            ✏️ Düzenle
                        </a>

                        <form asp-controller="Classes"
                              asp-action="Delete"
                              method="post"
                              data-delete="true"
                              data-delete-name="@className">

                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@item.Id" />

                            <button type="submit" class="classes-v2-delete">
                                🗑️ Sil
                            </button>
                        </form>
                    </div>
                </article>
            }
        </section>
    }
</div>
