@model List<mvc_web.Models.ClassViewModel>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sınıflar";

    var classes = Model ?? new List<mvc_web.Models.ClassViewModel>();
}

<div class="page-shell">
    <section class="page-header-card">
        <div>
            <div class="eyebrow">Yönetim Paneli</div>
            <h1>Sınıflar</h1>
            <p>Sınıf bilgilerini, kapasiteleri ve sınıf öğretmenlerini buradan yönetin.</p>
        </div>

        <div class="page-actions">
            <a asp-controller="Classes" asp-action="Create" class="btn-primary">
                🏫 Yeni Sınıf
            </a>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    @if (!classes.Any())
    {
        <div class="empty-state">
            Henüz sınıf eklenmedi.
        </div>
    }
    else
    {
        <section class="entity-grid">
            @foreach (var item in classes)
            {
                var className = string.IsNullOrWhiteSpace(item.Name) ? $"{item.Grade}-{item.Branch}" : item.Name;
                var teacherName = string.IsNullOrWhiteSpace(item.TeacherName) ? "Atanmadı" : item.TeacherName;
                var teacherBranch = string.IsNullOrWhiteSpace(item.TeacherBranch) ? "-" : item.TeacherBranch;
                var grade = item.Grade.ToString();
                var branch = string.IsNullOrWhiteSpace(item.Branch) ? "-" : item.Branch;
                var studentCount = item.StudentCount < 0 ? 0 : item.StudentCount;
                var capacity = item.Capacity <= 0 ? 30 : item.Capacity;
                var percent = Math.Min(100, (int)Math.Round((double)studentCount * 100 / capacity));

                <article class="entity-card">
                    <div class="entity-head">
                        <div class="entity-icon primary">🏫</div>

                        <div class="entity-title">
                            <h3>@className</h3>
                            <p>Seviye @grade • Şube @branch</p>
                        </div>
                    </div>

                    <div class="badge-row">
                        <span class="badge-pill badge-primary">@className</span>
                        <span class="badge-pill badge-success">@studentCount / @capacity Öğrenci</span>
                    </div>

                    <div class="meta-list">
                        <div class="meta-item">
                            <span>👨‍🏫</span>
                            <span>Sınıf Öğretmeni: @teacherName</span>
                        </div>

                        <div class="meta-item">
                            <span>📚</span>
                            <span>Branş: @teacherBranch</span>
                        </div>

                        <div class="meta-item">
                            <span>👥</span>
                            <span>Kapasite: @capacity</span>
                        </div>
                    </div>

                    <div class="progress-block">
                        <div class="progress-label">
                            <span>Doluluk Oranı</span>
                            <span>%@percent</span>
                        </div>

                        <div class="progress-rail">
                            <div class="progress-fill" style="width:@percent%"></div>
                        </div>
                    </div>

                    <div class="card-actions">
                        <a asp-controller="Classes" asp-action="Edit" asp-route-id="@item.Id" class="btn-secondary">
                            ✏️ Düzenle
                        </a>

                        <form asp-controller="Classes"
                              asp-action="Delete"
                              method="post"
                              class="inline-form js-delete-form"
                              data-delete-name="@className">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn-danger">🗑️ Sil</button>
                        </form>
                    </div>
                </article>
            }
        </section>
    }
</div>