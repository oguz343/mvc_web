@model mvc_web.Models.ClassViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Sınıf Düzenle";
}

<div class="class-form-page">
    <div class="page-header">
        <h1>Sınıf Düzenle</h1>
        <p>@Model.Name sınıfını güncelleyin.</p>
    </div>

    <div class="form-card">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Classes" asp-action="Edit" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Name" id="classNameInput" />

            <div class="form-grid">
                <div class="form-group">
                    <label>Sınıf Seviyesi</label>
                    <select asp-for="Grade" id="gradeSelect" class="form-control">
                        <option value="9">9</option>
                        <option value="10">10</option>
                        <option value="11">11</option>
                        <option value="12">12</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Şube</label>
                    <select asp-for="Branch" id="branchSelect" class="form-control">
                        <option value="A">A</option>
                        <option value="B">B</option>
                        <option value="C">C</option>
                        <option value="D">D</option>
                        <option value="E">E</option>
                        <option value="F">F</option>
                    </select>
                </div>

                <div class="form-group full">
                    <label>Sınıf Öğretmeni</label>
                    <select asp-for="TeacherId" asp-items="Model.Teachers" class="form-control"></select>
                </div>

                <div class="form-group">
                    <label>Kapasite</label>
                    <input asp-for="Capacity" type="number" min="1" class="form-control" />
                </div>

                <div class="form-group">
                    <label>Öğrenci Sayısı</label>
                    <input value="@Model.StudentCount" class="form-control" disabled />
                </div>
            </div>

            <div class="class-preview">
                Güncel sınıf adı otomatik oluşur:
                <strong id="classPreview">@Model.Name</strong>
            </div>

            <div class="actions">
                <button type="submit" class="btn-save">
                    💾 Değişiklikleri Kaydet
                </button>

                <a asp-controller="Classes" asp-action="Index" class="btn-back">
                    ← Geri Dön
                </a>
            </div>
        </form>
    </div>
</div>

<style>
    .page-header {
        background: #fff;
        border-radius: 28px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, .06);
    }

    .page-header h1 {
        margin: 0;
        color: #111827;
        font-size: 32px;
        font-weight: 900;
    }

    .page-header p {
        margin: 6px 0 0;
        color: #64748b;
        font-weight: 800;
    }

    .form-card {
        max-width: 760px;
        background: #fff;
        border-radius: 30px;
        padding: 28px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, .06);
    }

    .alert {
        padding: 14px 18px;
        border-radius: 18px;
        margin-bottom: 18px;
        font-weight: 900;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .form-group.full {
        grid-column: 1 / -1;
    }

    .form-group label {
        display: block;
        color: #111827;
        font-weight: 900;
        margin-bottom: 8px;
    }

    .form-control {
        width: 100%;
        border: 1px solid #e5e7eb;
        background: #f8fafc;
        border-radius: 18px;
        padding: 16px 18px;
        font-weight: 800;
        outline: none;
        color: #111827;
    }

    .form-control:focus {
        background: #fff;
        border-color: #4f46e5;
        box-shadow: 0 0 0 4px rgba(79, 70, 229, .12);
    }

    .class-preview {
        margin-top: 20px;
        background: #ffedd5;
        color: #9a3412;
        border-radius: 18px;
        padding: 14px 16px;
        font-weight: 900;
    }

    .actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 26px;
    }

    .btn-save,
    .btn-back {
        min-height: 52px;
        border: 0;
        border-radius: 16px;
        padding: 0 22px;
        font-weight: 900;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .btn-save {
        background: #4f46e5;
        color: #fff;
    }

    .btn-back {
        background: #eef2ff;
        color: #4338ca;
    }

    @@media (max-width: 720px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@section Scripts {
    <script>
        const gradeSelect = document.getElementById("gradeSelect");
        const branchSelect = document.getElementById("branchSelect");
        const classNameInput = document.getElementById("classNameInput");
        const classPreview = document.getElementById("classPreview");

        function updateClassName() {
            const name = `${gradeSelect.value}-${branchSelect.value}`;
            classNameInput.value = name;
            classPreview.innerText = name;
        }

        gradeSelect.addEventListener("change", updateClassName);
        branchSelect.addEventListener("change", updateClassName);

        updateClassName();
    </script>
}